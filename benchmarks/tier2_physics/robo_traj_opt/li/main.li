# robo_traj_opt — shared C oracle via LI_EXTRA_C (WP3 smoke-scale).

extern proc li_robo_traj_opt_kernel()
  requires true
  ensures true

extern proc li_robo_traj_opt_checksum() -> float
  requires true
  ensures true

extern proc li_rt_volatile_sink_f64(v: float) -> unit
  requires true
  ensures true

def main() raises IO -> int
  requires true
  ensures result == 0
  decreases 0
=
  li_robo_traj_opt_kernel()
  li_rt_volatile_sink_f64(li_robo_traj_opt_checksum())
  return 0
