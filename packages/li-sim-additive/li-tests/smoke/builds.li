import sim.additive

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_sim_additive_version() != 1:
    return 1
  if li_sim_additive_profile_contract() != sim_contract_sim_additive():
    return 2
  if li_sim_additive_studio_profile_id() != 5:
    return 3
  if run_additive_smoke() != 0:
    return 4
  if am_export_require_sim_pass() != 1:
    return 5
  if am_export_gcode_3mf_smoke() != 0:
    return 6
  return 0
