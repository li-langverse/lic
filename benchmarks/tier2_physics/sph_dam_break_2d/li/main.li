extern proc li_rt_volatile_sink_f64(v: float) -> unit
  requires true
  ensures true

extern proc li_sph_dam_2d_kernel()
  requires true
  ensures true

extern proc li_sph_dam_2d_checksum() -> float
  requires true
  ensures true

def main() raises IO -> int
  requires true
  ensures result == 0
  decreases 0
=
  li_sph_dam_2d_kernel()
  li_rt_volatile_sink_f64(li_sph_dam_2d_checksum())
  return 0
