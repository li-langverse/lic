# PH-ML Wave 11: @gpu matmul emit — LKIR progress via ml_gpu_matmul_lkir_progress.

import ml

@gpu
def ml_gpu_matmul_emit_stub() -> int raises IO
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  return ml_gpu_matmul_lkir_progress()

def main() -> int raises IO
  requires true
  ensures result == 0
  decreases 0
=
  if ml_gpu_matmul_emit_stub() != 1:
    return 1
  return 0
