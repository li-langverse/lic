# 2×2 float `@` codegen probe — runtime sink prevents DCE of ArrayMatMul2DF64 lowering.
# Contrast: Li.Discharge.mat2_at2_eval (Lean) vs MIR `A @ B` (no refinement lemma in semantics).

extern proc li_rt_volatile_sink_f64(v: float) -> unit
  requires true
  ensures true
  decreases 0

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var A: array[2, array[2, float]]
  var B: array[2, array[2, float]]
  A[0][0] = 1.0
  A[0][1] = 2.0
  A[1][0] = 3.0
  A[1][1] = 4.0
  B[0][0] = 5.0
  B[0][1] = 6.0
  B[1][0] = 7.0
  B[1][1] = 8.0
  var C: array[2, array[2, float]] = A @ B
  li_rt_volatile_sink_f64(C[1][1])
  return 0
