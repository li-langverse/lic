import ml_rl
import sim

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var sess: SimSessionStub = sim_session_stub_default()
  sim_session_apply_studio_profile(2, sess)
  var graph: JobGraphStub = job_graph_stub_default()
  if ml_rl_job_graph_collect(sess, 0.02, graph) != sim_status_ok():
    return 1
  if ml_rl_job_graph_train_step(graph, graph.samples_collected) != sim_status_ok():
    return 2
  if graph.train_step.dispatched != 1:
    return 3
  if ml_rl_job_graph_eval_step(graph, graph.samples_collected) != sim_status_ok():
    return 4
  if graph.eval_step.dispatched != 1:
    return 5
  return 0