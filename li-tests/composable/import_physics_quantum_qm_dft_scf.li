import physics.quantum

def smoke_qm_dft_scf_energy() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var v: int = li_std_physics_quantum_version()
  if v != 1:
    return 1
  var res: QmDftScfStubResult = qm_dft_scf_h2_lda_stub()
  if res.converged != 1:
    return 1
  if res.scf_iterations != 6:
    return 1
  return 0

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  return smoke_qm_dft_scf_energy()
