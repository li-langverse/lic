  if algo_id >= 101:
    if algo_id <= 117:
      return 2
  if algo_id >= 201:
    if algo_id <= 216:
      return 3
  if algo_id >= 301:
    if algo_id <= 305:
      return 4
  if algo_id >= 401:
    if algo_id <= 432:
      return 5
  if algo_id >= 501:
    if algo_id <= 505:
      return 6
  if algo_id >= 511:
    if algo_id <= 514:
      return 7
  if algo_id >= 521:
    if algo_id <= 523:
      return 8
  if algo_id >= 601:
    if algo_id <= 610:
      return 9
  if algo_id >= 701:
    if algo_id <= 707:
      return 10
  if algo_id >= 801:
    if algo_id <= 805:
      return 11
  if algo_id >= 901:
    if algo_id <= 903:
      return 12
  return 0

