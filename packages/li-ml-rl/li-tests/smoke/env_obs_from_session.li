import ml.rl
import sim

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var sess: SimSessionStub = sim_session_stub_default()
  var obs: EnvStepResult = env_obs_from_session(sess, 2, 0.02)
  if obs.env_index != 2:
    return 1
  if obs.obs1 != 0.02:
    return 2
  if obs.obs2 != 2.0:
    return 3
  if obs.act0 != 0.2:
    return 4
  return 0
