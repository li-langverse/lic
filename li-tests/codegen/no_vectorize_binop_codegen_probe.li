# Contrast probe: @no_vectorize def without @vectorized for → scalar element-wise binop.
extern proc li_rt_volatile_sink_f64(v: float) -> unit
  requires true
  ensures true

extern proc li_rt_sqrt(x: float) raises IO -> float
  requires true
  ensures true

@no_vectorize
def main() -> int raises IO
  requires true
  ensures result == 0
  decreases 0
=
  var x: array[4, float]
  var y: array[4, float]
  x[0] = li_rt_sqrt(1.1)
  x[1] = li_rt_sqrt(2.2)
  x[2] = li_rt_sqrt(3.3)
  x[3] = li_rt_sqrt(4.4)
  y[0] = li_rt_sqrt(5.5)
  y[1] = li_rt_sqrt(6.6)
  y[2] = li_rt_sqrt(7.7)
  y[3] = li_rt_sqrt(8.8)
  var z: array[4, float] = x * y
  var j: int = 0
  while j < 4
    li_rt_volatile_sink_f64(z[j])
    j = j + 1
  return 0
