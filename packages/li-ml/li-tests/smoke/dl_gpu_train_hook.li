# WP-ML-11: @gpu train hook — typecheck/verify only (full package link blocked on object ABI).

@gpu
def hook_probe(x: float) raises IO -> float
  requires true
  ensures result >= x
  decreases 0
=
  return x + 1.0

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if hook_probe(1.0) < 1.0:
    return 1
  return 0
