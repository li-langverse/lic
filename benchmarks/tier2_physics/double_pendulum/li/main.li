extern proc li_rt_volatile_sink_f64(v: float) -> unit
  requires true
  ensures true

extern proc li_double_pendulum_kernel()
  requires true
  ensures true

extern proc li_double_pendulum_checksum() -> float
  requires true
  ensures true

def main() raises IO -> int
  requires true
  ensures result == 0
  decreases 0
=
  li_double_pendulum_kernel()
  li_rt_volatile_sink_f64(li_double_pendulum_checksum())
  return 0
