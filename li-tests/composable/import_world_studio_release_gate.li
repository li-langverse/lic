import studio
import sim
import mmo
import bioeng
import physics.custom

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_studio_version() < 8:
    return 1
  if li_sim_version() < 7:
    return 2
  if studio_native_shell_smoke() != 0:
    return 3
  if demo_rocket_smoke() != 0:
    return 4
  if demo_mmo_smoke() != 0:
    return 5
  return bioeng_drug_litl_bridge_smoke()
