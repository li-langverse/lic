# PH-GD-1 smoke — studio play/pause (standalone until import studio lands).

type StudioProject = object
  public playing: int

def studio_play(project: StudioProject) -> unit
  requires true
  ensures project.playing == 1
  decreases 0
=
  project.playing = 1

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var p: StudioProject
  p.playing = 0
  studio_play(p)
  if p.playing != 1:
    return 1
  return 0
