# WP-GPU-04/06: @gpu MIR tag + codegen launch prologue (G-gpu Partial).

@gpu
def gpu_scale(x: float) -> float
  requires true
  ensures result >= x
  decreases 0
=
  return x + 1.0

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if gpu_scale(2.0) < 2.0:
    return 1
  return 0
