extern proc li_rt_volatile_sink_f64(v: float) -> unit
  requires true
  ensures true

extern proc li_schrodinger_1d_barrier_kernel()
  requires true
  ensures true

extern proc li_schrodinger_1d_barrier_checksum() -> float
  requires true
  ensures true

def main() raises IO -> int
  requires true
  ensures result == 0
  decreases 0
=
  li_schrodinger_1d_barrier_kernel()
  li_rt_volatile_sink_f64(li_schrodinger_1d_barrier_checksum())
  return 0
