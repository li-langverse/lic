def add_f32(a: float32, b: float32) -> float32
  requires true
  ensures result == a + b
  decreases 0
=
  return a + b

def add_i32(a: int32, b: int32) -> int32
  requires true
  ensures result == a + b
  decreases 0
=
  return a + b

def use_float8(x: float8, y: float8) -> float8
  requires true
  ensures result == x + y
  decreases 0
=
  return x + y

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  return 0
