# Soundness repro: wrong literal return still certifies with CallProc ensures stub.
type Vec3 = object
  public x: float
  public y: float
  public z: float

def vec3_dot(a: Vec3, b: Vec3) -> float
  requires true
  ensures result == a.x * b.x + a.y * b.y + a.z * b.z
  decreases 0
=
  return a.x * b.x + a.y * b.y + a.z * b.z

def vec3_len_sq_bad(a: Vec3) -> float
  requires true
  ensures result == vec3_dot(a, a)
  decreases 0
=
  return 0.0

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var v: Vec3
  v.x = 1.0
  v.y = 0.0
  v.z = 0.0
  var s: float = vec3_len_sq_bad(v)
  return 0
