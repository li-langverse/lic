def layout_role_hypothesis() -> int
  requires true
  ensures result == 0
  decreases 0
=
  return 0
def layout_role_generate() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1
def layout_role_dft() -> int
  requires true
  ensures result == 2
  decreases 0
=
  return 2
def layout_role_lab() -> int
  requires true
