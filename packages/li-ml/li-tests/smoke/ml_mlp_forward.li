import ml

def main() -> int raises IO
  requires true
  ensures result == 0
  decreases 0
=
  var x: array[8, array[8, float]]
  var w1: array[8, array[8, float]]
  var w2: array[8, array[8, float]]
  var y: array[8, array[8, float]]
  x[0][0] = 1.0
  x[0][1] = 1.0
  w1[0][0] = 1.0
  w1[0][1] = 0.0
  w1[1][0] = 0.0
  w1[1][1] = 1.0
  w2[0][0] = 1.0
  w2[1][0] = 1.0
  if ml_mlp_forward_f32(2, 2, 1, x, w1, w2, y) != 1:
    return 1
  if ml_mlp_lig_run() < -2:
    return 2
  return 0
