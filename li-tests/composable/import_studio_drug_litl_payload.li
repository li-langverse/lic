import chem
import sim.drug_design
import studio

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var p0: DrugLitlStagePayload = studio_drug_litl_stage_payload_from_tick(0)
  if p0.smiles_placeholder != drug_litl_smiles_placeholder_hypothesis():
    return 1
  var p2: DrugLitlStagePayload = drug_litl_stage_payload(drug_litl_stage_dft())
  if p2.dft_energy_hartree != chem_dft_run_smoke():
    return 2
  if p2.admet[0] <= 0.0:
    return 3
  if run_drug_design_smoke() != 0:
    return 4
  return 0
