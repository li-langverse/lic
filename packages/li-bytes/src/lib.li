import std.bytes

def li_bytes_version() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def li_bytes_reader_smoke(buf: bytes) raises Alloc, IO -> int
  requires true
  ensures result == 0
  decreases 0
=
  var r: Reader = reader_new()
  if reader_remaining(r, buf) != bytes_len(buf):
    return -1
  return 0
