import studio

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 3:
    return 1
  if li_std_gui_version() < 1:
    return 2
  var compose: StudioShellCompose = studio_compose_shell(1280.0, 720.0, 0, 0, 0)
  if studio_compose_ok(compose) != 1:
    return 3
  if compose.inspector.has_selection != 0:
    return 4
  var frame: PaintFrame = studio_shell_frame(1280.0, 720.0)
  if frame.cmd_count != studio_shell_chrome_count(1, 1, studio_agent_task_running()):
    return 5
  var timing: PanelSwitchTiming = studio_panel_switch_inspector(compose.panel, 80.0)
  if timing.within_budget != 1:
    return 6
  return 0
