import sim

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if sim_env_obs_dim() != 8:
    return 1
  var sess: SimSessionStub = sim_session_stub_default()
  sim_session_apply_studio_profile(2, sess)
  if sim_rl_session_env_pool_step(sess, 0.02) != sim_status_ok():
    return 2
  var psz: int = sim_rl_env_pool_size_default()
  if sess.env_pool_size != psz:
    return 3
  if sess.env_pool_steps_emitted != psz:
    return 4
  if sess.env_pool_total_reward <= 0.0:
    return 5
  var obs0: EnvStepResult = env_obs_from_session(sess)
  if obs0.obs1 != sess.last_dt:
    return 6
  if obs0.env_index != psz - 1:
    return 7
  var reward0: float = sess.env_pool_total_reward
  var steps0: int = sess.env_pool_steps_emitted
  if sim_rl_session_env_pool_step(sess, 0.02) != sim_status_ok():
    return 8
  if sess.env_pool_steps_emitted != steps0 + psz:
    return 9
  if sess.env_pool_total_reward <= reward0:
    return 10
  var obs1: EnvStepResult = env_obs_from_session(sess)
  if obs1.obs0 != env_tick_as_float(sess.tick):
    return 11
  var pre: EnvStepResult = env_step_contract_pre(psz, sess.tick - 1, 0.02, 0)
  var post: EnvStepResult = env_step_contract_post(pre, sess.tick, sess.last_dt, psz)
  if post.obs0 != obs1.obs0:
    return 12
  return 0
