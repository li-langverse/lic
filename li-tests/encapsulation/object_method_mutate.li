type BumpCounter = object
  public value: int

def BumpCounter_bump(self: var BumpCounter) -> unit
  requires true
  ensures true
  decreases 0
=
  self.value = self.value + 1

def main() -> int
  requires true
  ensures result == 2
  decreases 0
=
  var c: BumpCounter
  c.value = 1
  c.bump()
  return c.value
