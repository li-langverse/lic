# P-linalg: fixed-size float dot — closed AutoVC (return matches ensures formula).
def dot4_float(a: array[4, float], b: array[4, float]) -> float
  requires true
  ensures result == a[0] * b[0] + a[1] * b[1] + a[2] * b[2] + a[3] * b[3]
  decreases 0
=
  return a[0] * b[0] + a[1] * b[1] + a[2] * b[2] + a[3] * b[3]

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var a: array[4, float]
  var b: array[4, float]
  var i: int = 0
  while i < 4
    a[i] = 1.0
    b[i] = 2.0
    i = i + 1
  var s: float = dot4_float(a, b)
  return 0
