# P-linalg / P-float: prelude norm(a) lowers to li_rt_sqrt in MIR; no sqrt_open-style VC.
def norm4_prelude(a: array[4, float]) -> float
  requires true
  ensures result >= 0.0
  decreases 0
=
  return norm(a)

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var a: array[4, float]
  a[0] = 3.0
  a[1] = 4.0
  a[2] = 0.0
  a[3] = 0.0
  var n: float = norm4_prelude(a)
  return 0
