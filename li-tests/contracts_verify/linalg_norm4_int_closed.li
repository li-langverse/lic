def norm4_sq(a: array[4, int]) -> int
  requires true
  ensures result == a[0] * a[0] + a[1] * a[1] + a[2] * a[2] + a[3] * a[3]
  decreases 0
=
  return a[0] * a[0] + a[1] * a[1] + a[2] * a[2] + a[3] * a[3]

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var a: array[4, int]
  a[0] = 1
  a[1] = 0
  a[2] = 0
  a[3] = 0
  var n: int = norm4_sq(a)
  return 0
