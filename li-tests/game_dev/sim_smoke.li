# PH-SIM-1 smoke — sim step API (standalone copy of types until import sim lands in checker).

type SimWorld = object
  public tick: int
  public dt: float

def sim_step(world: SimWorld) -> unit
  requires world.dt > 0.0
  ensures world.tick >= 1
  decreases world.tick
=
  world.tick = world.tick + 1

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var w: SimWorld
  w.tick = 0
  w.dt = 1.0 / 60.0
  sim_step(w)
  if w.tick != 1:
    return 1
  return 0
