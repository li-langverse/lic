import lig.lkir

def main() -> int raises IO, Alloc
  requires true
  ensures result == 0
  decreases 0
=
  if lkir_validate_matmul_file("packages/lig/lkir/matmul_f32.lkir") != 1:
    return 1
  if lkir_validate_mlp_forward_file("packages/lig/lkir/mlp_forward_f32.lkir") != 1:
    return 2
  return 0
