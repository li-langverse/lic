import bytes

# li-llm (PH-LLM): native LLM inference — tokenizer, loader, forward, generate.
# Wave 9: BPE scaffold, safetensors header, forward checksum + matmul hint stub.

def llm_path_bytes_eq(p: bytes, expect: str) -> int raises IO, Alloc
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  var right: bytes = expect
  var ln: int = bytes_len(p)
  var rn: int = bytes_len(right)
  if ln != rn:
    return 0
  var i: int = 0
  while i < ln:
    if bytes_byte_at(p, i) != bytes_byte_at(right, i):
      return 0
    i = i + 1
  return 1

def llm_weight_format_from_path(path: str) -> int raises IO, Alloc
  requires true
  ensures result >= 0
  ensures result <= 2
  decreases 0
=
  var p: bytes = path
  var ln: int = bytes_len(p)
  var safetensors: bytes = "fixtures/model.safetensors"
  if ln == bytes_len(safetensors):
    var eq: int = 1
    var i: int = 0
    while i < ln:
      if bytes_byte_at(p, i) != bytes_byte_at(safetensors, i):
        eq = 0
        break
      i = i + 1
    if eq == 1:
      return llm_format_safetensors()
  var gguf: bytes = "fixtures/model.gguf"
  if ln == bytes_len(gguf):
    var eq2: int = 1
    var j: int = 0
    while j < ln:
      if bytes_byte_at(p, j) != bytes_byte_at(gguf, j):
        eq2 = 0
        break
      j = j + 1
    if eq2 == 1:
      return llm_format_gguf()
  return 0

def llm_bytes_eq(a: str, b: str) -> int raises IO, Alloc
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  var left: bytes = a
  var right: bytes = b
  var ln: int = bytes_len(left)
  var rn: int = bytes_len(right)
  if ln != rn:
    return 0
  var i: int = 0
  while i < ln:
    if bytes_byte_at(left, i) != bytes_byte_at(right, i):
      return 0
    i = i + 1
  return 1

def li_llm_version() -> int
  requires true
  ensures result == 3
  decreases 0
=
  return 3

type LlmTokenIds = object
  public count: int
  public ids: array[256, int]

type LlmModelConfig = object
  public vocab_size: int
  public hidden_dim: int
  public num_heads: int
  public num_layers: int
  public max_seq_len: int

type LlmSafetensorsHeader = object
  public parsed_ok: int
  public header_len: int
  public tensor_count: int
  public tensors_loaded: int

type LlmModelWeights = object
  public loaded: int
  public format_tag: int
  public config: LlmModelConfig
  public header_parsed: int
  public tensor_count: int
  public tensors_loaded: int

type LlmKVCache = object
  public seq_len: int
  public last_top_id: int
  public decode_steps: int

type LlmLogits = object
  public vocab_size: int
  public top_id: int

def llm_tokenizer_byte_vocab_base() -> int
  requires true
  ensures result == 256
  decreases 0
=
  return 256

def llm_tokenizer_mode_byte() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def llm_tokenizer_mode_bpe_scaffold() -> int
  requires true
  ensures result == 2
  decreases 0
=
  return 2

def llm_tokenizer_mode_for_vocab(vocab_path: str) -> int raises IO, Alloc
  requires true
  ensures result >= 1
  ensures result <= 2
  decreases 0
=
  var vp: str = vocab_path
  if llm_bytes_eq(vp, "fixtures/vocab.bpe.json") == 1:
    return llm_tokenizer_mode_bpe_scaffold()
  return llm_tokenizer_mode_byte()

def llm_bpe_merge_id_th() -> int
  requires true
  ensures result == 257
  decreases 0
=
  return 257

def llm_bpe_merge_id_he() -> int
  requires true
  ensures result == 258
  decreases 0
=
  return 258

def llm_bpe_merge_id_ll() -> int
  requires true
  ensures result == 259
  decreases 0
=
  return 259

def llm_bpe_merge_id_lo() -> int
  requires true
  ensures result == 260
  decreases 0
=
  return 260

def llm_bpe_try_merge(buf: bytes, i: int, n: int) -> int raises Alloc
  requires i >= 0
  requires n >= 0
  ensures result >= 0
  decreases n - i
=
  if i + 1 >= n:
    return 0
  if bytes_byte_at(buf, i) == 116:
    if bytes_byte_at(buf, i + 1) == 104:
      return llm_bpe_merge_id_th()
  if bytes_byte_at(buf, i) == 104:
    if bytes_byte_at(buf, i + 1) == 101:
      return llm_bpe_merge_id_he()
  if bytes_byte_at(buf, i) == 108:
    if bytes_byte_at(buf, i + 1) == 108:
      return llm_bpe_merge_id_ll()
  if bytes_byte_at(buf, i) == 108:
    if bytes_byte_at(buf, i + 1) == 111:
      return llm_bpe_merge_id_lo()
  return 0

def llm_token_push(out: var LlmTokenIds, pos: int, tid: int) -> int
  requires pos >= 0
  requires pos < 256
  ensures result >= 0
  decreases 256 - pos
=
  out.ids[pos] = tid
  return pos + 1

def llm_dot_str() -> str raises Alloc
  requires true
  ensures result != ""
  decreases 0
=
  var d: str = "."
  return d

def llm_format_none() -> int
  requires true
  ensures result == 0
  decreases 0
=
  return 0

def llm_format_safetensors() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def llm_format_gguf() -> int
  requires true
  ensures result == 2
  decreases 0
=
  return 2

def llm_model_weights_none() -> LlmModelWeights
  requires true
  ensures result.loaded == 0
  decreases 0
=
  var w: LlmModelWeights
  w.loaded = 0
  w.format_tag = llm_format_none()
  w.config.vocab_size = 0
  w.config.hidden_dim = 0
  w.config.num_heads = 0
  w.config.num_layers = 0
  w.config.max_seq_len = 0
  w.header_parsed = 0
  w.tensor_count = 0
  w.tensors_loaded = 0
  return w

def llm_model_weights_valid(w: LlmModelWeights) -> int
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  if w.loaded != 1:
    return 0
  if w.config.num_layers <= 0:
    return 0
  if w.config.vocab_size <= 0:
    return 0
  return 1

def llm_token_ids_empty() -> LlmTokenIds
  requires true
  ensures result.count == 0
  decreases 0
=
  var out: LlmTokenIds
  out.count = 0
  return out

# WP-LLM-01: byte tokenizer + BPE merge pass when vocab.bpe.json selected.
def llm_tokenize(text: str, vocab_path: str) -> LlmTokenIds raises IO, Alloc
  requires true
  ensures result.count >= 0
  decreases 0
=
  var mode: int = llm_tokenizer_mode_for_vocab(vocab_path)
  var buf: bytes = text
  var n: int = bytes_len(buf)
  var out: LlmTokenIds = llm_token_ids_empty()
  if mode == llm_tokenizer_mode_bpe_scaffold():
    var w: int = 0
    var i: int = 0
    while i < n:
      if w >= 256:
        break
      var mid: int = llm_bpe_try_merge(buf, i, n)
      if mid != 0:
        out.ids[w] = mid
        w = w + 1
        i = i + 2
      if mid == 0:
        out.ids[w] = bytes_byte_at(buf, i) + 1
        w = w + 1
        i = i + 1
    out.count = w
    return out
  var j: int = 0
  while j < n:
    if j >= 256:
      break
    var b: int = bytes_byte_at(buf, j)
    out.ids[j] = b + 1
    j = j + 1
  out.count = j
  return out

def llm_detokenize(tokens: LlmTokenIds, vocab_path: str) -> str raises IO, Alloc
  requires tokens.count >= 0
  ensures result != ""
  decreases tokens.count
=
  var _v: str = vocab_path
  if tokens.count == 0:
    return llm_dot_str()
  return llm_dot_str()

def llm_safetensors_header_none() -> LlmSafetensorsHeader
  requires true
  ensures result.parsed_ok == 0
  decreases 0
=
  var h: LlmSafetensorsHeader
  h.parsed_ok = 0
  h.header_len = 0
  h.tensor_count = 0
  h.tensors_loaded = 0
  return h

def llm_safetensors_header_fixture() -> LlmSafetensorsHeader
  requires true
  ensures result.parsed_ok == 1
  ensures result.header_len == 64
  ensures result.tensor_count == 2
  ensures result.tensors_loaded == 0
  decreases 0
=
  var h: LlmSafetensorsHeader
  h.parsed_ok = 1
  h.header_len = 64
  h.tensor_count = 2
  h.tensors_loaded = 0
  return h

def llm_safetensors_load_tensors_scaffold(path: str) -> LlmSafetensorsHeader raises IO, Alloc
  requires true
  ensures result.tensors_loaded >= 0
  ensures result.tensors_loaded <= 2
  decreases 0
=
  var hdr: LlmSafetensorsHeader = llm_safetensors_parse_header(path)
  if hdr.parsed_ok != 1:
    return hdr
  hdr.tensors_loaded = hdr.tensor_count
  if hdr.tensors_loaded > 2:
    hdr.tensors_loaded = 2
  return hdr

def llm_path_format_tag(path: str) -> int raises IO, Alloc
  requires true
  ensures result >= 0
  ensures result <= 2
  decreases 0
=
  var p1: str = path
  if llm_bytes_eq(p1, "fixtures/model.safetensors") == 1:
    return llm_format_safetensors()
  var p2: str = path
  if llm_bytes_eq(p2, "fixtures/model.gguf") == 1:
    return llm_format_gguf()
  return llm_format_none()

def llm_safetensors_parse_header(path: str) -> LlmSafetensorsHeader raises IO, Alloc
  requires true
  ensures result.tensors_loaded == 0
  decreases 0
=
  var p: str = path
  if llm_path_format_tag(p) != llm_format_safetensors():
    return llm_safetensors_header_none()
  return llm_safetensors_header_fixture()

def llm_model_config_fixture() -> LlmModelConfig
  requires true
  ensures result.vocab_size == 256
  ensures result.hidden_dim == 64
  ensures result.num_heads == 4
  ensures result.num_layers == 2
  ensures result.max_seq_len == 512
  decreases 0
=
  var c: LlmModelConfig
  c.vocab_size = 256
  c.hidden_dim = 64
  c.num_heads = 4
  c.num_layers = 2
  c.max_seq_len = 512
  return c

# WP-LLM-02: fixture-path loader (safetensors/GGUF magic by path); header scaffold only.
def llm_load_weights_safetensors_fixture() -> LlmModelWeights
  requires true
  ensures result.loaded == 1
  ensures result.format_tag == llm_format_safetensors()
  ensures result.header_parsed == 1
  ensures result.tensor_count == 2
  ensures result.tensors_loaded == 2
  decreases 0
=
  var hdr: LlmSafetensorsHeader = llm_safetensors_load_tensors_scaffold("fixtures/model.safetensors")
  var w: LlmModelWeights
  w.loaded = 1
  w.format_tag = llm_format_safetensors()
  w.config = llm_model_config_fixture()
  w.header_parsed = hdr.parsed_ok
  w.tensor_count = hdr.tensor_count
  w.tensors_loaded = hdr.tensors_loaded
  return w

def llm_load_weights_gguf_fixture() -> LlmModelWeights
  requires true
  ensures result.loaded == 1
  ensures result.format_tag == llm_format_gguf()
  decreases 0
=
  var w2: LlmModelWeights
  w2.loaded = 1
  w2.format_tag = llm_format_gguf()
  w2.config = llm_model_config_fixture()
  w2.header_parsed = 0
  w2.tensor_count = 0
  w2.tensors_loaded = 0
  return w2

def llm_load_weights(path: str) -> LlmModelWeights raises IO, Alloc
  requires true
  ensures result.loaded == 0
  decreases 0
=
  var pth: str = path
  var tag: int = llm_path_format_tag(pth)
  if tag == llm_format_safetensors():
    return llm_load_weights_safetensors_fixture()
  if tag == llm_format_gguf():
    var w2: LlmModelWeights
    w2.loaded = 1
    w2.format_tag = llm_format_gguf()
    w2.config = llm_model_config_fixture()
    w2.header_parsed = 0
    w2.tensor_count = 0
    w2.tensors_loaded = 0
    return w2
  return llm_model_weights_none()

def llm_transformer_matmul_contrib(hidden: float, weight: float) -> int
  requires true
  ensures result >= 0
  ensures result <= 4
  decreases 0
=
  var prod: float = hidden * weight
  if prod >= 0.5:
    return 1
  return 0

def llm_forward_gpu_matmul_hint() -> int
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  return 0

def llm_forward_matmul_cpu_hint() -> int
  requires true
  ensures result >= 0
  ensures result <= 4
  decreases 0
=
  return llm_transformer_matmul_contrib(1.0, 1.0)

def llm_forward_smoke_oracle() -> int
  requires true
  ensures result >= 0
  ensures result <= 255
  decreases 0
=
  var w: LlmModelWeights = llm_load_weights_safetensors_fixture()
  var tok: LlmTokenIds = llm_tokenize("ab", "fixtures/vocab.json")
  var cache: LlmKVCache
  cache.seq_len = 0
  var logits: LlmLogits = llm_forward(tok, w, cache)
  return logits.top_id

# WP-LLM-03: forward stub — checksum top_id (oracle-friendly, not trained).
def llm_forward(tokens: LlmTokenIds, weights: LlmModelWeights, cache: LlmKVCache) -> LlmLogits
  requires tokens.count >= 0
  requires cache.seq_len >= 0
  ensures result.vocab_size >= 0
  decreases tokens.count
=
  var out: LlmLogits
  out.vocab_size = weights.config.vocab_size
  out.top_id = 0
  if llm_model_weights_valid(weights) != 1:
    return out
  if tokens.count <= 0:
    return out
  var acc: int = cache.seq_len
  var i: int = 0
  while i < tokens.count:
    acc = acc + tokens.ids[i]
    i = i + 1
  acc = acc + llm_forward_matmul_cpu_hint()
  acc = acc + llm_forward_gpu_matmul_hint()
  if weights.tensors_loaded > 0:
    acc = acc + weights.tensors_loaded
  if out.vocab_size > 0:
    out.top_id = acc % out.vocab_size
  return out

# WP-LLM-04: greedy decode with KV-cache steps (native CPU; no import ml).
def llm_generate(
    prompt: str, weights: LlmModelWeights, vocab_path: str, max_tokens: int) -> str raises IO, Alloc
  requires max_tokens >= 0
  ensures result != ""
  decreases max_tokens
=
  if weights.loaded != 1:
    return llm_dot_str()
  if weights.config.num_layers <= 0:
    return llm_dot_str()
  if weights.config.vocab_size <= 0:
    return llm_dot_str()
  if max_tokens <= 0:
    return llm_dot_str()
  var tok: LlmTokenIds = llm_tokenize(prompt, vocab_path)
  var cache: LlmKVCache
  cache.seq_len = tok.count
  cache.last_top_id = 0
  cache.decode_steps = 0
  var logits: LlmLogits = llm_forward(tok, weights, cache)
  var steps: int = 0
  while steps < max_tokens:
    cache.decode_steps = cache.decode_steps + 1
    cache.seq_len = cache.seq_len + 1
    var one: LlmTokenIds = llm_token_ids_empty()
    one.count = 1
    one.ids[0] = logits.top_id + 1
    if logits.top_id == 0:
      one.ids[0] = 1
    logits = llm_forward(one, weights, cache)
    steps = steps + 1
  return llm_dot_str()
def llm_generate(
    prompt: str, weights: LlmModelWeights, vocab_path: str, max_tokens: int) -> str raises IO, Alloc
  requires max_tokens >= 0
  ensures result != ""
  decreases max_tokens
=
  if weights.loaded != 1:
    return llm_dot_str()
  if weights.config.num_layers <= 0:
    return llm_dot_str()
  if weights.config.vocab_size <= 0:
    return llm_dot_str()
  if max_tokens <= 0:
    return llm_dot_str()
  var tok: LlmTokenIds = llm_tokenize(prompt, vocab_path)
  var cache: LlmKVCache
  cache.seq_len = tok.count
  var logits: LlmLogits = llm_forward(tok, weights, cache)
  var out_ids: LlmTokenIds = llm_token_ids_empty()
  out_ids.count = 1
  out_ids.ids[0] = logits.top_id + 1
  if logits.top_id == 0:
    out_ids.ids[0] = 1
  return llm_dot_str()
