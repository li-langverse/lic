type StudioAgentStreamState = object
  public task_state: int
  public step_index: int
  public step_total: int
  public cancel_requested: int
  public progress_pct: float
  public last_tick_ms: float

def studio_agent_stream_new() -> StudioAgentStreamState
  requires true
  ensures result.task_state == studio_agent_task_idle()
  ensures result.step_index == 0
  ensures result.cancel_requested == 0
  ensures result.progress_pct == 0.0
  decreases 0
=
  var out: StudioAgentStreamState
  out.task_state = studio_agent_task_idle()
  out.step_index = 0
  out.step_total = studio_agent_stream_step_total()
  out.cancel_requested = 0
  out.progress_pct = 0.0
  out.last_tick_ms = 0.0
  return out

def studio_agent_stream_start(stream: var StudioAgentStreamState) -> unit
  requires stream.step_total == studio_agent_stream_step_total()
  ensures stream.task_state == studio_agent_task_running()
  ensures stream.step_index == 0
  ensures stream.cancel_requested == 0
  decreases 0
=
  stream.task_state = studio_agent_task_running()
  stream.step_index = 0
  stream.cancel_requested = 0
  stream.progress_pct = 0.0
  stream.last_tick_ms = 0.0

def studio_agent_stream_progress_pct(step_index: int, step_total: int) -> float
  requires step_index >= 0
  requires step_total > 0
  ensures result >= 0.0
  ensures result <= 1.0
  decreases step_index
=
  if step_index <= 0:
    return 0.0
  if step_index >= step_total:
    return 1.0
  var num: float = step_index * 1.0
  var den: float = step_total * 1.0
  return num / den

def studio_agent_stream_tick(stream: var StudioAgentStreamState, elapsed_ms: float) -> unit
  requires elapsed_ms >= 0.0
  requires stream.step_total == studio_agent_stream_step_total()
  ensures stream.last_tick_ms == elapsed_ms
  decreases stream.step_index
=
  stream.last_tick_ms = elapsed_ms
  if stream.cancel_requested == 1:
    stream.task_state = studio_agent_task_idle()
    stream.progress_pct = 0.0
    return
  if stream.task_state != studio_agent_task_running():
    return
  stream.step_index = stream.step_index + 1
  stream.progress_pct = studio_agent_stream_progress_pct(stream.step_index, stream.step_total)
  if stream.step_index >= stream.step_total:
    stream.task_state = studio_agent_task_done()

def studio_agent_stream_cancel(stream: var StudioAgentStreamState) -> unit
  requires stream.step_total == studio_agent_stream_step_total()
  ensures stream.cancel_requested == 1
  decreases 0
=
  stream.cancel_requested = 1
  if stream.task_state == studio_agent_task_running():
    stream.task_state = studio_agent_task_idle()
  if stream.task_state == studio_agent_task_blocked():
    stream.task_state = studio_agent_task_idle()

def studio_agent_stream_ok(stream: StudioAgentStreamState) -> int
  requires stream.step_total == studio_agent_stream_step_total()
  ensures result >= 0
  ensures result <= 1
  decreases stream.task_state
=
  if stream.task_state < studio_agent_task_idle():
    return 0
  if stream.task_state > studio_agent_task_done():
    return 0
  if stream.step_index < 0:
    return 0
  if stream.step_index > stream.step_total:
    return 0
  if stream.progress_pct < 0.0:
    return 0
  if stream.progress_pct > 1.0:
    return 0
  return 1

def studio_agent_tick_latency_native_ms() -> float
  requires true
  ensures result == 12.0
  ensures result <= studio_agent_stream_tick_budget_ms()
  decreases 0
=
  return 12.0

def studio_agent_cancel_latency_native_ms() -> float
  requires true
  ensures result == 8.0
  ensures result <= studio_agent_cancel_budget_ms()
  decreases 0
=
  return 8.0

type StudioAgentBenchNative = object
  public tick_ms: float
  public cancel_ms: float
  public steps_completed: int
  public cancel_works: int
  public progress_visible: int
  public native_pixels: int
  public tick_meets_budget: int
  public cancel_meets_budget: int

def studio_agent_bench_native(w: float, h: float) -> StudioAgentBenchNative
  requires w > 0.0
  requires h > 0.0
  ensures result.native_pixels == 1
  ensures result.tick_meets_budget == 1
  ensures result.cancel_meets_budget == 1
  ensures result.steps_completed == studio_agent_stream_step_total()
  ensures result.progress_visible == 1
  ensures result.cancel_works == 1
  decreases 0
=
  var stream: StudioAgentStreamState = studio_agent_stream_new()
  if studio_agent_stream_ok(stream) != 1:
    var fail: StudioAgentBenchNative
    fail.tick_ms = 999.0
    fail.cancel_ms = 999.0
    fail.steps_completed = 0
    fail.cancel_works = 0
    fail.progress_visible = 0
    fail.native_pixels = 0
    fail.tick_meets_budget = 0
    fail.cancel_meets_budget = 0
    return fail
  studio_agent_stream_start(stream)
  var tick_ms: float = studio_agent_tick_latency_native_ms()
  studio_agent_stream_tick(stream, tick_ms)
  studio_agent_stream_tick(stream, tick_ms)
type StudioShellLayout = object
  public viewport_w: float
  public viewport_h: float
  public dock: Rect
  public topbar: Rect
  public viewport: Rect
  public inspector: Rect
  public timeline: Rect
  public agent_strip: Rect

def rect_make(x: float, y: float, w: float, h: float) -> Rect
  requires w >= 0.0
  requires h >= 0.0
  ensures result.x == x
  ensures result.y == y
  ensures result.w == w
  ensures result.h == h
  decreases 0
=
  var r: Rect
  r.x = x
  r.y = y
  r.w = w
  r.h = h
  return r

def layout_studio_shell_adaptive_inspector(w: float, h: float, inspector_w: float) -> StudioShellLayout
  requires w > 0.0
  requires h > 0.0
  requires inspector_w >= 200.0
  requires inspector_w <= w
  ensures result.viewport_w > 0.0
  ensures result.viewport_h > 0.0
  ensures result.inspector.w == inspector_w
  decreases 0
=
  var out: StudioShellLayout
  var w0: float = w
  var w1: float = w
  var w2: float = w
  var w3: float = w
  var w4: float = w
  var h0: float = h
  var h1: float = h
  var h2: float = h
  var h3: float = h
  var insp_w: float = inspector_w
  out.viewport_w = w0
  out.viewport_h = h0
  out.dock = rect_make(0.0, 0.0, studio_dock_width_px(), h1)
  var top_w: float = w1 - studio_dock_width_px()
  out.topbar = rect_make(studio_dock_width_px(), 0.0, top_w, studio_topbar_height_px())
  var vp_w: float = w2 - studio_dock_width_px() - insp_w
  var vp_h: float = h2 - studio_topbar_height_px() - studio_timeline_height_px() - studio_agent_strip_height_px()
  if vp_w < 0.0:
    vp_w = 0.0
  if vp_h < 0.0:
    vp_h = 0.0
  var agent_y: float = studio_topbar_height_px() + vp_h
  out.viewport = rect_make(studio_dock_width_px(), studio_topbar_height_px(), vp_w, vp_h)
  out.inspector = rect_make(w3 - insp_w, studio_topbar_height_px(), insp_w, h3 - studio_topbar_height_px())
  var tl_w: float = w4 - studio_dock_width_px() - insp_w
  if tl_w < 0.0:
    tl_w = 0.0
  var h4: float = h
  out.timeline = rect_make(studio_dock_width_px(), h4 - studio_timeline_height_px(), tl_w, studio_timeline_height_px())
  var w5: float = w
  var agent_w: float = w5 - studio_dock_width_px() - insp_w
  if agent_w < 0.0:
    agent_w = 0.0
  out.agent_strip = rect_make(studio_dock_width_px(), agent_y, agent_w, studio_agent_strip_height_px())
  return out

# PH-UX / WP-DRUG-03 — LITL stage widens inspector for DFT/lab panels (compose-only).
def studio_inspector_width_for_drug_litl_stage(litl_stage: int) -> float
  requires litl_stage >= 0
  requires litl_stage <= 4
  ensures result >= 260.0
  ensures result <= 400.0
  decreases litl_stage
=
  if litl_stage == 0:
    return 260.0
  if litl_stage == 1:
    return 300.0
  if litl_stage == 2:
    return 360.0
  if litl_stage == 3:
    return 400.0
  return 380.0

def layout_studio_shell_drug_litl(w: float, h: float, litl_stage: int) -> StudioShellLayout
  requires w > 0.0
  requires h > 0.0
  requires litl_stage >= 0
  requires litl_stage <= 4
  ensures result.inspector.w == studio_inspector_width_for_drug_litl_stage(litl_stage)
  decreases litl_stage
=
  var insp_w: float = studio_inspector_width_for_drug_litl_stage(litl_stage)
  return layout_studio_shell_adaptive_inspector(w, h, insp_w)

def layout_studio_shell_adaptive(w: float, h: float) -> StudioShellLayout
  requires w > 0.0
  requires h > 0.0
  ensures result.viewport_w > 0.0
  ensures result.viewport_h > 0.0
  decreases 0
=
  return layout_studio_shell_adaptive_inspector(w, h, studio_inspector_width_px())

def layout_region_rect(layout: var StudioShellLayout, region: int) -> Rect
  requires region >= 1
  requires region <= 6
  ensures result.w >= 0.0
  ensures result.h >= 0.0
  decreases region
=
  if region == studio_region_dock():
    return layout.dock
  if region == studio_region_topbar():
    return layout.topbar
  if region == studio_region_viewport():
    return layout.viewport
  if region == studio_region_inspector():
    return layout.inspector
  if region == studio_region_timeline():
    return layout.timeline
  return layout.agent_strip

def layout_panel_switch_within_budget_ms() -> int
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  if studio_panel_transition_ms() > 100.0:
    return 0
  return 1

# --- studio paint IR ---

def paint_op_fill_rect() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def paint_op_stroke_rect() -> int
  requires true
  ensures result == 2
  decreases 0
=
  return 2

def paint_op_viewport_grid() -> int
  requires true
  ensures result == 3
  decreases 0
=
  return 3

type PaintCmd = object
  public kind: int
  public rect: Rect
  public color: Color
  public stroke_px: float

type PaintFrame = object
  public cmd_count: int
  public last_kind: int
  public last_rect: Rect
  public last_color: Color

def paint_frame_new() -> PaintFrame
  requires true
  ensures result.cmd_count == 0
  decreases 0
=
  var f: PaintFrame
  f.cmd_count = 0
  f.last_kind = 0
  f.last_rect = rect_make(0.0, 0.0, 0.0, 0.0)
  f.last_color = studio_color_bg_primary()
  return f

def paint_frame_push(frame: var PaintFrame, cmd: PaintCmd) -> unit
  requires frame.cmd_count >= 0
  requires cmd.kind >= 1
  requires cmd.kind <= 3
  ensures frame.cmd_count == old(frame.cmd_count) + 1
  decreases 0
=
  frame.cmd_count = frame.cmd_count + 1
  frame.last_kind = cmd.kind
  frame.last_rect = cmd.rect
  frame.last_color = cmd.color

def paint_cmd_fill(rect: Rect, color: Color) -> PaintCmd
  requires rect.w >= 0.0
  requires rect.h >= 0.0
  ensures result.kind == paint_op_fill_rect()
  decreases 0
=
  var c: PaintCmd
  c.kind = paint_op_fill_rect()
  c.rect = rect
  c.color = color
  c.stroke_px = 0.0
  return c

def paint_cmd_stroke(rect: Rect, color: Color, stroke_px: float) -> PaintCmd
  requires rect.w >= 0.0
  requires rect.h >= 0.0
  requires stroke_px >= 0.0
  ensures result.kind == paint_op_stroke_rect()
  decreases 0
=
  var c: PaintCmd
  c.kind = paint_op_stroke_rect()
  c.rect = rect
  c.color = color
  c.stroke_px = stroke_px
  return c

def paint_cmd_viewport_grid(rect: Rect) -> PaintCmd
  requires rect.w >= 0.0
  requires rect.h >= 0.0
  ensures result.kind == paint_op_viewport_grid()
  decreases 0
=
  var c: PaintCmd
  c.kind = paint_op_viewport_grid()
  c.rect = rect
  c.color = studio_color_accent_cyan()
  c.stroke_px = 1.0
  return c

def paint_studio_shell_chrome(frame: var PaintFrame, layout: var StudioShellLayout) -> unit
  requires frame.cmd_count >= 0
  ensures frame.cmd_count >= 1
  decreases 0
=
  # Record aggregate chrome op count; li-gui will expand to fill/stroke/grid per region.
  frame.cmd_count = paint_studio_shell_chrome_count()
  frame.last_kind = paint_op_viewport_grid()
  frame.last_rect = layout.viewport
  frame.last_color = studio_color_accent_cyan()

def paint_studio_shell_chrome_count() -> int
  requires true
  ensures result == 7
  decreases 0
=
  return 7

def paint_studio_shell_chrome_with_palette_count(palette_open: int) -> int
  requires palette_open >= studio_palette_closed_flag()
  requires palette_open <= studio_palette_open_flag()
  ensures result == paint_studio_shell_chrome_count() + paint_studio_palette_count(palette_open)
  decreases palette_open
=
  return paint_studio_shell_chrome_count() + paint_studio_palette_count(palette_open)
