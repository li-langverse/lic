import ml_rl
import sim

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if ml_rl_worker_mode() != 0:
    return 1
  var sess: SimSessionStub = sim_session_stub_default()
  sim_session_apply_studio_profile(2, sess)
  sim_session_env_pool_init(sess)
  if ml_rl_env_pool_async_collect(sess, 0.02) != sim_status_ok():
    return 2
  if sess.env_pool_steps_emitted < 4:
    return 3
  if ml_rl_env_pool_async_collect(sess, 0.02) != sim_status_ok():
    return 4
  if sess.env_pool_steps_emitted < 8:
    return 5
  return 0