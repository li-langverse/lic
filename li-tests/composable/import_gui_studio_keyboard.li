import gui

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var panel: GuiPanelState = gui_panel_state_new()
  var focus_viewport: InputState = input_default()
  focus_viewport.key_digit = 2
  if gui_handle_studio_key(panel, focus_viewport) != studio_key_action_region_focus():
    return 1
  if panel.active_region != studio_region_viewport():
    return 2
  return 0
