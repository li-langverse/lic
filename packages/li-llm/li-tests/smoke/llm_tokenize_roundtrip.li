import llm

def main() -> int raises IO, Alloc
  requires true
  ensures result == 0
  decreases 0
=
  if li_llm_version() != 2:
    return 1
  if llm_tokenizer_byte_vocab_base() != 256:
    return 2
  var tok: LlmTokenIds = llm_tokenize("hello", "fixtures/vocab.json")
  if tok.count != 5:
    return 3
  var back: str = llm_detokenize(tok, "fixtures/vocab.json")
  var round2: LlmTokenIds = llm_tokenize(back, "fixtures/vocab.json")
  if round2.count != 5:
    return 4
  if tok.ids[0] != 104:
    return 5
  return 0
