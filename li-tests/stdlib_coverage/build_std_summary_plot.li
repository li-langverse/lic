import std.summary
import std.plot

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var t: int = summary_tag() + plot_tag()
  if t != 12:
    return 1
  var s: int = build_summary_json_stub()
  var p: int = render_static_dashboard_stub()
  if s != 0 or p != 0:
