# PH-SIM SIM-0 — studio profile → sim contract (read-only; no stepping).
def sim_contract_unknown() -> int
  requires true
  ensures result == 0
  decreases 0
=
  return 0

def sim_contract_game() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def sim_contract_sim_rl() -> int
  requires true
  ensures result == 2
  decreases 0
=
  return 2

def sim_contract_sim_automotive() -> int
  requires true
  ensures result == 3
  decreases 0
=
  return 3

def sim_contract_sim_robotics() -> int
  requires true
  ensures result == 4
  decreases 0
=
  return 4

def sim_contract_sim_additive() -> int
  requires true
  ensures result == 5
  decreases 0
=
  return 5

def sim_contract_sim_scientific() -> int
  requires true
  ensures result == 6
  decreases 0
=
  return 6

def sim_contract_sim_drug_design() -> int
  requires true
  ensures result == 7
  decreases 0
=
