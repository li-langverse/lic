def main() raises IO -> int
  requires true
  ensures result == 0
  decreases 0
=
  var acc: float = 0.0
  var chunk: int = 0
  while chunk < 39062
    var off: int = 0
    while off < 256
      var va: float = dot_lut_a(off)
      var vb: float = dot_lut_b7(off)
      acc = acc + va * vb
      off = off + 1
    chunk = chunk + 1
  var off_tail: int = 0
  while off_tail < 128
    var va_tail: float = dot_lut_a(off_tail)
    var vb_tail: float = dot_lut_b7(off_tail)
    acc = acc + va_tail * vb_tail
    off_tail = off_tail + 1
  li_rt_volatile_sink_f64(acc)
  return 0

