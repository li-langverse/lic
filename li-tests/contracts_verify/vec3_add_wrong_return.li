# Soundness repro: wrong vec3_add (zeros) still certifies with per-field ensures.
type Vec3 = object
  public x: float
  public y: float
  public z: float

def vec3_add_bad(a: Vec3, b: Vec3) -> Vec3
  requires true
  ensures result.x == a.x + b.x
  ensures result.y == a.y + b.y
  ensures result.z == a.z + b.z
  decreases 0
=
  var r: Vec3
  r.x = 0.0
  r.y = 0.0
  r.z = 0.0
  return r

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var a: Vec3
  a.x = 1.0
  a.y = 2.0
  a.z = 3.0
  var b: Vec3
  b.x = 4.0
  b.y = 5.0
  b.z = 6.0
  var c: Vec3 = vec3_add_bad(a, b)
  return 0
