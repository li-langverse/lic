import sim
import sim.scientific
import scene
import studio

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if tier2_bench_row_md_lennard_jones() != 1:
    return 1
  if tier2_bench_row_params_tag(tier2_bench_row_md_lennard_jones()) != 101:
    return 2
  if tier2_md_oracle_built(tier2_bench_row_md_lennard_jones()) != 0:
    return 3
  if studio_md_particle_tier_select_ok(studio_scientific_viewport_tier_id()) != 1:
    return 4
  if sim_scientific_tier2_tick(output_detail_debug(), tier2_bench_row_md_lennard_jones()) != 1:
    return 5
  var cfg: StudioProjectConfig = studio_project_config_new(studio_profile_sim_scientific())
  var sess: SimSessionStub = sim_session_stub_default()
  if studio_sim_step_hook(cfg, sess, 0.01) != sim_status_ok():
    return 20
  if sess.tick != 1:
    return 21
  if sess.sim_contract_id != sim_contract_sim_scientific():
    return 22
  return 0
