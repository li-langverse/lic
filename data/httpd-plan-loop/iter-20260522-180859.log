ule(mod)\n+    return mod\n+\n+\n+def run_python_driver(\n+    cfg: dict[str, Any],\n+    *,\n+    lang: str,\n+    stub: bool,\n+    port: int,\n+) -> dict[str, Any]:\n+    script = attack_script_path(cfg)\n+    if script is None or not script.is_file():\n+        raise FileNotFoundError(f\"driver script missing for {cfg.get('id')}\")\n+    mod = load_driver_module(script)\n+    if not hasattr(mod, \"run\"):\n+        raise AttributeError(f\"{script}: missing run(cfg, lang=..., stub=..., port=...)\")\n+    return mod.run(cfg, lang=lang, stub=stub, port=port)\n+\n+\n+def evaluate_expect(cfg: dict[str, Any], outcome: dict[str, Any], *, lang: str) -> tuple[bool, str]:\n+    expect = cfg.get(\"expect\") or {}\n+    if not isinstance(expect, dict):\n+        return True, \"no [expect]\"\n+    notes: list[str] = []\n+    for key, want in expect.items():\n+        if key == \"li_behavior\":\n+            continue\n+        if want is None:\n+            continue\n+        got = outcome.get(key)\n+        if got is None:\n+            got = outcome.get(f\"expect_{key}\")\n+        if isinstance(want, bool):\n+            if bool(got) != want:\n+                return False, f\"{key}: got {got!r} want {want!r}\"\n+        elif isinstance(want, (int, float)):\n+            if got is None or float(got) > float(want):\n+                return False, f\"{key}: got {got!r} exceeds {want!r}\"\n+        else:\n+            if str(got) != str(want):\n+                return False, f\"{key}: got {got!r} want {want!r}\"\n+        notes.append(f\"{key}=ok\")\n+    li_behavior = expect.get(\"li_behavior\")\n+    if li_behavior == \"stricter\" and outcome.get(\"li_stricter\"):\n+        notes.append(\"li_stricter=ok\")\n+    return True, \"; \".join(notes) or \"expect ok\"\n+\n+\n+def compare_langs_outcomes(\n+    cfg: dict[str, Any],\n+    by_lang: dict[str, tuple[bool, str]],\n+) -> list[str]:\n+    \"\"\"When --compare-nginx, note li stricter than nginx on [expect].\"\"\"\n+    notes: list[str] = []\n+    li_ok = by_lang.get(\"li\", (False, \"\"))[0]\n+    ngx_ok = by_lang.get(\"nginx\", (False, \"\"))[0]\n+    expect = cfg.get(\"expect\") or {}\n+    if isinstance(expect, dict) and expect.get(\"li_behavior\") == \"stricter\":\n+        if li_ok and not ngx_ok:\n+            notes.append(\"li_stricter_than_nginx\")\n+        elif li_ok and ngx_ok:\n+            notes.append(\"both_pass\")\n+        elif not li_ok and ngx_ok:\n+            notes.append(\"regression: nginx passed li failed\")\n+    return notes\n+\n+\n+def write_csv(path: Path, rows: list[dict[str, object]]) -> None:\n+    path.parent.mkdir(parents=True, exist_ok=True)\n+    with path.open(\"w\", newline=\"\") as f:\n+        w = csv.DictWriter(f, fieldnames=CSV_HEADER)\n+        w.writeheader()\n+        for row in rows:\n+            w.writerow({k: row.get(k, \"\") for k in CSV_HEADER})\n+\n+\n+def pick_port(cfg: dict[str, Any], exploit_id: str) -> int:\n+    defaults = cfg.get(\"global\") or {}\n+    base = int(defaults.get(\"port_base\", 19080))\n+    return base + (hash(exploit_id) % 200)\n+\n+\n+def start_nginx_for_bench(server_cfg: Path, port: int) -> tuple[subprocess.Popen[str] | None, Path | None]:\n+    name = server_cfg.parent.parent.name if server_cfg.parent.name == \"bench.toml\" else \"static_small\"\n+    if server_cfg.name == \"bench.toml\" and server_cfg.parent.parent.name != \"scenarios\":\n+        name = server_cfg.parent.name\n+    try:\n+        cfg = merge_scenario(name, profile=\"ci\", overrides=None)\n+    except Exception:\n+        cfg = merge_scenario(\"static_small\", profile=\"ci\", overrides=None)\n+    ensure_fixtures(cfg)\n+    conf_dir = Path(tempfile.mkdtemp(prefix=\"tier5_exploit_\"))\n+    conf_path = conf_dir / \"nginx.conf\"\n+    prefix = conf_dir / \"prefix\"\n+    conf_path.write_text(render_nginx_conf(cfg, port=port), encoding=\"utf-8\")\n+    nginx = shutil.which(\"nginx\")\n+    if not nginx:\n+        return None, conf_dir\n+    prefix.mkdir(parents=True)\n+    (prefix / \"logs\").mkdir(exist_ok=True)\n+    proc = subprocess.Popen(\n+        [nginx, \"-c\", str(conf_path), \"-p\", str(prefix)],\n+        stderr=subprocess.PIPE,\n+        text=True,\n+    )\n+    import time\n+\n+    time.sleep(0.35)\n+    if proc.poll() is not None:\n+        proc.kill()\n+        return None, conf_dir\n+    return proc, conf_dir\n+\n+\n+def start_li_httpd(server_cfg: Path, port: int) -> subprocess.Popen[str] | None:\n+    bin_path = os.environ.get(\"LI_HTTPD_BIN\", str(REPO / \"build\" / \"li-httpd\"))\n+    if not os.path.isfile(bin_path) or not os.access(bin_path, os.X_OK):\n+        return None\n+    env = os.environ.copy()\n+    env[\"LI_HTTPD_CONFIG\"] = str(server_cfg.resolve())\n+    env[\"LI_HTTPD_PORT\"] = str(port)\n+    return subprocess.Popen(\n+        [bin_path],\n+        env=env,\n+        stdout=subprocess.DEVNULL,\n+        stderr=subprocess.PIPE,\n+        text=True,\n+    )\n+\n+\n+def run_exploit_for_lang(\n+    cfg: dict[str, Any],\n+    lang: str,\n+    *,\n+    stub: bool,\n+    compare: bool,\n+) -> tuple[bool, str, dict[str, Any]]:\n+    exploit_id = str(cfg[\"id\"])\n+    port = pick_port(cfg, exploit_id)\n+    attack = cfg.get(\"attack\") or {}\n+    driver = str(attack.get(\"driver\", \"python\")) if isinstance(attack, dict) else \"python\"\n+    proc: subprocess.Popen[str] | None = None\n+    conf_dir: Path | None = None\n+    try:\n+        if not stub and lang == \"nginx\" and shutil.which(\"nginx\"):\n+            server_cfg = resolve_server_config(cfg)\n+            proc, conf_dir = start_nginx_for_bench(server_cfg, port)\n+            if proc is None:\n+                stub = True\n+        elif not stub and lang == \"li\":\n+            server_cfg = resolve_server_config(cfg)\n+            proc = start_li_httpd(server_cfg, port)\n+            if proc is None:\n+                stub = True\n+            else:\n+                import time\n+\n+                time.sleep(0.5)\n+                if proc.poll() is not None:\n+                    err = proc.stderr.read() if proc.stderr else \"\"\n+                    proc = None\n+                    return False, f\"li-httpd failed to start: {err}\", {}\n+        if driver == \"python\":\n+            outcome = run_python_driver(cfg, lang=lang, stub=stub, port=port)\n+        else:\n+            return False, f\"driver {driver!r} not implemented (use stub)\", {}\n+        ok, msg = evaluate_expect(cfg, outcome, lang=lang)\n+        if compare and outcome.get(\"li_stricter\"):\n+            msg = f\"{msg}; li_stricter\"\n+        return ok, msg, outcome\n+    finally:\n+        if proc is not None:\n+            proc.terminate()\n+            try:\n+                proc.wait(timeout=3)\n+            except subprocess.TimeoutExpired:\n+                proc.kill()\n+        if conf_dir is not None:\n+            shutil.rmtree(conf_dir, ignore_errors=True)\n+\n+\n+def dry_run_exploit(exploit_id: str, *, profile: str | None, overrides: list[str] | None) -> tuple[bool, str]:\n+    cfg = merge_exploit(exploit_id, overrides=overrides, profile=profile)\n+    errs = validate_exploit(cfg)\n+    if errs:\n+        return False, \"; \".join(errs)\n+    langs = target_langs(cfg, cli_langs=None)\n+    script = attack_script_path(cfg)\n+    if cfg.get(\"enabled\") is False:\n+        return True, \"disabled\"\n+    if script and not script.is_file():\n+        return False, f\"missing script {script}\"\n+    return True, f\"merged ok tier={cfg.get('tier')} langs={langs}\"\n+\n+\n+def main() -> int:\n+    parser = argparse.ArgumentParser(description=\"tier5_http exploit harness (TOML only)\")\n+    parser.add_argument(\"exploits\", nargs=\"*\", help=\"exploit ids (default from suite_exploits.toml)\")\n+    parser.add_argument(\"--profile\", default=None, help=\"suite_exploits.toml profile (pr, nightly, …)\")\n+    parser.add_argument(\"--set\", action=\"append\", default=[], dest=\"overrides\")\n+    parser.add_argument(\"--out\", type=Path, default=RESULTS / \"exploit_report.csv\")\n+    parser.add_argument(\"--dry-run\", action=\"store_true\", help=\"merge/validate only\")\n+    parser.add_argument(\"--langs\", nargs=\"+\", default=None, help=\"subset: nginx li\")\n+    parser.add_argument(\n+        \"--compare-nginx\",\n+        action=\"store_true\",\n+        help=\"run nginx then li; record stricter-li deltas in notes\",\n+    )\n+    args = parser.parse_args()\n+\n+    profile = args.profile\n+    if profile is None:\n+        suite = load_suite_exploits()\n+        profile = str(suite.get(\"default_profile\", \"pr\"))\n+\n+    ids = list_exploit_ids(profile=profile, explicit=args.exploits or None)\n+    if not ids:\n+        print(\"exploit_http: no exploits for profile\", profile, file=sys.stderr)\n+        return 1\n+\n+    if args.dry_run or os.environ.get(\"TIER5_EXPLOIT_DRY_RUN\", \"\").strip() in (\"1\", \"true\", \"yes\"):\n+        ok_all = True\n+        for eid in ids:\n+            ok, msg = dry_run_exploit(eid, profile=profile, overrides=args.overrides)\n+            status = \"PASS\" if ok else \"FAIL\"\n+            print(f\"{status} exploit_http dry-run {eid}: {msg}\")\n+            ok_all = ok_all and ok\n+        return 0 if ok_all else 1\n+\n+    stub = stub_mode() or not (shutil.which(\"nginx\") or os.path.isfile(os.environ.get(\"LI_HTTPD_BIN\", str(REPO / \"build\" / \"li-httpd\"))))\n+    if stub:\n+        print(\"exploit_http: stub mode (TIER5_EXPLOIT_STUB or missing nginx/li-httpd)\", file=sys.stderr)\n+\n+    sha = git_sha()\n+    loc = loc_httpd()\n+    rows: list[dict[str, object]] = []\n+    failed = 0\n+\n+    for eid in ids:\n+        cfg = merge_exploit(eid, overrides=args.overrides, profile=profile)\n+        cfg[\"_profile\"] = profile or \"\"\n+        if cfg.get(\"enabled\") is False:\n+            continue\n+        errs = validate_exploit(cfg)\n+        if errs:\n+            print(f\"FAIL exploit_http {eid}: {'; '.join(errs)}\", file=sys.stderr)\n+            failed += 1\n+            continue\n+        langs = target_langs(cfg, cli_langs=args.langs)\n+        if args.compare_nginx:\n+            langs = [\"nginx\", \"li\"]\n+        by_lang: dict[str, tuple[bool, str]] = {}\n+        for lang in langs:\n+            ok, msg, _outcome = run_exploit_for_lang(\n+                cfg, lang, stub=stub, compare=args.compare_nginx\n+            )\n+            by_lang[lang] = (ok, msg)\n+            inv = \"\"\n+            mit = load_toml_path = mitigation_id(cfg)\n+            _ = load_toml_path\n+            try:\n+                mit_path = TIER5 / \"nginx_mitigations.toml\"\n+                if mit_path.is_file():\n+                    import tomllib\n+\n+                    mit_data = tomllib.loads(mit_path.read_text(encoding=\"utf-8\"))\n+                    for row in mit_data.get(\"mitigation\") or []:\n+                        if isinstance(row, dict) and row.get(\"id\") == mit:\n+                            inv = str(row.get(\"li_invariant\", \"\"))\n+                            break\n+            except Exception:\n+                pass\n+            cmp_notes = compare_langs_outcomes(cfg, by_lang) if args.compare_nginx else []\n+            note = msg\n+            if cmp_notes:\n+                note = f\"{note}; {'; '.join(cmp_notes)}\"\n+            rows.append(\n+                {\n+                    \"exploit_id\": eid,\n+                    \"mitigation_id\": mit,\n+                    \"lang\": lang,\n+                    \"passed\": \"true\" if ok else \"false\",\n+                    \"li_invariant\": inv,\n+                    \"git_sha\": sha,\n+                    \"loc_httpd\": loc,\n+                    \"notes\": note,\n+                }\n+            )\n+            status = \"PASS\" if ok else \"FAIL\"\n+            print(f\"{status} exploit_http {eid} [{lang}]: {msg}\")\n+            if not ok:\n+                failed += 1\n+\n+    if rows:\n+        write_csv(args.out, rows)\n+        print(f\"exploit_http: wrote {len(rows)} rows -> {args.out}\")\n+    return 1 if failed else 0\n+\n+\n+if __name__ == \"__main__\":\n+    sys.exit(main())"
