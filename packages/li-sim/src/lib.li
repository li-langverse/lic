  public sensor_last_hit1: float
  public sensor_last_hit2: float
  public sensor_last_hit3: float
  public sensor_last_raycast_id: int

def sim_session_stub_default() -> SimSessionStub
  requires true
  ensures result.studio_profile_id == 0
  ensures result.sim_contract_id == sim_contract_unknown()
  ensures result.output_detail == output_detail_summary()
  ensures result.tick == 0
  ensures result.last_dt == 0.0
  ensures result.replay_capacity == sim_replay_capacity_default()
  ensures result.replay_count == 0
  ensures result.replay_last_tick == 0
  ensures result.game_px == 0.0
  ensures result.game_pz == 0.0
  ensures result.game_physics_steps == 0
  ensures result.env_pool_size == 0
  ensures result.env_pool_steps_emitted == 0
  ensures result.env_pool_total_reward == 0.0
  ensures result.sensor_bus_size == 0
  ensures result.sensor_rays_emitted == 0
  ensures result.sensor_last_raycast_id == 0
  decreases 0
=
  var s: SimSessionStub
  s.studio_profile_id = 0
  s.sim_contract_id = sim_contract_unknown()
  s.output_detail = output_detail_summary()
  s.tick = 0
  s.last_dt = 0.0
  s.replay_capacity = sim_replay_capacity_default()
  s.replay_count = 0
  s.replay_last_tick = 0
  s.game_px = 0.0
  s.game_py = 0.0
  s.game_pz = 0.0
  s.game_vx = 0.0
  s.game_vy = 0.0
  s.game_vz = 0.0
  s.game_physics_steps = 0
  s.env_pool_size = 0
  s.env_pool_steps_emitted = 0
  s.env_pool_total_reward = 0.0
  s.env_last_obs0 = 0.0
  s.env_last_obs1 = 0.0
  s.env_last_obs2 = 0.0
  s.env_last_obs3 = 0.0
  s.env_last_obs4 = 0.0
  s.env_last_obs5 = 0.0
  s.env_last_obs6 = 0.0
  s.env_last_obs7 = 0.0
  s.env_last_reward = 0.0
  s.env_last_done = 0
  s.env_last_env_index = 0
  s.sensor_bus_size = 0
  s.sensor_rays_emitted = 0
  s.sensor_last_hit0 = 0.0
  s.sensor_last_hit1 = 0.0
  s.sensor_last_hit2 = 0.0
  s.sensor_last_hit3 = 0.0
  s.sensor_last_raycast_id = 0
  return s

def sim_session_replay_record(session: var SimSessionStub) -> unit
  requires session.replay_capacity > 0
  requires session.tick >= 0
  ensures session.replay_last_tick == session.tick
  decreases session.replay_count
=
  session.replay_count = session.replay_count + 1
  if session.replay_count > session.replay_capacity:
    session.replay_count = session.replay_capacity
  session.replay_last_tick = session.tick

def sim_session_replay_last_tick(session: SimSessionStub) -> int
  requires true
  ensures result == session.replay_last_tick
  decreases 0
=
  return session.replay_last_tick

# PH-SIM SIM-1 — deterministic tick counter (no physics kernel).
def sim_reset(session: var SimSessionStub) -> int
  requires true
  ensures result == sim_status_ok()
  ensures session.tick == 0
  ensures session.last_dt == 0.0
  ensures session.replay_count == 0
  ensures session.replay_last_tick == 0
  ensures session.game_px == 0.0
  ensures session.game_pz == 0.0
  ensures session.game_physics_steps == 0
  ensures session.env_pool_steps_emitted == 0
  ensures session.env_pool_total_reward == 0.0
  ensures session.sensor_rays_emitted == 0
  ensures session.sensor_last_raycast_id == 0
  decreases 0
=
  session.tick = 0
  session.last_dt = 0.0
  session.replay_count = 0
  session.replay_last_tick = 0
  session.game_px = 0.0
  session.game_py = 0.0
  session.game_pz = 0.0
  session.game_vx = 0.0
  session.game_vy = 0.0
  session.game_vz = 0.0
  session.game_physics_steps = 0
  session.env_pool_steps_emitted = 0
  session.env_pool_total_reward = 0.0
  session.env_last_obs0 = 0.0
  session.env_last_obs1 = 0.0
  session.env_last_obs2 = 0.0
  session.env_last_obs3 = 0.0
  session.env_last_obs4 = 0.0
  session.env_last_obs5 = 0.0
  session.env_last_obs6 = 0.0
  session.env_last_obs7 = 0.0
  session.env_last_reward = 0.0
  session.env_last_done = 0
  session.env_last_env_index = 0
  session.sensor_rays_emitted = 0
  session.sensor_last_hit0 = 0.0
  session.sensor_last_hit1 = 0.0
  session.sensor_last_hit2 = 0.0
  session.sensor_last_hit3 = 0.0
  session.sensor_last_raycast_id = 0
  return sim_status_ok()

def sim_step(session: var SimSessionStub, dt: float) -> int
  requires session.tick >= 0
  requires session.replay_capacity > 0
  ensures result >= 0
  ensures result <= 1
  decreases session.tick
=
  if dt <= 0.0:
    return sim_status_invalid_dt()
  session.tick = session.tick + 1
  session.last_dt = dt
  sim_session_replay_record(session)
  return sim_status_ok()

def sim_session_apply_studio_profile(studio_profile_id: int, sim_out: var SimSessionStub) -> unit
  requires true
  ensures sim_out.studio_profile_id == studio_profile_id
  ensures sim_out.sim_contract_id == li_sim_profile_from_studio_id(studio_profile_id)
  ensures sim_out.output_detail == sim_output_detail_for_studio_profile(studio_profile_id)
  decreases studio_profile_id
=
  var sid: int = studio_profile_id
  sim_out.studio_profile_id = sid
  var contract0: int = sim_contract_unknown()
  if sid == 1:
    contract0 = sim_contract_game()
  if sid == 2:
    contract0 = sim_contract_sim_rl()
  if sid == 3:
    contract0 = sim_contract_sim_automotive()
  if sid == 4:
    contract0 = sim_contract_sim_robotics()
  if sid == 5:
    contract0 = sim_contract_sim_additive()
  if sid == 6:
    contract0 = sim_contract_sim_scientific()
  if sid == 7:
    contract0 = sim_contract_sim_drug_design()
  sim_out.sim_contract_id = contract0
  var detail0: int = output_detail_summary()
  if sid == 6:
    detail0 = output_detail_debug()
  if sid == 7:
    detail0 = output_detail_debug()
  if sid >= 2:
    if sid <= 5:
      detail0 = output_detail_fields()
  sim_out.output_detail = detail0

# PH-SIM SIM-3 partial — RL env pool stub batches sim_step across parallel env slots.
def sim_rl_env_pool_size_default() -> int
  requires true
  ensures result == 4
  decreases 0
=
  return 4

type EnvPoolStub = object
  public pool_size: int
  public steps_emitted: int
  public total_reward: float

type EnvStepResult = object
  public obs0: float
  public obs1: float
  public obs2: float
  public obs3: float
  public obs4: float
  public obs5: float
  public obs6: float
  public obs7: float
  public act0: float
  public act1: float
  public act2: float
  public act3: float
  public reward: float
  public done: int
  public env_index: int

def env_pool_stub_default() -> EnvPoolStub
  requires true
  ensures result.pool_size == sim_rl_env_pool_size_default()
  ensures result.steps_emitted == 0
  ensures result.total_reward == 0.0
  decreases 0
=
  var p: EnvPoolStub
  p.pool_size = sim_rl_env_pool_size_default()
  p.steps_emitted = 0
  p.total_reward = 0.0
  return p

def sim_env_obs_dim() -> int
  requires true
  ensures result == 8
  decreases 0
=
  return 8

def sim_session_env_pool_init(session: var SimSessionStub) -> unit
  requires true
  ensures session.env_pool_size == sim_rl_env_pool_size_default()
  ensures session.env_pool_steps_emitted == 0
  ensures session.env_pool_total_reward == 0.0
  decreases 0
=
  session.env_pool_size = sim_rl_env_pool_size_default()
  session.env_pool_steps_emitted = 0
  session.env_pool_total_reward = 0.0

def sim_session_env_pool_load(session: SimSessionStub) -> EnvPoolStub
  requires session.env_pool_size > 0
  ensures result.pool_size == session.env_pool_size
  ensures result.steps_emitted == session.env_pool_steps_emitted
  ensures result.total_reward == session.env_pool_total_reward
  decreases 0
=
  var p: EnvPoolStub
  p.pool_size = session.env_pool_size
  p.steps_emitted = session.env_pool_steps_emitted
  p.total_reward = session.env_pool_total_reward
  return p

def sim_session_env_pool_store(session: var SimSessionStub, pool: EnvPoolStub) -> unit
  requires pool.pool_size > 0
  ensures session.env_pool_size == pool.pool_size
  ensures session.env_pool_steps_emitted == pool.steps_emitted
  ensures session.env_pool_total_reward == pool.total_reward
  decreases 0
=
  session.env_pool_size = pool.pool_size
  session.env_pool_steps_emitted = pool.steps_emitted
  session.env_pool_total_reward = pool.total_reward

def env_obs_store_on_session(session: var SimSessionStub, post: EnvStepResult) -> unit
  requires true
  ensures session.env_last_obs0 == post.obs0
  ensures session.env_last_obs1 == post.obs1
  ensures session.env_last_reward == post.reward
  ensures session.env_last_done == post.done
  ensures session.env_last_env_index == post.env_index
  decreases 0
=
  session.env_last_obs0 = post.obs0
  session.env_last_obs1 = post.obs1
  session.env_last_obs2 = post.obs2
  session.env_last_obs3 = post.obs3
  session.env_last_obs4 = post.obs4
  session.env_last_obs5 = post.obs5
  session.env_last_obs6 = post.obs6
  session.env_last_obs7 = post.obs7
  session.env_last_reward = post.reward
  session.env_last_done = post.done
  session.env_last_env_index = post.env_index

def env_obs_from_session(session: SimSessionStub) -> EnvStepResult
  requires true
  ensures result.obs0 == session.env_last_obs0
  ensures result.obs1 == session.env_last_obs1
  ensures result.reward == session.env_last_reward
  ensures result.done == session.env_last_done
  ensures result.env_index == session.env_last_env_index
  decreases 0
=
  var r: EnvStepResult
  r.obs0 = session.env_last_obs0
  r.obs1 = session.env_last_obs1
  r.obs2 = session.env_last_obs2
  r.obs3 = session.env_last_obs3
  r.obs4 = session.env_last_obs4
  r.obs5 = session.env_last_obs5
  r.obs6 = session.env_last_obs6
  r.obs7 = session.env_last_obs7
  r.act0 = 0.0
  r.act1 = 0.0
  r.act2 = 0.0
  r.act3 = 0.0
  r.reward = session.env_last_reward
  r.done = session.env_last_done
  r.env_index = session.env_last_env_index
  return r

def env_tick_as_float(tick: int) -> float
  requires tick >= 0
  requires tick <= 32
  ensures result >= 0.0
  decreases tick
=
  if tick == 0:
    return 0.0
  if tick == 1:
    return 1.0
  if tick == 2:
    return 2.0
  if tick == 3:
    return 3.0
  if tick == 4:
    return 4.0
  return 5.0

def env_action_for_index(env_index: int) -> EnvStepResult
  requires env_index >= 0
  requires env_index < 32
  ensures result.env_index == env_index
  decreases env_index
=
  var ei: int = env_index
  var e1: int = env_index
  var e2: int = env_index
  var e3: int = env_index
  var r: EnvStepResult
  r.env_index = ei
  r.act0 = 0.0
  r.act1 = 0.0
  r.act2 = 0.0
  r.act3 = 0.0
  if e1 == 1:
    r.act0 = 0.1
  if e2 == 2:
    r.act0 = 0.2
  if e3 == 3:
    r.act0 = 0.3
  r.obs0 = 0.0
  r.obs1 = 0.0
  r.obs2 = 0.0
  r.obs3 = 0.0
  r.obs4 = 0.0
  r.obs5 = 0.0
  r.obs6 = 0.0
  r.obs7 = 0.0
  r.reward = 0.0
  r.done = 0
  return r

def env_obs_fill_fields(
    r: var EnvStepResult, tick: int, last_dt: float, env_index: int) -> unit
  requires tick >= 0
  requires env_index >= 0
  requires env_index < 32
  ensures r.obs1 == last_dt
  decreases env_index
=
  var e1: int = env_index
  var e2: int = env_index
  var e3: int = env_index
  var t_obs: int = tick
  r.obs0 = env_tick_as_float(t_obs)
  r.obs1 = last_dt
  r.obs2 = 0.0
  if e1 == 1:
    r.obs2 = 1.0
  if e2 == 2:
    r.obs2 = 2.0
  if e3 == 3:
    r.obs2 = 3.0
  r.obs3 = 0.0
  r.obs4 = 0.0
  r.obs5 = 0.0
  r.obs6 = 0.0
  r.obs7 = 0.0

def env_reward_for_action(act0: float, env_index: int, tick: int) -> float
  requires env_index >= 0
  requires env_index < 32
  requires tick >= 0
  ensures result >= -1.0
  decreases env_index
=
  var pen: float = 0.0
  var e1: int = env_index
  var e2: int = env_index
  var e3: int = env_index
  var t_rew: int = tick
  if e1 == 1:
    pen = 0.05
  if e2 == 2:
    pen = 0.10
  if e3 == 3:
    pen = 0.15
  return act0 - pen + 0.01 * env_tick_as_float(t_rew)

def env_step_contract_pre(
    pool_size: int, tick: int, last_dt: float, env_index: int) -> EnvStepResult
  requires pool_size > 0
  requires env_index >= 0
  requires env_index < pool_size
  requires tick >= 0
  ensures result.env_index == env_index
  ensures result.done == 0
  decreases env_index
=
  var t_obs: int = tick
  var ei_act: int = env_index
  var ei_obs: int = env_index
  var r: EnvStepResult = env_action_for_index(ei_act)
  env_obs_fill_fields(r, t_obs, last_dt, ei_obs)
  r.reward = 0.0
  r.done = 0
  return r

def env_step_contract_post(
    pre: EnvStepResult, tick: int, last_dt: float, pool_size: int) -> EnvStepResult
  requires tick >= 0
  requires pool_size > 0
  requires pre.env_index >= 0
  requires pre.env_index < pool_size
  ensures result.env_index == pre.env_index
  ensures result.done >= 0
  ensures result.done <= 1
  decreases pre.env_index
=
  var idx_obs: int = pre.env_index
  var idx_rew: int = pre.env_index
  var act0: float = pre.act0
  var t_obs: int = tick
  var t_rew: int = tick
  var t_done: int = tick
  var r: EnvStepResult = pre
  env_obs_fill_fields(r, t_obs, last_dt, idx_obs)
  r.reward = env_reward_for_action(act0, idx_rew, t_rew)
  r.done = 0
  if t_done >= pool_size * 8:
    r.done = 1
  return r

# PH-SIM SIM-3 Wave 5 � scratch buffers for pthread parallel env reward fill (G-ml-async).
type EnvPoolParallelScratch = object
  public pool_size: int
  public rewards: array[32, float]
  public env_indices: array[32, int]

def sim_rl_env_worker_mode() -> int
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  return 1

def env_pool_parallel_scratch_default(pool_size: int) -> EnvPoolParallelScratch
  requires pool_size > 0
  requires pool_size <= 32
  ensures result.pool_size == pool_size
  decreases pool_size
=
  var s: EnvPoolParallelScratch
  s.pool_size = pool_size
  var i: int = 0
  while i < 32
    s.rewards[i] = 0.0
    s.env_indices[i] = 0
    i = i + 1
  return s

def env_pool_parallel_reward_at(pool_size: int, base_tick: int, last_dt: float, env_index: int) -> float
  requires pool_size > 0
  requires pool_size <= 32
  requires base_tick >= 0
  requires env_index >= 0
  requires env_index < pool_size
  ensures result >= -1.0
  decreases env_index
=
  var pre: EnvStepResult = env_step_contract_pre(pool_size, base_tick + env_index, last_dt, env_index)
  var post: EnvStepResult = env_step_contract_post(pre, base_tick + env_index + 1, last_dt, pool_size)
  return post.reward

@cpu
@parallel(disjoint=disjoint_elem)
def env_pool_fill_rewards_parallel(scratch: var EnvPoolParallelScratch, base_tick: int, last_dt: float) -> int
  requires scratch.pool_size > 0
  requires scratch.pool_size <= 32
  requires base_tick >= 0
  ensures result >= 0
  ensures result <= 1
  decreases scratch.pool_size
=
  var psz: int = scratch.pool_size
  parallel for i in 0..<4
    requires disjoint_elem(i, scratch.rewards)
    decreases 4 - i
  =
    var ei: int = 0
    if i == 1:
      ei = 1
    if i == 2:
      ei = 2
    if i == 3:
      ei = 3
    if i < psz:
      scratch.env_indices[ei] = ei
      scratch.rewards[ei] = env_pool_parallel_reward_at(psz, base_tick, last_dt, ei)
  return sim_status_ok()

def env_pool_stub_step_sync(pool: var EnvPoolStub, session: var SimSessionStub, dt: float) -> int
  requires pool.pool_size > 0
  requires pool.pool_size <= 32
  requires session.tick >= 0
  requires session.replay_capacity > 0
  ensures result >= 0
  ensures result <= 1
  decreases pool.pool_size
=
  if dt <= 0.0:
    return sim_status_invalid_dt()
  var i: int = 0
  while i < pool.pool_size
    var tick0: int = session.tick
    var last_dt0: float = session.last_dt
    var psz: int = pool.pool_size
    var pre: EnvStepResult = env_step_contract_pre(psz, tick0, last_dt0, i)
    if sim_step(session, dt) != sim_status_ok():
      return sim_status_invalid_dt()
    var tick1: int = session.tick
    var last_dt1: float = session.last_dt
    var post: EnvStepResult = env_step_contract_post(pre, tick1, last_dt1, psz)
    pool.total_reward = pool.total_reward + post.reward
    pool.steps_emitted = pool.steps_emitted + 1
    env_obs_store_on_session(session, post)
    i = i + 1
  return sim_status_ok()

def env_pool_stub_step_thread_pool(pool: var EnvPoolStub, session: var SimSessionStub, dt: float) -> int
  requires pool.pool_size > 0
  requires pool.pool_size <= 32
  requires session.tick >= 0
  requires session.replay_capacity > 0
  ensures result >= 0
  ensures result <= 1
  decreases pool.pool_size
=
  if dt <= 0.0:
    return sim_status_invalid_dt()
  var scratch: EnvPoolParallelScratch = env_pool_parallel_scratch_default(pool.pool_size)
  var base_tick: int = session.tick
  var last_dt0: float = session.last_dt
  if env_pool_fill_rewards_parallel(scratch, base_tick, last_dt0) != sim_status_ok():
    return sim_status_invalid_dt()
  var i: int = 0
  while i < pool.pool_size
    var tick0: int = session.tick
    var psz: int = pool.pool_size
    var pre: EnvStepResult = env_step_contract_pre(psz, tick0, last_dt0, i)
    if sim_step(session, dt) != sim_status_ok():
      return sim_status_invalid_dt()
    var tick1: int = session.tick
    var last_dt1: float = session.last_dt
    var post: EnvStepResult = env_step_contract_post(pre, tick1, last_dt1, psz)
    post.reward = scratch.rewards[i]
    post.env_index = scratch.env_indices[i]
    pool.total_reward = pool.total_reward + post.reward
    pool.steps_emitted = pool.steps_emitted + 1
    env_obs_store_on_session(session, post)
    i = i + 1
  return sim_status_ok()

def env_pool_stub_step(pool: var EnvPoolStub, session: var SimSessionStub, dt: float) -> int
  requires pool.pool_size > 0
  requires pool.pool_size <= 32
  requires session.tick >= 0
  requires session.replay_capacity > 0
  ensures result >= 0
  ensures result <= 1
  decreases pool.pool_size
=
  if sim_rl_env_worker_mode() == 0:
    return env_pool_stub_step_sync(pool, session, dt)
  return env_pool_stub_step_thread_pool(pool, session, dt)

def sim_rl_session_env_pool_step(session: var SimSessionStub, dt: float) -> int
  requires session.tick >= 0
  requires session.replay_capacity > 0
  ensures result >= 0
  ensures result <= 1
  decreases session.tick
=
  if dt <= 0.0:
    return sim_status_invalid_dt()
  if session.env_pool_size <= 0:
    sim_session_env_pool_init(session)
  var steps_before: int = session.env_pool_steps_emitted
  var pool: EnvPoolStub = sim_session_env_pool_load(session)
  if env_pool_stub_step(pool, session, dt) != sim_status_ok():
    return sim_status_invalid_dt()
  sim_session_env_pool_store(session, pool)
  var psz: int = session.env_pool_size
  if session.env_pool_steps_emitted != steps_before + psz:
    return sim_status_invalid_dt()
  if session.env_pool_total_reward <= 0.0:
    return sim_status_invalid_dt()
  if sim_session_replay_last_tick(session) != session.tick:
    return sim_status_invalid_dt()
  var obs: EnvStepResult = env_obs_from_session(session)
  if obs.obs1 != session.last_dt:
    return sim_status_invalid_dt()
  if obs.env_index != psz - 1:
    return sim_status_invalid_dt()
  return sim_status_ok()

def sim_rl_tick_stub(detail: int) -> int
  requires detail >= 0
  requires detail <= 3
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  var sess: SimSessionStub = sim_session_stub_default()
  sim_session_apply_studio_profile(2, sess)
  var dt: float = 0.02
  if detail == 0:
    dt = 0.016
  if sim_rl_session_env_pool_step(sess, dt) != sim_status_ok():
    return 0
  return 1
