_id <= 117:\n      vert = vertical_md_lennard_jones()\n  if algo_id >= 201:\n    if algo_id <= 216:\n      vert = vertical_pde_heat_2d()\n  if algo_id >= 301:\n    if algo_id <= 305:\n      vert = vertical_gaming_rigid()\n  if algo_id >= 401:\n    if algo_id <= 432:\n      vert = vertical_qm_dft()\n  var r: SimRunResult\n  r.ok = 1\n  r.algo_id = algo_id\n  r.vertical_id = vert\n  r.checksum = 1.001\n  r.detail_emitted = detail\n  return r\n\ndef run_algo(algo_id: int, detail: int) -> SimRunResult\n  requires detail >= 0\n  requires detail <= 3\n  requires algo_id > 0\n  ensures result.detail_emitted == detail\n  decreases 0\n=\n  var reg_chk: int = algo_id\n  var reg_run: int = algo_id\n  if algo_id == algo_md_lj_cutoff_mic():\n    var d0: int = detail\n    return run_md_lj_smoke(d0)\n  if algo_id == algo_md_integrator_verlet():\n    var d1: int = detail\n    return run_md_lj_smoke(d1)\n  if algo_id == algo_pde_heat_explicit_2d():\n    var d2: int = detail\n    return run_heat_smoke(d2)\n  if algo_id == algo_rigid_semi_implicit():\n    var d3: int = detail\n    return run_rigid_smoke(d3)\n  if algo_in_registry(reg_chk) == 1:\n    var d4: int = detail\n    return run_algo_registry_stub(reg_run, d4)\n  var bad: SimRunResult\n  var d5: int = detail\n  bad.ok = 0\n  bad.algo_id = algo_id\n  bad.vertical_id = 0\n  bad.checksum = 0.0\n  bad.detail_emitted = d5\n  return bad\n\ndef run_simulation(vertical_id: int, detail: int) -> SimRunResult\n  requires detail >= 0\n  requires detail <= 3\n  requires vertical_id > 0\n  ensures result.detail_emitted == detail\n  decreases 0\n=\n  if vertical_id == vertical_md_lennard_jones():\n    var d0: int = detail\n    return run_md_lj_smoke(d0)\n  if vertical_id == vertical_pde_heat_2d():\n    var d1: int = detail\n    return run_heat_smoke(d1)\n  if vertical_id == vertical_gaming_rigid():\n    var d2: int = detail\n    return run_rigid_smoke(d2)\n  if vertical_id == vertical_qm_dft():\n    var d3: int = detail\n    return run_algo(algo_qm_dft_scf_energy(), d3)\n  var bad: SimRunResult\n  var d4: int = detail\n  bad.ok = 0\n  bad.algo_id = 0\n  bad.vertical_id = vertical_id\n  bad.checksum = 0.0\n  bad.detail_emitted = d4\n  return bad\n",
