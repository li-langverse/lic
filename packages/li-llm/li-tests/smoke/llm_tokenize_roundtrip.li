import llm

# PH-LLM WP-LLM-01 gate — stub honesty until tokenizer roundtrip is implemented.

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_llm_version() != 0:
    return 1
  var empty: LlmTokenIds = llm_token_ids_empty()
  if empty.count != 0:
    return 2
  var tok: LlmTokenIds = llm_tokenize("hello", "fixtures/vocab.json")
  if tok.count < 0:
    return 3
  var w: LlmModelWeights = llm_load_weights("fixtures/model.safetensors")
  if llm_model_weights_valid(w) != 0:
    return 4
  return 0
