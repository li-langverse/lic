import sim

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var f: SensorFrame = sensor_frame_make(1, output_detail_fields(), vertical_sim_automotive(), 64, 123.0)
  if sensor_frame_validate(f) != 1:
    return 1
  var b: SensorBus = sensor_bus_default()
  if sensor_bus_step_update(b, f) != sim_status_ok():
    return 2
  if sensor_bus_validate(b) != 1:
    return 3
  if b.last_step_index != 1:
    return 4
  if b.last_frame.raycast_count != 64:
    return 5
  return 0

