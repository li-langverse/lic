# G-bnd / G-vc probe: call-site refinement emits bounds Prop; callee body VC strips Index8→Int.
# Harness-only (open refine VC) — not in manifest verify_ok.
type Idx8 = {i: int | 0 <= i and i < 8}

def get_cell(grid: array[8, int], i: Idx8) -> int
  requires true
  ensures result == grid[i]
  decreases 0
=
  return grid[i]

def main() -> int
  requires true
  ensures result == 3
  decreases 0
=
  var g: array[8, int]
  g[3] = 3
  return get_cell(g, 3)
