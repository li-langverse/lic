# WP-GPU-04/06: @gpu MIR tag + codegen launch prologue (G-gpu Partial).
# Wave 4c: `fn.gpu_device` set in MIR lower; telemetry `mir_gpu_proc` at verify.

@gpu
def gpu_scale(x: float) -> float
  requires true
  ensures result == x + 1.0
  decreases 0
=
  return x + 1.0

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if gpu_scale(2.0) != 3.0:
    return 1
  return 0
