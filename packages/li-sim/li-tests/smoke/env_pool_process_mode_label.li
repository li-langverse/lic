import sim

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if sim_rl_env_worker_process_mode_label() != 2:
    return 1
  var pool: EnvPoolStub = env_pool_stub_default()
  var sess: SimSessionStub = sim_session_stub_default()
  sim_session_apply_studio_profile(2, sess)
  if env_pool_stub_step_process_pool(pool, sess, 0.02) != sim_status_ok():
    return 2
  if sess.tick != pool.pool_size:
    return 3
  if pool.steps_emitted != pool.pool_size:
    return 4
  return 0
