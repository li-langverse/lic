=
  var h: LlmSafetensorsHeader
  h.parsed_ok = 1
  h.header_len = 64
  h.tensor_count = 2
  h.tensors_loaded = 0
  return h

def llm_path_format_tag(path: str) -> int raises IO, Alloc
  requires true
  ensures result >= 0
  ensures result <= 2
  decreases 0
=
  var left: bytes = path
  var st: bytes = "fixtures/model.safetensors"
  var gguf: bytes = "fixtures/model.gguf"
  var ln: int = bytes_len(left)
  if ln == bytes_len(st):
    var i: int = 0
    var ok: int = 1
    while i < ln:
      if bytes_byte_at(left, i) != bytes_byte_at(st, i):
        ok = 0
        break
      i = i + 1
    if ok == 1:
      return llm_format_safetensors()
  if ln == bytes_len(gguf):
    var j: int = 0
    var ok2: int = 1
    while j < ln:
      if bytes_byte_at(left, j) != bytes_byte_at(gguf, j):
        ok2 = 0
        break
      j = j + 1
    if ok2 == 1:
      return llm_format_gguf()
  return llm_format_none()

# WP-LLM-02: safetensors header scaffold — fixture metadata only; tensor bytes not loaded.
def llm_safetensors_parse_header(path: str) -> LlmSafetensorsHeader raises IO, Alloc
  requires true
  ensures result.tensors_loaded == 0
  decreases 0
=
  var p: str = path
  var tag: int = llm_path_format_tag(p)
  if tag != llm_format_safetensors():
    return llm_safetensors_header_none()
  return llm_safetensors_header_fixture()


def llm_load_weights_safetensors_fixture() -> LlmModelWeights
  requires true
  ensures result.loaded == 1
  ensures result.format_tag == llm_format_safetensors()
  ensures result.header_parsed == 1
  ensures result.tensor_count == 2
  ensures result.tensors_loaded == 0
  decreases 0
=
  var hdr: LlmSafetensorsHeader = llm_safetensors_header_fixture()
  var w: LlmModelWeights
  w.loaded = 1
  w.format_tag = llm_format_safetensors()
  w.config = llm_model_config_fixture()
  w.header_parsed = hdr.parsed_ok
  w.tensor_count = hdr.tensor_count
  w.tensors_loaded = hdr.tensors_loaded
  return w

def llm_forward_smoke_oracle() raises IO -> int
  requires true
  ensures result >= 0
  ensures result <= 255
  decreases 0
=
  var w: LlmModelWeights = llm_load_weights_safetensors_fixture()
  var tok: LlmTokenIds = llm_tokenize("ab", "fixtures/vocab.json")
  var cache: LlmKVCache
  cache.seq_len = 0
  var logits: LlmLogits = llm_forward(tok, w, cache)
  return logits.top_id

def llm_load_weights(path: str) -> LlmModelWeights raises IO, Alloc
  requires true
  ensures result.loaded == 0
  decreases 0
=
  var pth: str = path
  var tag: int = llm_path_format_tag(pth)
  if tag == llm_format_safetensors():
    var hdr: LlmSafetensorsHeader = llm_safetensors_header_fixture()
    var w: LlmModelWeights
    w.loaded = 1
    w.format_tag = llm_format_safetensors()
    w.config = llm_model_config_fixture()
    w.header_parsed = hdr.parsed_ok
    w.tensor_count = hdr.tensor_count
    w.tensors_loaded = hdr.tensors_loaded
    return w
  if tag == llm_format_gguf():
    var w2: LlmModelWeights
    w2.loaded = 1
    w2.format_tag = llm_format_gguf()
    w2.config = llm_model_config_fixture()
    w2.header_parsed = 0
    w2.tensor_count = 0
    w2.tensors_loaded = 0
    return w2
  return llm_model_weights_none()

def llm_forward_matmul_cpu_hint() raises IO -> int
  requires true
  ensures result >= -1
  decreases 0
=
  return ml_lig_matmul_run_auto()

def llm_transformer_matmul_contrib(token_acc: int, hidden_dim: int) raises IO -> int
  requires token_acc >= 0
  requires hidden_dim >= 1
  ensures result >= 0
  decreases hidden_dim
=
  var _hd: int = hidden_dim
  var slot: int = token_acc % 16
  var a: array[64, float]
  var b: array[64, float]
  var c: array[64, float]
  a[0] = 1.0
  b[0] = 1.0
  if ml_matmul_f32(1, 1, 1, a, b, c) != 1:
    return 0
  if c[0] < 0.5:
    return 0
  return slot + 1

# WP-LLM-03: transformer graph scaffold — token checksum + ml_matmul_f32 layer stub.
def llm_forward(tokens: LlmTokenIds, weights: LlmModelWeights, cache: LlmKVCache) -> LlmLogits raises IO
  requires tokens.count >= 0
  requires cache.seq_len >= 0
  ensures result.vocab_size >= 0
  decreases tokens.count
=
  var out: LlmLogits
  out.vocab_size = weights.config.vocab_size
  out.top_id = 0
  if llm_model_weights_valid(weights) != 1:
    return out
  if tokens.count <= 0:
    return out
  var acc: int = 0
  var i: int = 0
  while i < tokens.count:
    acc = acc + tokens.ids[i]
    i = i + 1
  var matmul_hint: int = llm_forward_matmul_cpu_hint()
  if matmul_hint < 0:
    acc = acc + 7
  if matmul_hint >= 0:
    acc = acc + matmul_hint
  acc = acc + llm_transformer_matmul_contrib(acc, weights.config.hidden_dim)
  if out.vocab_size > 0:
    out.top_id = acc % out.vocab_size
  return out

def llm_generate(
    prompt: str, weights: LlmModelWeights, vocab_path: str, max_tokens: int) -> str raises IO, Alloc
  requires max_tokens >= 0
  ensures result != ""
  decreases max_tokens
=
  if llm_model_weights_valid(weights) != 1:
    return "."
  if max_tokens <= 0:
    return "."
  var vocab_copy: str = vocab_path
  var tok: LlmTokenIds = llm_tokenize(prompt, vocab_path)
  var cache: LlmKVCache
  cache.seq_len = tok.count
  var logits: LlmLogits = llm_forward(tok, weights, cache)
  var out_ids: LlmTokenIds = llm_token_ids_empty()
  out_ids.count = 1
  out_ids.ids[0] = logits.top_id + 1
  if logits.top_id == 0:
    out_ids.ids[0] = 1
  return llm_detokenize(out_ids, vocab_copy)
