# Author-facing sim_step_physics — copy `sim_step_physics` into world.li (see physics.runtime).
import physics.runtime

def sim_step_physics(tick: int, tier: int, dt_millis: int) -> int
  requires tick >= 0
  requires tier >= 0
  requires tier <= 3
  requires dt_millis > 0
  ensures result == tick + 1
  decreases tick
=
  return physics_step_for_game_tick(tier, tick, dt_millis)

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  return 0
