#!/usr/bin/env bash
# Phase 8b stub — package manager CLI (full impl in li-langverse/lip).
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"

usage() {
  cat <<'EOF'
lip — Li package manager (stub)

  lip init NAME [--kind library|binary]   scaffold via li-new-package
  lip lock [--out FILE]                   write stub li.lock (phase 8c)
  lip publish [--dry-run]                 verify + lit stub (phase 8d)
  lip --version

Set LI_REPO_ROOT to the lic monorepo when developing.
EOF
}

cmd="${1:-}"
case "$cmd" in
  -h|--help|"") usage; exit 0 ;;
  --version|-V) echo "lip 0.1.0-stub"; exit 0 ;;
  init)
    shift
    name="${1:?package name required}"
    shift || true
    exec "$ROOT/scripts/li-new-package" "$name" "$@"
    ;;
  lock)
    shift
    out="${ROOT}/li.lock"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --out) out="${2:?}"; shift 2 ;;
        *) echo "lip lock: unknown option $1" >&2; exit 1 ;;
      esac
    done
    digest="stub-unproved"
    if command -v shasum >/dev/null 2>&1; then
      digest="$(shasum -a 256 "$ROOT/build/compiler/lic/lic" 2>/dev/null | awk '{print $1}' || echo stub-unproved)"
    fi
    cat >"$out" <<EOF
# Generated by lip lock (phase 8c stub — ed25519 verify in lip repo)
version = 1
proof_digest = "sha256:${digest}"
sig_ed25519 = ""
coverage_digest = "stub-none"
EOF
    echo "wrote $out"
    ;;
  publish)
    shift
    dry=false
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --dry-run) dry=true; shift ;;
        *) echo "lip publish: unknown option $1" >&2; exit 1 ;;
      esac
    done
    LIC="${LIC:-$("$ROOT/scripts/resolve-lic.sh")}"
  export LI_REPO_ROOT="$ROOT"
    echo "lip publish: lic build + lit (stub gate)"
    if [[ "$dry" == true ]]; then
      echo "lip publish: dry-run ok"
      exit 0
    fi
    "$LIC" build "$ROOT/li-tests/modules/greeter/greeter.li" -o /dev/null
    "$ROOT/scripts/lit" test modules
    echo "lip publish: ok (registry upload not implemented)"
    ;;
  *)
    echo "lip: unknown command '$cmd' (stub)" >&2
    exit 1
    ;;
esac
