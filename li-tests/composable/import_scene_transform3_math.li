import scene
import math

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_scene_version() < 2:
    return 1
  var t: Transform3 = transform_identity()
  if t.rotation.w < 0.99 or t.rotation.w > 1.01:
    return 2
  if t.scale.x < 0.99 or t.scale.x > 1.01:
    return 3
  if t.position.x != 0.0:
    return 4
  var other: Transform3 = transform_identity()
  var rot: Quat = other.rotation
  rot.z = 0.5
  other.rotation = rot
  var t_b: Transform3 = transform_identity()
  var d: float = transform_rotation_dot(t_b, other)
  if d < 0.49 or d > 0.51:
    return 5
  return 0
