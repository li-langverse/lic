# Spin-up: additive manufacturing / voxel (PH-AM / PH-VOXEL).
import studio
import voxel
import sim.additive
import sim

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if sim_profile_additive() != voxel_mode_additive():
    return 1
  if voxel_additive_smoke() != 0:
    return 2
  return additive_voxel_smoke()
