# P-linalg: full 2×2 float `@` as one Lean Prop (Li.Discharge.mat2_at2_float_spec).
def mat2_at2(A: array[2, array[2, float]], B: array[2, array[2, float]]) -> array[2, array[2, float]]
  requires true
  ensures result[0][0] == A[0][0] * B[0][0] + A[0][1] * B[1][0] and result[0][1] == A[0][0] * B[0][1] + A[0][1] * B[1][1] and result[1][0] == A[1][0] * B[0][0] + A[1][1] * B[1][0] and result[1][1] == A[1][0] * B[0][1] + A[1][1] * B[1][1]
  decreases 0
=
  return A @ B

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var A: array[2, array[2, float]]
  var B: array[2, array[2, float]]
  A[0][0] = 1.0
  A[0][1] = 2.0
  A[1][0] = 3.0
  A[1][1] = 4.0
  B[0][0] = 5.0
  B[0][1] = 6.0
  B[1][0] = 7.0
  B[1][1] = 8.0
  var C: array[2, array[2, float]] = mat2_at2(A, B)
  return 0
