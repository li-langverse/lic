# Studio-shaped module: @gpu on viewport tick kernel (headless parse + MIR only).
@gpu
def studio_viewport_tick_kernel(frame: int) -> int
  requires frame >= 0
  ensures result == frame
  decreases 0
=
  return frame

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if studio_viewport_tick_kernel(3) != 3:
    return 1
  return 0
