import sim

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var pool: EnvPoolStub = env_pool_stub_default()
  var sess: SimSessionStub = sim_session_stub_default()
  sim_session_apply_studio_profile(2, sess)
  if env_pool_stub_step(pool, sess, 0.02) != sim_status_ok():
    return 1
  if sess.tick != pool.pool_size:
    return 2
  if pool.steps_emitted != pool.pool_size:
    return 3
  if pool.total_reward <= 0.0:
    return 4
  if sim_session_replay_last_tick(sess) != pool.pool_size:
    return 5
  if sim_rl_tick_stub(1) != 1:
    return 6
  return 0
