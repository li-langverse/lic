# PH-PHYS-CUSTOM smoke — inverse gravity (unphysical).

type CustomState = object
  public vx: float
  public vy: float
  public py: float

def inverse_gravity_step(s: CustomState, dt: float) -> unit
  requires dt > 0.0
  decreases 0
=
  s.vy = s.vy + 9.81 * dt
  s.py = s.py + s.vy * dt

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var s: CustomState
  s.vx = 0.0
  s.vy = 0.0
  s.py = 0.0
  inverse_gravity_step(s, 1.0 / 60.0)
  if s.vy <= 0.0:
    return 1
  return 0
