import sim.scientific

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_sim_scientific_version() != 3:
    return 1
  var md: float = sim_scientific_oracle_checksum_md()
  if md <= 0.0:
    return 2
  if md >= 1.0e-3:
    return 3
  var heat: float = sim_scientific_oracle_checksum_heat()
  if heat <= 1.0:
    return 4
  if heat >= 10.0:
    return 5
  var md_run: SimRunResult = run_md_lj_smoke(0)
  if run_result_ok(md_run) != 1:
    return 6
  if md_run.checksum != md:
    return 7
  var heat_run: SimRunResult = run_heat_smoke(0)
  if run_result_ok(heat_run) != 1:
    return 8
  if heat_run.checksum != heat:
    return 9
  return 0
