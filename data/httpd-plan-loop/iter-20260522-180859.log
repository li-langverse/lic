es, dict) and profile in profiles:\n+        prof = profiles[profile]\n+        if isinstance(prof, dict) and prof.get(\"tiers\"):\n+            tiers = {str(t) for t in prof[\"tiers\"]}\n+            return _ids_for_tiers(tiers)\n+    default_profile = str(suite.get(\"default_profile\", \"pr\"))\n+    if profile is None:\n+        profile = default_profile\n+    if isinstance(profiles, dict) and profile in profiles:\n+        prof = profiles[profile]\n+        if isinstance(prof, dict) and prof.get(\"tiers\"):\n+            tiers = {str(t) for t in prof[\"tiers\"]}\n+            return _ids_for_tiers(tiers)\n+    return _ids_for_tiers(set())\n+\n+\n+def _ids_for_tiers(tiers: set[str]) -> list[str]:\n+    if not EXPLOITS_DIR.is_dir():\n+        return []\n+    names: list[str] = []\n+    for path in sorted(EXPLOITS_DIR.glob(\"*.toml\")):\n+        data = load_toml(path)\n+        if data.get(\"enabled\") is False:\n+            continue\n+        tier = str(data.get(\"tier\", \"\"))\n+        if tiers and tier not in tiers:\n+            continue\n+        names.append(path.stem)\n+    return names\n+\n+\n+def profile_tiers(profile: str | None) -> list[str]:\n+    suite = load_suite_exploits()\n+    profiles = suite.get(\"profiles\") or {}\n+    if profile and isinstance(profiles, dict):\n+        prof = profiles.get(profile)\n+        if isinstance(prof, dict) and prof.get(\"tiers\"):\n+            return [str(t) for t in prof[\"tiers\"]]\n+    return []\n+\n+\n+def target_langs(cfg: dict[str, Any], *, cli_langs: list[str] | None) -> list[str]:\n+    if cli_langs:\n+        return list(cli_langs)\n+    targets = cfg.get(\"targets\") or {}\n+    if isinstance(targets, dict) and targets.get(\"langs\"):\n+        raw = targets[\"langs\"]\n+        if isinstance(raw, list):\n+            return [str(x) for x in raw]\n+    return [\"nginx\", \"li\"]\n+\n+\n+def resolve_server_config(cfg: dict[str, Any]) -> Path:\n+    targets = cfg.get(\"targets\") or {}\n+    rel = targets.get(\"server_config\") if isinstance(targets, dict) else None\n+    if not rel:\n+        raise ValueError(f\"exploit {cfg.get('id')}: missing [targets].server_config\")\n+    path = Path(str(rel))\n+    if not path.is_absolute():\n+        path = (TIER5 / path).resolve()\n+        if not path.is_file():\n+            path = (TIER5.parent.parent / rel).resolve()\n+    if not path.is_file():\n+        raise FileNotFoundError(f\"server_config not found: {rel}\")\n+    return path\n+\n+\n+def attack_script_path(cfg: dict[str, Any]) -> Path | None:\n+    attack = cfg.get(\"attack\") or {}\n+    if not isinstance(attack, dict):\n+        return None\n+    script = attack.get(\"script\")\n+    if not script:\n+        return None\n+    path = Path(str(script))\n+    if path.is_absolute():\n+        return path\n+    return (TIER5 / path).resolve()\n+\n+\n+def mitigation_id(cfg: dict[str, Any]) -> str:\n+    nginx_src = cfg.get(\"nginx_src\") or {}\n+    if isinstance(nginx_src, dict) and nginx_src.get(\"mitigation_id\"):\n+        return str(nginx_src[\"mitigation_id\"])\n+    return \"\"\n+\n+\n+def validate_exploit(cfg: dict[str, Any]) -> list[str]:\n+    errors: list[str] = []\n+    if not cfg.get(\"id\"):\n+        errors.append(\"missing id\")\n+    if cfg.get(\"enabled\") is False:\n+        return errors\n+    if not cfg.get(\"tier\"):\n+        errors.append(\"missing tier\")\n+    expect = cfg.get(\"expect\")\n+    if expect is not None and not isinstance(expect, dict):\n+        errors.append(\"[expect] must be a table\")\n+    attack = cfg.get(\"attack\")\n+    if attack is not None and not isinstance(attack, dict):\n+        errors.append(\"[attack] must be a table\")\n+    elif isinstance(attack, dict):\n+        driver = attack.get(\"driver\")\n+        if driver not in (\"python\", \"raw_socket\", \"h2_flood\", \"tlsfuzzer\", \"nuclei\", None):\n+            errors.append(f\"unsupported attack.driver={driver!r}\")\n+        if driver == \"python\" and 