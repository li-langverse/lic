# G-par / G-dec: proc @parallel(disjoint=) does not enable capture policy on @parallel `for`.
def par_def_decor_mut_capture() -> unit
  requires true
  ensures true
  decreases 0
=
  var counter: int = 0
  var buf: array[8, float]
  @parallel(disjoint=disjoint_elem)
  for i in 0..<8
    counter = counter + 1
    buf[i] = 0.0
