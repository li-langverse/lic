# Pure-Li horner loop — no LI_EXTRA_C; exercises BinOpFloat + while.

proc main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var x: float = 1.1
  var acc: float = 0.0
  var i: int = 0
  while i < 5000000
    acc = acc * x + 1.0
    i = i + 1
  if acc > 0.0:
    return 0
  return 1
