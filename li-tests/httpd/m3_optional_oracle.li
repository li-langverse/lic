# M3 optional oracle — L4 stream config + token-budget hooks (C runtime).
import http

extern proc li_rt_httpd_m3_enabled() -> int
  requires true
  ensures 0 <= result
  ensures result <= 1

extern proc li_rt_httpd_m3_l4_enabled() -> int
  requires true
  ensures 0 <= result
  ensures result <= 1

extern proc li_rt_httpd_m3_l4_listen_port() -> int
  requires true
  ensures 0 <= result

extern proc li_rt_httpd_m3_l4_upstream_port() -> int
  requires true
  ensures 0 <= result

extern proc li_rt_httpd_m3_l4_max_connections() -> int
  requires true
  ensures 0 <= result

extern proc li_rt_httpd_m3_token_budget_enabled() -> int
  requires true
  ensures 0 <= result
  ensures result <= 1

extern proc li_rt_httpd_m3_token_budget_max() -> int
  requires true
  ensures 0 <= result

extern proc li_rt_httpd_m3_token_budget_check(header_val: str) -> int
  requires true
  ensures -2 <= result
  ensures result <= 1

extern proc li_rt_httpd_m3_selftest() -> int
  requires true
  ensures -5 <= result
  ensures result <= 0

def main() raises IO, Alloc -> int
  requires true
  ensures result == 0
  decreases 0
=
  var cfg: str = "li-tests/config_desugar/good/m3_optional.toml"
  if load_routes_from_toml(cfg) != 0:
    return 1
  if li_rt_httpd_m3_enabled() != 1:
    return 2
  if li_rt_httpd_m3_l4_enabled() != 1:
    return 3
  if li_rt_httpd_m3_l4_listen_port() != 9443:
    return 4
  if li_rt_httpd_m3_l4_upstream_port() != 11435:
    return 5
  if li_rt_httpd_m3_l4_max_connections() != 512:
    return 6
  if li_rt_httpd_m3_token_budget_enabled() != 1:
    return 7
  if li_rt_httpd_m3_token_budget_max() != 500000:
    return 8
  if li_rt_httpd_m3_token_budget_check("1000") != 1:
    return 9
  if li_rt_httpd_m3_token_budget_check("9999999") != 0:
    return 10
  if li_rt_httpd_m3_token_budget_check("0") != 0:
    return 11
  if li_rt_httpd_m3_selftest() != 0:
    return 12
  return 0
