# Pure-Li horner loop — no LI_EXTRA_C; exercises BinOpFloat + while.

extern proc li_rt_volatile_sink_f64(v: float) -> unit
  requires true
  ensures true

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var x: float = 0.999999
  var acc: float = 0.0
  var i: int = 0
  while i < 5000000
    acc = acc * x + 1.0
    i = i + 1
  li_rt_volatile_sink_f64(acc)
  return 0
