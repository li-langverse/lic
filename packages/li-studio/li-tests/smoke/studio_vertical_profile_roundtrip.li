import studio

# Per-vertical compose roundtrip — every world-studio-vision runtime profile.

def studio_vertical_compose_ok(profile_id: int) -> int
  requires studio_profile_id_valid(profile_id) == 1
  ensures result >= 0
  decreases profile_id
=
  var compose: StudioShellCompose = studio_compose_shell_profile(1280.0, 720.0, 0, 0, profile_id)
  if studio_compose_ok(compose) != 1:
    return 1
  if studio_active_profile(compose) != profile_id:
    return 2
  var frame: PaintFrame = paint_frame_new()
  studio_paint_topbar_profile(frame, compose.layout.topbar, profile_id)
  if frame.last_rect.h != studio_profile_paint_tag_h(profile_id):
    return 3
  return 0

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 4:
    return 1
  var n0: int = studio_vertical_compose_ok(studio_profile_game())
  if n0 != 0:
    return 10 + n0
  var n1: int = studio_vertical_compose_ok(studio_profile_sim_rl())
  if n1 != 0:
    return 20 + n1
  var n2: int = studio_vertical_compose_ok(studio_profile_sim_automotive())
  if n2 != 0:
    return 30 + n2
  var n3: int = studio_vertical_compose_ok(studio_profile_sim_robotics())
  if n3 != 0:
    return 40 + n3
  var n4: int = studio_vertical_compose_ok(studio_profile_sim_additive())
  if n4 != 0:
    return 50 + n4
  var n5: int = studio_vertical_compose_ok(studio_profile_sim_scientific())
  if n5 != 0:
    return 60 + n5
  var n6: int = studio_vertical_compose_ok(studio_profile_sim_drug_design())
  if n6 != 0:
    return 70 + n6
  var rl_name: int = studio_profile_from_name("sim_rl")
  if rl_name != studio_profile_sim_rl():
    return 80
  var parsed: int = studio_parse_toml_profile_line("profile = \"sim_additive\"")
  if parsed != studio_profile_sim_additive():
    return 81
  return 0
