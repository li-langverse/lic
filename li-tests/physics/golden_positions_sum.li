# Small golden: constant checksum 3.0 (three-body mini layout semantics).

extern proc li_rt_volatile_sink_f64(v: float) -> unit
  requires true
  ensures true

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var s: float = 1.0 + 1.0 + 1.0
  if s != 3.0:
    return 1
  li_rt_volatile_sink_f64(s)
  return 0
