import llm

def main() -> int raises IO, Alloc
  requires true
  ensures result == 0
  decreases 0
=
  var hdr: LlmSafetensorsHeader = llm_safetensors_load_tensors_scaffold("fixtures/model.safetensors")
  if hdr.parsed_ok != 1:
    return 1
  if hdr.tensors_loaded != 2:
    return 2
  var w: LlmModelWeights = llm_load_weights("fixtures/model.safetensors")
  if w.tensors_loaded != 2:
    return 3
  return 0
