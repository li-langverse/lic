# Forces ArrayMatMul2DF64 loop codegen (m,k,n > kUnrollMax=24 in emit.cpp).
# Runtime init + sink so LLVM cannot constant-fold or DCE the `@`.

extern proc li_rt_volatile_sink_f64(v: float) -> unit
  requires true
  ensures true

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var A: array[25, array[25, float]]
  var B: array[25, array[25, float]]
  var x: float = 1.01
  var i: int = 0
  while i < 25
    var j: int = 0
    while j < 25
      A[i][j] = x
      B[i][j] = x + 0.1
      x = x + 0.001
      j = j + 1
    i = i + 1
  var C: array[25, array[25, float]] = A @ B
  li_rt_volatile_sink_f64(C[12][12])
  return 0
