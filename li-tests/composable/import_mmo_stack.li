# PH-MMO-1 — mmo + sim + store + world stack gate.

import mmo
import sim
import store.realtime
import world

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if sim_profile_mmo() != 8:
    return 1
  if store_realtime_smoke() != 0:
    return 2
  if world_realm_smoke() != 0:
    return 3
  return mmo_matchmaking_smoke()
