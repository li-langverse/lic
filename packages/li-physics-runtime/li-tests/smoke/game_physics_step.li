import sim
import physics.runtime

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var out0: GamePhysicsStepOutcome = game_physics_step_hook(0.016, 0)
  if out0.status != sim_status_ok():
    return 1
  if out0.physics_step_count < 4:
    return 2
  if out0.body_pz > 2.0:
    return 3
  if out0.scene_sync_count != 2:
    return 4
  if out0.position_checksum < 1:
    return 5
  return 0
