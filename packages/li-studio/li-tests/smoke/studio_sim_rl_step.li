import ml_rl
import sim
import studio

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var rl_cfg: StudioProjectConfig = studio_project_config_new(studio_profile_sim_rl())
  var rl_sess: SimSessionStub = sim_session_stub_default()
  studio_apply_profile_to_sim(rl_cfg, rl_sess)
  var graph: JobGraphStub = job_graph_stub_default()
  if ml_rl_job_graph_collect(rl_sess, 0.02, graph) != sim_status_ok():
    return 10
  if graph.samples_collected < 4:
    return 11
  if studio_sim_rl_step_hook(rl_sess, 0.02) != sim_status_ok():
    return 12
  var expected: int = ml_rl_async_env_count() + ml_rl_async_env_count()
  if rl_sess.tick != expected:
    return 13
  return 0
