# Small golden: constant checksum 3.0 (three-body mini layout semantics).

extern proc li_rt_volatile_sink_f64(v: float) raises IO -> unit
  requires true
  ensures true

def physics_golden_position_sum() -> float
  requires true
  ensures result == 3.0
  decreases 0
=
  return 1.0 + 1.0 + 1.0

def main() raises IO -> int
  requires true
  ensures result == 0
  decreases 0
=
  li_rt_volatile_sink_f64(physics_golden_position_sum())
  return 0
