# P-linalg gap specimen: 2×2 float matmul via IKJ loops — no static witness (cf. dot4_int_loop).
def mat2_loop_entry00(A: array[2, array[2, float]], B: array[2, array[2, float]]) -> float
  requires true
  ensures result == A[0][0] * B[0][0] + A[0][1] * B[1][0]
  decreases 8
=
  var C: array[2, array[2, float]]
  var i: int = 0
  while i < 2
    var j0: int = 0
    while j0 < 2
      C[i][j0] = 0.0
      j0 = j0 + 1
    i = i + 1
  i = 0
  while i < 2
    var k: int = 0
    while k < 2
      var j1: int = 0
      while j1 < 2
        C[i][j1] = C[i][j1] + A[i][k] * B[k][j1]
        j1 = j1 + 1
      k = k + 1
    i = i + 1
  return C[0][0]

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var A: array[2, array[2, float]]
  var B: array[2, array[2, float]]
  A[0][0] = 1.0
  A[0][1] = 0.0
  A[1][0] = 0.0
  A[1][1] = 0.0
  B[0][0] = 1.0
  B[0][1] = 0.0
  B[1][0] = 0.0
  B[1][1] = 0.0
  var e: float = mat2_loop_entry00(A, B)
  return 0
