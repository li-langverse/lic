# N-LM-SQRT-BOUND: mirrors contracts_verify sqrt_open_bound (WP1 numerics specimen).
extern proc li_rt_sqrt(x: float) -> float

def sqrt_open(x: float) raises IO -> float
  requires x >= 0.0
  ensures abs(result * result - x) < 1e-12
  decreases 0
=
  return li_rt_sqrt(x)

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var y: float = sqrt_open(4.0)
  return 0