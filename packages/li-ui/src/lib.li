def studio_palette_action_for_slot(slot: int) -> int
  requires slot >= 1
  requires slot <= studio_palette_result_count_stub()
  ensures result >= studio_palette_action_focus_inspector()
  ensures result <= studio_palette_action_focus_agent()
  decreases slot
=
  if slot == 1:
    return studio_palette_action_focus_inspector()
  if slot == 2:
    return studio_palette_action_focus_timeline()
  return studio_palette_action_focus_agent()

type StudioCommandPaletteCompose = object
  public is_open: int
  public backdrop_rect: Rect
  public panel_rect: Rect
  public search_rect: Rect
  public result_count: int
  public selected_slot: int
  public last_action_id: int

def studio_palette_backdrop_rect_at(w: float, h: float) -> Rect
  requires w > 0.0
  requires h > 0.0
  ensures result.w == w
  ensures result.h == h
  decreases 0
=
  return rect_make(0.0, 0.0, w, h)

def studio_palette_panel_rect_at(w: float, h: float) -> Rect
  requires w > 0.0
  requires h > 0.0
  ensures result.w == studio_palette_panel_width_px()
  ensures result.h == studio_palette_panel_height_px()
  decreases 0
=
  var pw: float = studio_palette_panel_width_px()
  var ph: float = studio_palette_panel_height_px()
  var x: float = (w - pw) / 2.0
  var y: float = (h - ph) / 2.0
  if x < 0.0:
    x = 0.0
  if y < 0.0:
    y = 0.0
  return rect_make(x, y, pw, ph)

def studio_palette_search_rect_at(panel: Rect) -> Rect
  requires panel.w >= studio_palette_panel_width_px()
  requires panel.h >= studio_palette_search_bar_height_px()
  ensures result.w == panel.w - 32.0
  ensures result.h == studio_palette_search_bar_height_px()
  decreases 0
=
  var pad: float = 16.0
  return rect_make(panel.x + pad, panel.y + pad, panel.w - (pad * 2.0), studio_palette_search_bar_height_px())

def studio_compose_palette(w: float, h: float, is_open: int) -> StudioCommandPaletteCompose
  requires w > 0.0
  requires h > 0.0
  requires is_open >= studio_palette_closed_flag()
  requires is_open <= studio_palette_open_flag()
  ensures result.is_open == is_open
  ensures result.result_count >= 0
  decreases is_open
=
  var out: StudioCommandPaletteCompose
  out.is_open = is_open
  out.backdrop_rect = rect_make(0.0, 0.0, 0.0, 0.0)
  out.panel_rect = rect_make(0.0, 0.0, 0.0, 0.0)
  out.search_rect = rect_make(0.0, 0.0, 0.0, 0.0)
  out.result_count = 0
  out.selected_slot = 0
  out.last_action_id = studio_palette_action_none()
  if is_open == studio_palette_open_flag():
    var backdrop_w: float = w
    var backdrop_h: float = h
    out.backdrop_rect = studio_palette_backdrop_rect_at(backdrop_w, backdrop_h)
    var panel_w: float = w
    var panel_h: float = h
    out.panel_rect = studio_palette_panel_rect_at(panel_w, panel_h)
    var search_pad: float = 16.0
    out.search_rect = rect_make(out.panel_rect.x + search_pad, out.panel_rect.y + search_pad, out.panel_rect.w - (search_pad * 2.0), studio_palette_search_bar_height_px())
    out.result_count = studio_palette_result_count_stub()
  return out

def studio_palette_open(palette: var StudioCommandPaletteCompose, w: float, h: float) -> unit
  requires w > 0.0
  requires h > 0.0
  requires palette.is_open == studio_palette_closed_flag()
  ensures palette.is_open == studio_palette_open_flag()
  ensures palette.result_count == studio_palette_result_count_stub()
  ensures palette.backdrop_rect.w == w
  decreases 0
=
  var open_w: float = w
  var open_h: float = h
  var opened: StudioCommandPaletteCompose = studio_compose_palette(open_w, open_h, studio_palette_open_flag())
  palette.is_open = opened.is_open
  palette.backdrop_rect = opened.backdrop_rect
  palette.panel_rect = opened.panel_rect
  palette.search_rect = opened.search_rect
  palette.result_count = opened.result_count
  palette.selected_slot = 0
  palette.last_action_id = studio_palette_action_none()

def studio_palette_close(palette: var StudioCommandPaletteCompose) -> unit
  requires palette.is_open == studio_palette_open_flag()
  ensures palette.is_open == studio_palette_closed_flag()
  ensures palette.result_count == 0
  decreases 0
=
  palette.is_open = studio_palette_closed_flag()
  palette.result_count = 0
  palette.backdrop_rect = rect_make(0.0, 0.0, 0.0, 0.0)
  palette.panel_rect = rect_make(0.0, 0.0, 0.0, 0.0)
  palette.search_rect = rect_make(0.0, 0.0, 0.0, 0.0)
  palette.selected_slot = 0

def studio_palette_exec_slot(palette: var StudioCommandPaletteCompose, slot: int) -> int
  requires slot >= 1
  requires slot <= studio_palette_result_count_stub()
  requires palette.is_open == studio_palette_open_flag()
  ensures palette.is_open == studio_palette_closed_flag()
  ensures palette.last_action_id == studio_palette_action_for_slot(slot)
  ensures result == palette.last_action_id
  decreases slot
=
  palette.selected_slot = slot
  palette.last_action_id = studio_palette_action_for_slot(slot)
  studio_palette_close(palette)
  return palette.last_action_id

def studio_palette_toggle(palette: var StudioCommandPaletteCompose, w: float, h: float) -> unit
  requires w > 0.0
  requires h > 0.0
  requires palette.is_open >= studio_palette_closed_flag()
  requires palette.is_open <= studio_palette_open_flag()
  ensures palette.is_open >= studio_palette_closed_flag()
  ensures palette.is_open <= studio_palette_open_flag()
  decreases palette.is_open
=
  if palette.is_open == studio_palette_open_flag():
    studio_palette_close(palette)
    return
  var toggle_w: float = w
  var toggle_h: float = h
  studio_palette_open(palette, toggle_w, toggle_h)

def studio_palette_ok(palette: StudioCommandPaletteCompose) -> int
  requires palette.is_open >= studio_palette_closed_flag()
  requires palette.is_open <= studio_palette_open_flag()
  ensures result >= 0
  ensures result <= 1
  decreases palette.is_open
=
  if palette.is_open == studio_palette_closed_flag():
    if palette.result_count != 0:
      return 0
    if palette.search_rect.w != 0.0:
      return 0
    return 1
  if palette.backdrop_rect.w <= 0.0:
    return 0
  if palette.panel_rect.w != studio_palette_panel_width_px():
    return 0
  if palette.search_rect.h != studio_palette_search_bar_height_px():
    return 0
  if palette.result_count != studio_palette_result_count_stub():
    return 0
  return 1

def studio_paint_palette_cmds(is_open: int) -> int
  requires is_open >= studio_palette_closed_flag()
  requires is_open <= studio_palette_open_flag()
  ensures result >= 0
  ensures result <= 3
  decreases is_open
=
  if is_open == studio_palette_closed_flag():
    return 0
  return 3

def paint_studio_palette(frame: var PaintFrame, palette: StudioCommandPaletteCompose) -> unit
  requires frame.cmd_count >= 0
  requires palette.is_open >= studio_palette_closed_flag()
  requires palette.is_open <= studio_palette_open_flag()
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_palette_cmds(palette.is_open)
  decreases palette.is_open
=
  if palette.is_open == studio_palette_closed_flag():
    return
  frame.cmd_count = frame.cmd_count + 1
  frame.last_kind = paint_op_fill_rect()
  frame.last_rect = palette.backdrop_rect
  frame.last_color = color_rgb(0.051, 0.067, 0.090, 0.72)
  frame.cmd_count = frame.cmd_count + 1
  frame.last_kind = paint_op_fill_rect()
  frame.last_rect = palette.panel_rect
  frame.last_color = studio_color_bg_elevated()
  frame.cmd_count = frame.cmd_count + 1
  frame.last_kind = paint_op_stroke_rect()
  frame.last_rect = palette.search_rect
  frame.last_color = studio_color_accent_cyan()

def paint_studio_palette_count(is_open: int) -> int
  requires is_open >= studio_palette_closed_flag()
  requires is_open <= studio_palette_open_flag()
  ensures result == studio_paint_palette_cmds(is_open)
  decreases is_open
=
  return studio_paint_palette_cmds(is_open)

