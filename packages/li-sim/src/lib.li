  requires true
  ensures result == 1
  decreases 0
=
  return 1

def output_detail_debug() -> int
  requires true
  ensures result == 2
  decreases 0
=
  return 2

def output_detail_repro() -> int
  requires true
  ensures result == 3
  decreases 0
=
  return 3

def summary_format_json() -> int
  requires true
  ensures result == 0
  decreases 0
=
  return 0

def summary_format_json_min() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def summary_format_yaml() -> int
  requires true
  ensures result == 2
  decreases 0
=
