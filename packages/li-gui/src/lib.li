type DockTab = object
  public tab_id: int
  public layout_role: int
  public zone_id: int

def gui_dock_tab_new(tab_id: int, layout_role: int, zone_id: int) -> DockTab
  requires tab_id >= 0
  requires tab_id < 5
  requires layout_role >= 0
  requires layout_role < 5
  requires zone_id >= 0
  requires zone_id < 4
  ensures result.tab_id == tab_id
  ensures result.layout_role == layout_role
  ensures result.zone_id == zone_id
  decreases tab_id
=
  var t: DockTab
  t.tab_id = tab_id
  t.layout_role = layout_role
  t.zone_id = zone_id
  return t

# Bottom-right ML stage panel — matches `adaptive_panel_rect_ml()` on `import ui`.
def gui_dock_rect_ml() -> GuiRect
  requires true
  ensures result.w == 283.0
  ensures result.h == 360.0
  decreases 0
=
  return gui_rect_at(997.0, 360.0, 283.0, 360.0)

def studio_shell_dock_zone_rect(shell: StudioShell, zone_id: int) -> GuiRect
  requires zone_id >= 0
  requires zone_id < 4
  ensures result.w >= 0.0
  ensures result.h >= 0.0
  decreases zone_id
=
  if zone_id == gui_dock_zone_sidebar():
    return shell.sidebar
  if zone_id == gui_dock_zone_main():
    return shell.main
  if zone_id == gui_dock_zone_inspector():
    return shell.inspector
  return gui_dock_rect_ml()

