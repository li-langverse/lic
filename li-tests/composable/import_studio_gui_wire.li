import studio
import gui
import ui

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 1:
    return 1
  var entry: int = studio_wire_smoke_entry()
  if entry != 0:
    return 2
  var shell: StudioShell = studio_shell_layout_hd()
  var chrome: StudioChrome = studio_chrome_hd()
  if shell.sidebar.w != chrome.layout.sidebar.w:
    return 3
  if shell.main.w != chrome.layout.main.w:
    return 4
  if shell.inspector.w != chrome.layout.inspector.w:
    return 5
  var layout: AdaptiveLayout = adaptive_layout_hd()
  if shell.sidebar.w != layout.sidebar.w:
    return 6
  var region: Rect = rect_at_f(0.0, 0.0, 1280.0, 32.0)
  var toolbar: StudioChromeHook = studio_chrome_hook_new(studio_chrome_hook_toolbar(), region, 1)
  studio_chrome_attach_hook(chrome, toolbar)
  if chrome.hook_count != 1:
    return 7
  var doc: UiDocument = ui_document_new()
  var panel: GuiRect = shell.inspector
  var stroke: PaintCmd = paint_rect(0, panel)
  ui_document_attach_paint(doc, stroke)
  if doc.paint_count != 1:
    return 8
  return 0
