import studio.ai

def main() -> int raises IO
  requires true
  ensures result == 0
  decreases 0
=
  if li_studio_ai_version() != 1:
    return 1
  var bg: StudioAiToolResult = studio_ai_mcp_dispatch("set_viewport_background", 1)
  if bg.success != 1:
    return 2
  var tier: StudioAiToolResult = studio_ai_mcp_dispatch("set_particle_display", 1)
  if tier.success != 1:
    return 3
  var bad: StudioAiToolResult = studio_ai_mcp_dispatch("not_a_tool", 0)
  if bad.success != 0:
    return 4
  return 0
