import llm

def main() -> int raises IO, Alloc
  requires true
  ensures result == 0
  decreases 0
=
  var w: LlmModelWeights = llm_load_weights("fixtures/model.safetensors")
  if llm_model_weights_valid(w) != 1:
    return 1
  var tok: LlmTokenIds = llm_tokenize("ab", "fixtures/vocab.json")
  var cache: LlmKVCache
  cache.seq_len = 0
  var logits: LlmLogits = llm_forward(tok, w, cache)
  if logits.vocab_size != 256:
    return 2
  var expect: int = 104 + 99
  if logits.top_id != expect:
    return 3
  return 0
