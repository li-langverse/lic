# Agent task state (UX-06): idle / running / blocked / failed / done
def studio_agent_task_idle() -> int
  requires true
  ensures result == 0
  decreases 0
=
  return 0

def studio_agent_task_running() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def studio_agent_task_blocked() -> int
  requires true
  ensures result == 2
  decreases 0
=
  return 2

def studio_agent_task_failed() -> int
  requires true
  ensures result == 3
  decreases 0
=
  return 3

def studio_agent_task_done() -> int
  requires true
  ensures result == 4
  decreases 0
=
  return 4

