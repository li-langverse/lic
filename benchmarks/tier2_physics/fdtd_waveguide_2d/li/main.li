extern proc li_rt_volatile_sink_f64(v: float) -> unit
  requires true
  ensures true

extern proc li_fdtd_waveguide_kernel()
  requires true
  ensures true

extern proc li_fdtd_waveguide_checksum() -> float
  requires true
  ensures true

def main() raises IO -> int
  requires true
  ensures result == 0
  decreases 0
=
  li_fdtd_waveguide_kernel()
  li_rt_volatile_sink_f64(li_fdtd_waveguide_checksum())
  return 0
