import ui

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_ui_version() < 2:
    return 1
  var layout: StudioShellLayout = layout_studio_shell_adaptive(1280.0, 720.0)
  if layout.topbar.h != studio_topbar_height_px():
    return 2
  var frame: PaintFrame = paint_frame_new()
  paint_studio_shell_chrome(frame, layout)
  if frame.cmd_count < 6:
    return 3
  return 0
