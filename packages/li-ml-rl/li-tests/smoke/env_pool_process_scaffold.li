import ml_rl
import sim

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if sim_rl_env_worker_mode_process_scaffold() != 2:
    return 1
  var sess: SimSessionStub = sim_session_stub_default()
  sim_session_apply_studio_profile(2, sess)
  if ml_rl_env_pool_process_scaffold_collect(sess, 0.02) != sim_status_ok():
    return 2
  if sess.env_pool_steps_emitted < 4:
    return 3
  return 0
