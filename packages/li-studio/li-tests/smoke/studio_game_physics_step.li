import sim
import physics.runtime
import studio

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var out0: GamePhysicsStepOutcome = game_physics_step_hook(0.016, 0)
  if out0.status != sim_status_ok():
    return 1
  if out0.scene_sync_count != 2:
    return 2
  var snap0: WorldSnapshot = studio_game_world_snapshot_from_physics(0, out0.scene_sync_count, out0.position_checksum)
  if world_snapshot_valid(snap0) != 1:
    return 3
  if studio_game_world_checkpoint_fields(0, out0.scene_sync_count, out0.position_checksum) != 1:
    return 4
  var cfg: StudioProjectConfig = studio_project_config_new(studio_profile_game())
  var sess: SimSessionStub = sim_session_stub_default()
  if studio_sim_step_hook(cfg, sess, 0.016) != sim_status_ok():
    return 5
  if sess.tick != 1:
    return 6
  return 0
