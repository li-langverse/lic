# Copy to ../.env.github.backup (sibling of li/, lip/, lit/) — chmod 600, never commit.
#
# Fine-grained PAT: read li-langverse/* ; full org access on li-langverse-backup only.

BACKUP_GH_TOKEN=github_pat_REPLACE_ME
BACKUP_OWNER=li-langverse-backup
LIVE_ORG=li-langverse
BACKUP_ROOT=/Users/julian/Documents/li-langverse-backup
BACKUP_PUSH=1
