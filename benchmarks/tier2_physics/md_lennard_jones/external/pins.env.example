# Copy to pins.env (gitignored) when running real LAMMPS/GROMACS oracles locally.
# Pins must match benchmarks/competitive/md_oracle.toml.

export LAMMPS_PINNED_VERSION=2024.06.27
export LAMMPS_PINNED_TAG=stable_22Jun2024
export GROMACS_PINNED_VERSION=2024.2
export GROMACS_PINNED_TAG=v2024.2

# Optional: enable real driver attempts (B1+). Stub CI leaves these unset.
# export LI_MD_ORACLE_LAMMPS=1
# export LI_MD_ORACLE_GROMACS=1
# export LAMMPS_BIN=/path/to/lammps
