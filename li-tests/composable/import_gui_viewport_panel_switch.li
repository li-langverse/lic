import gui

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_gui_version() < 1:
    return 1
  if li_std_ui_studio_composables_version() < 2:
    return 2
  var layout: StudioShellLayout = layout_studio_shell_adaptive(1280.0, 720.0)
  var vp: ViewportRegion = gui_viewport_region_from_layout(layout)
  if vp.rect.h <= 0.0:
    return 3
  var frame: PaintFrame = gui_studio_shell_frame(1280.0, 720.0)
  if frame.last_kind != paint_op_viewport_grid():
    return 4
  var timing: PanelSwitchTiming = gui_panel_switch_timing(studio_region_viewport(), studio_region_inspector(), 80.0)
  if gui_panel_switch_within_budget(timing) != 1:
    return 5
  return 0
