import studio.ai

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_studio_ai_version() != 1:
    return 1
  var run: StudioAgentRun = studio_ai_run_agent_pipeline(studio_agent_context_world())
  if run.used_html_mock != 0:
    return 2
  if run.task_state != studio_agent_task_done():
    return 3
  if studio_agent_run_complete_ok(run) != 1:
    return 4
  return 0
