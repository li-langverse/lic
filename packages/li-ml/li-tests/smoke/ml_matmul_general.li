import ml

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if ml_version() != 2:
    return 1
  var a: array[8, array[8, float]]
  var b: array[8, array[8, float]]
  var c: array[8, array[8, float]]
  a[0][0] = 1.0
  a[0][1] = 0.0
  a[1][0] = 0.0
  a[1][1] = 1.0
  b[0][0] = 1.0
  b[0][1] = 2.0
  b[1][0] = 3.0
  b[1][1] = 4.0
  if ml_matmul_cpu_nested(2, 2, 2, a, b, c) != 1:
    return 2
  if c[0][0] < 0.9 or c[0][0] > 1.1:
    return 3
  if c[1][1] < 3.9 or c[1][1] > 4.1:
    return 4
  return 0