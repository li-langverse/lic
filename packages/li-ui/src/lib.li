# UX-04 command palette — fuzzy filter + open/filter latency hooks (studio-ux-16).

def studio_palette_open_flag() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def studio_palette_closed_flag() -> int
  requires true
  ensures result == 0
  decreases 0
=
  return 0

def studio_palette_panel_width_px() -> float
  requires true
  ensures result == 560.0
  decreases 0
=
  return 560.0

def studio_palette_panel_height_px() -> float
  requires true
  ensures result == 360.0
  decreases 0
=
  return 360.0

def studio_palette_search_bar_height_px() -> float
  requires true
  ensures result == 44.0
  decreases 0
=
  return 44.0

def studio_palette_cmd_catalog_count() -> int
  requires true
  ensures result == 6
  decreases 0
=
  return 6

def studio_palette_cmd_keyword(cmd_id: int) -> int
  requires cmd_id >= 1
  requires cmd_id <= studio_palette_cmd_catalog_count()
  ensures result >= 1101
  ensures result <= 1606
  decreases cmd_id
=
  if cmd_id == 1:
    return 1101
  if cmd_id == 2:
    return 1202
  if cmd_id == 3:
    return 1303
  if cmd_id == 4:
    return 1404
  if cmd_id == 5:
    return 1505
  return 1606

def studio_palette_action_for_cmd(cmd_id: int) -> int
  requires cmd_id >= 1
  requires cmd_id <= studio_palette_cmd_catalog_count()
  ensures result >= 1
  ensures result <= 3
  decreases cmd_id
=
  if cmd_id == 1:
    return 1
  if cmd_id == 2:
    return 2
  if cmd_id == 3:
    return 3
  if cmd_id == 4:
    return 2
  if cmd_id == 5:
    return 3
  return 1

def studio_palette_fuzzy_match(cmd_keyword: int, query_code: int) -> int
  requires cmd_keyword >= 1101
  requires cmd_keyword <= 1606
  requires query_code >= 0
  ensures result >= 0
  ensures result <= 1
  decreases query_code
=
  if query_code == 0:
    return 1
  if cmd_keyword == query_code:
    return 1
  var bucket: int = query_code
  var kw_bucket: int = cmd_keyword / 100
  if kw_bucket == bucket:
    return 1
  var q_tens: int = (query_code / 10) % 10
  var k_tens: int = (cmd_keyword / 10) % 10
  if q_tens > 0:
    if k_tens == q_tens:
      return 1
  return 0

def studio_palette_filter_count(query_code: int) -> int
  requires query_code >= 0
  ensures result >= 0
  ensures result <= studio_palette_cmd_catalog_count()
  decreases query_code
=
  var n: int = 0
  var c1: int = studio_palette_fuzzy_match(studio_palette_cmd_keyword(1), query_code)
  if c1 == 1:
    n = n + 1
  var c2: int = studio_palette_fuzzy_match(studio_palette_cmd_keyword(2), query_code)
  if c2 == 1:
    n = n + 1
  var c3: int = studio_palette_fuzzy_match(studio_palette_cmd_keyword(3), query_code)
  if c3 == 1:
    n = n + 1
  var c4: int = studio_palette_fuzzy_match(studio_palette_cmd_keyword(4), query_code)
  if c4 == 1:
    n = n + 1
  var c5: int = studio_palette_fuzzy_match(studio_palette_cmd_keyword(5), query_code)
  if c5 == 1:
    n = n + 1
  var c6: int = studio_palette_fuzzy_match(studio_palette_cmd_keyword(6), query_code)
  if c6 == 1:
    n = n + 1
  return n

