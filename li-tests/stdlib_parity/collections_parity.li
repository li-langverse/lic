def counter_get(counts: dict[str, int], key: str) raises Alloc -> int
  requires true
  ensures result == 0
  decreases 0
=
  return 0

def main() raises Alloc -> int
  requires true
  ensures result == 0
  decreases 0
=
  var counts: dict[str, int]
  return counter_get(counts, "k")
