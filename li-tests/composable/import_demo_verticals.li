import physics.custom
import sim.automotive
import sim.robotics
import sim.drug_design
import bioeng
import mmo

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if demo_rocket_smoke() != 0:
    return 1
  if demo_racing_smoke() != 0:
    return 2
  if demo_robot_smoke() != 0:
    return 3
  if demo_drug_smoke() != 0:
    return 4
  if demo_bioeng_smoke() != 0:
    return 5
  return demo_mmo_smoke()
