import lig
def main() raises IO -> int
  requires true
  ensures result == 0
  decreases 0
=
  if lig_kernel_run_auto(lig_kernel_matmul_f32()) != -1:
    return 1
  if lig_kernel_run(lig_kernel_matmul_f32(), lig_backend_webgpu()) != 0:
    return 2
  if lig_validity_gate_pass(0.999) != 1:
    return 3
  return 0
