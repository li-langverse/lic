import physics.rigid

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var b: RigidBody
  b.px = 0.0
  b.py = 0.0
  b.pz = 1.0
  b.vx = 0.0
  b.vy = 0.0
  b.vz = 0.0
  b.inv_mass = 1.0
  b.radius = 0.5
  rigid_integrate_semi_implicit(b, 0.0, 0.0, -9.81, 1.0 / 60.0)
  if b.pz >= 1.0:
    return 1
  return 0
