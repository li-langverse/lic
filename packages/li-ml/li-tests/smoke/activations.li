import ml

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if ml_relu_scalar(-1.0) != 0.0:
    return 1
  if ml_relu_scalar(2.5) != 2.5:
    return 2
  if ml_sigmoid_scalar(0.0) <= 0.0:
    return 3
  if ml_sigmoid_scalar(0.0) >= 1.0:
    return 4
  var logits: array[4, float]
  logits[0] = 1.0
  logits[1] = 2.0
  logits[2] = 0.5
  logits[3] = -1.0
  var probs: array[4, float] = ml_softmax4(logits)
  if probs[0] <= 0.0:
    return 5
  if probs[1] <= 0.0:
    return 6
  return 0
