import world

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if world_format_version() != 1:
    return 1
  var snap: WorldSnapshot = world_snapshot_default()
  snap.name = "arena"
  snap.tick = 42
  snap.entity_count = 7
  if world_roundtrip_ok(snap) != 1:
    return 2
  var line: str = world_serialize(snap)
  var parsed: WorldSnapshot = world_parse_line(line)
  if world_snapshot_fields_match(snap, parsed) != 1:
    return 3
  var buf: str = world_save_to_buffer(snap)
  var loaded: WorldSnapshot = world_load_from_buffer(buf)
  if world_snapshot_fields_match(snap, loaded) != 1:
    return 4
  return 0
