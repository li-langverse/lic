# Render package smoke: @cpu host paint path + @gpu loop for particle tier stub.
@cpu
def render_host_paint_gate() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if render_host_paint_gate() != 1:
    return 1
  var n: int = 0
  @gpu
  for i in 0..<2
    n = n + 1
  if n != 2:
    return 2
  return 0
