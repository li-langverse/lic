# Mini three-body distance smoke (initialized arrays; compile + verify).

proc dist2(px: array[3, float], py: array[3, float], i: int) -> float
  requires i >= 0
  requires i < 3
  decreases i
=
  var dx: float = px[i] - px[0]
  var dy: float = py[i] - py[0]
  return dx * dx + dy * dy

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var px: array[3, float]
  var py: array[3, float]
  px[0] = 0.0
  px[1] = 1.0
  px[2] = 0.0
  py[0] = 1.0
  py[1] = 0.0
  py[2] = 0.0
  var r2: float = dist2(px, py, 1)
  if r2 < 0.0
    return 1
  return 0
