import sim.scientific

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if sim_scientific_tick_stub(0) != 1:
    return 1
  if sim_scientific_tick_stub(2) != 1:
    return 2
  if sim_scientific_tick_stub(3) != 1:
    return 3
  var d_md: int = 0
  var d_heat: int = 2
  var md: SimRunResult = run_simulation(vertical_md_lennard_jones(), d_md)
  if md.checksum <= 0.0:
    return 4
  var heat: SimRunResult = run_simulation(vertical_pde_heat_2d(), d_heat)
  if heat.checksum <= 0.0:
    return 5
  return 0
