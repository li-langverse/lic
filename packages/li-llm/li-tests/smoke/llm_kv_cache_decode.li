import llm

def main() -> int raises IO, Alloc
  requires true
  ensures result == 0
  decreases 0
=
  var w: LlmModelWeights = llm_load_weights("fixtures/model.safetensors")
  var tok: LlmTokenIds = llm_tokenize("ab", "fixtures/vocab.json")
  var cache: LlmKVCache
  cache.seq_len = tok.count
  cache.last_top_id = 0
  cache.decode_steps = 0
  var logits0: LlmLogits = llm_forward(tok, w, cache)
  var one: LlmTokenIds = llm_token_ids_empty()
  one.count = 1
  one.ids[0] = logits0.top_id + 1
  cache.decode_steps = 1
  var logits1: LlmLogits = llm_forward(one, w, cache)
  if cache.last_top_id != logits1.top_id:
    return 1
  if logits1.vocab_size != 256:
    return 2
  var out: str = llm_generate("ab", w, "fixtures/vocab.json", 1)
  if out == "":
    return 3
  return 0
