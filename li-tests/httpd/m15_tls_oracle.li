# M1.5 TLS auto oracle — TOML load + runtime TLS profile selftest (C).
import http

extern proc li_rt_httpd_tls_enabled() -> int
  requires true
  ensures 0 <= result
  ensures result <= 1

extern proc li_rt_httpd_tls_mode() -> int
  requires true
  ensures 0 <= result
  ensures result <= 3

extern proc li_rt_httpd_tls_le_domain_count() -> int
  requires true
  ensures 0 <= result

extern proc li_rt_httpd_tls_renew_before_days() -> int
  requires true
  ensures 0 <= result

extern proc li_rt_httpd_tls_self_signed_dev() -> int
  requires true
  ensures 0 <= result
  ensures result <= 1

extern proc li_rt_httpd_tls_selftest() -> int
  requires true
  ensures -3 <= result
  ensures result <= 0

def main() raises IO, Alloc -> int
  requires true
  ensures result == 0
  decreases 0
=
  if load_routes_from_m15_tls_le_fixture() != 0:
    return 1
  if li_rt_httpd_tls_enabled() != 1:
    return 2
  if li_rt_httpd_tls_mode() != 3:
    return 3
  if li_rt_httpd_tls_le_domain_count() < 1:
    return 4
  if li_rt_httpd_tls_renew_before_days() != 30:
    return 5
  if li_rt_httpd_tls_selftest() != 0:
    return 6
  if load_routes_from_m15_tls_dev_fixture() != 0:
    return 7
  if li_rt_httpd_tls_mode() != 2:
    return 8
  if li_rt_httpd_tls_self_signed_dev() != 0:
    return 9
  return 0
