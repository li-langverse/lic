              "content": "# Pure-Li three-body mini kernel (library-aligned, reduced steps for CI).\n\nextern proc li_rt_sqrt(x: float) -> float\n\ndef three_body_forces(\n    px: array[3, float], py: array[3, float],\n    fx: array[3, float], fy: array[3, float]) -> unit\n  requires true\n  decreases 0\n=\n  var i: int = 0\n  while i < 3\n    fx[i] = 0.0\n    fy[i] = 0.0\n    i = i + 1\n  var g: float = 1.0\n  var mass: float = 1.0\n  var soft: float = 0.000000001\n  var eps2: float = soft * soft\n  i = 0\n  while i < 3\n    var j: int = i + 1\n    while j < 3\n      var dx: float = px[j] - px[i]\n      var dy: float = py[j] - py[i]\n      var r2: float = dx * dx + dy * dy + eps2\n      var inv_r: float = 1.0 / li_rt_sqrt(r2)\n      var inv_r3: float = inv_r * inv_r * inv_r\n      var scale: float = g * mass * mass * inv_r3\n      var fxi: float = scale * dx\n      var fyi: float = scale * dy\n      fx[i] = fx[i] + fxi\n      fy[i] = fy[i] + fyi\n      fx[j] = fx[j] - fxi\n      fy[j] = fy[j] - fyi\n      j = j + 1\n    i = i + 1\n\ndef main() -> int\n  requires true\n  ensures result == 0\n  decreases 0\n=\n  var px: array[3, float]\n  var py: array[3, float]\n  var vx: array[3, float]\n  var vy: array[3, float]\n  var fx: array[3, float]\n  var fy: array[3, float]\n  px[0] = 0.0\n  py[0] = 1.0\n  px[1] = -0.8660254037844386\n  py[1] = -0.5\n  px[2] = 0.8660254037844386\n  py[2] = -0.5\n  var step: int = 0\n  while step < 1000\n    three_body_forces(px, py, fx, fy)\n    var i: int = 0\n    var dt: float = 0.01\n    while i < 3\n      vx[i] = vx[i] + fx[i] * dt\n      vy[i] = vy[i] + fy[i] * dt\n      px[i] = px[i] + vx[i] * dt\n      py[i] = py[i] + vy[i] * dt\n      i = i + 1\n    step = step + 1\n  return 0\n",
