# P-linalg: 2×2 float matmul entry via CallProc on nested arrays (G-math 2D CallProc).
def mat2_entry00(A: array[2, array[2, float]], B: array[2, array[2, float]]) -> float
  requires true
  ensures result == A[0][0] * B[0][0] + A[0][1] * B[1][0]
  decreases 0
=
  var C: array[2, array[2, float]] = A @ B
  return A[0][0] * B[0][0] + A[0][1] * B[1][0]

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var A: array[2, array[2, float]]
  var B: array[2, array[2, float]]
  A[0][0] = 1.0
  A[0][1] = 0.0
  A[1][0] = 0.0
  A[1][1] = 1.0
  B[0][0] = 2.0
  B[0][1] = 0.0
  B[1][0] = 0.0
  B[1][1] = 3.0
  var e: float = mat2_entry00(A, B)
  return 0
