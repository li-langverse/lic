
import std.runtime.seam

extern proc li_rt_str_eq(a: str, b: str) -> int
  requires true
  ensures 0 <= result
  ensures result <= 1
  decreases 0

extern proc li_rt_path_exact(path: str, want: str) -> int
  requires true
  ensures 0 <= result
  ensures result <= 1
  decreases 0

extern proc li_rt_path_prefix(path: str, prefix: str) -> int
  requires true
  ensures 0 <= result
  ensures result <= 1
  decreases 0

extern proc li_rt_str_prefix_is_get(s: var str) -> int
  requires true
  ensures 0 <= result
  ensures result <= 1
  decreases 0

extern proc li_rt_http_parse_request_len_tag(buf: var str, max_header_block: int, max_body: int) -> int
  requires 0 < max_header_block
  requires 0 < max_body
  ensures 0 <= result
  decreases 0

def http_is_get_method_line(buf: var str) raises Alloc, IO -> int
  requires true
  ensures 0 <= result
  ensures result <= 1
  decreases 0
=
  return li_rt_str_prefix_is_get(buf)

def parse_request(buf: var str, max_header_block: int, max_body: int) raises Alloc, IO -> int
  requires 0 < max_header_block
  requires 0 < max_body
  ensures 0 <= result
  ensures result <= max_body
  decreases 0
=
  return li_rt_http_parse_request_len_tag(buf, max_header_block, max_body)

# Route ids for li-tests/httpd/fixtures/routing.toml (priority order).
# 0 = no match, 1 = get_health, 2 = post_v1_wild, 3 = get_v1_wild

def http_route_id_none() -> int
  requires true
  ensures result == 0
  decreases 0
=
  return 0

def http_route_action_static() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def http_route_action_proxy() -> int
  requires true
  ensures result == 2
  decreases 0
=
  return 2

def http_action_kind_for_route(route_id: int) -> int
  requires 0 <= route_id
  requires route_id <= 3
  ensures 0 <= result
  ensures result <= 2
  decreases route_id
=
  if route_id == 1:
    return http_route_action_static()
  if route_id == 2:
    return http_route_action_proxy()
  if route_id == 3:
    return http_route_action_proxy()
  return 0

