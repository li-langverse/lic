  requires 0 <= route_id
  requires route_id <= 64
  ensures 0 <= result
  ensures result <= 2
  decreases route_id

extern proc li_rt_httpd_load_routing_fixture() -> int
  requires true
  ensures -1 <= result
  ensures result <= 0
  decreases 0

def load_routes_from_toml(path: str) raises IO, Alloc -> int
  requires true
  ensures -1 <= result
  ensures result <= 0
  decreases 0
=
  return li_rt_httpd_load_config(path)

