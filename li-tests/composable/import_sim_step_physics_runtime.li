# Author API: sim_step_physics lives in physics.runtime (do not import sim in this file).
import physics.runtime

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if sim_step_physics(0, 2, 16) != 1:
    return 1
  if sim_step_physics(1, 2, 16) != 2:
    return 2
  return physics_runtime_smoke()
