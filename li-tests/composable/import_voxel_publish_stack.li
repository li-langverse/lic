import voxel
import studio
import sim.additive
import render

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if sim_profile_additive() != voxel_mode_additive():
    return 1
  if voxel_additive_smoke() != 0:
    return 2
  if studio_publish_smoke() != 0:
    return 3
  return render_studio_viewport_smoke()
