              "content": "# Pure-Li matmul (256×256).\n\nextern proc li_rt_volatile_sink_f64(v: float) raises IO -> unit\n  requires true\n  ensures true\n\ndef mm_lut_a(rem: int) -> float\n  requires rem >= 0\n  ensures result >= 0.0\n  decreases rem\n=\n  if rem == 0:\n    return 0.0\n  if rem == 1:\n    return 0.01\n  if rem == 2:\n    return 0.02\n  if rem == 3:\n    return 0.03\n  if rem == 4:\n    return 0.04\n  if rem == 5:\n    return 0.05\n  if rem == 6:\n    return 0.06\n  if rem == 7:\n    return 0.07\n  if rem == 8:\n    return 0.08\n  if rem == 9:\n    return 0.09\n  if rem == 10:\n    return 0.1\n  if rem == 11:\n    return 0.11\n  if rem == 12:\n    return 0.12\n  if rem == 13:\n    return 0.13\n  if rem == 14:\n    return 0.14\n  if rem == 15:\n    return 0.15\n  if rem == 16:\n    return 0.16\n  return 0.0\n\ndef mm_lut_b(rem: int) -> float\n  requires rem >= 0\n  ensures result >= 0.0\n  decreases rem\n=\n  if rem == 0:\n    return 0.0\n  if rem == 1:\n    return 0.02\n  if rem == 2:\n    return 0.04\n  if rem == 3:\n    return 0.06\n  if rem == 4:\n    return 0.08\n  if rem == 5:\n    return 0.1\n  if rem == 6:\n    return 0.12\n  if rem == 7:\n    return 0.14\n  if rem == 8:\n    return 0.16\n  if rem == 9:\n    return 0.18\n  if rem == 10:\n    return 0.2\n  if rem == 11:\n    return 0.22\n  if rem == 12:\n    return 0.24\n  return 0.0\n\ndef main() raises IO -> int\n  requires true\n  ensures result == 0\n  decreases 0\n=\n  var A: array[256, array[256, float]]\n  var B: array[256, array[256, float]]\n  var C: array[256, array[256, float]]\n  var i: int = 0\n  while i < 256\n    var j_init: int = 0\n    while j_init < 256\n      A[i][j_init] = mm_lut_a((i + j_init) % 17)\n      B[i][j_init] = mm_lut_b((i * 3 + j_init) % 13)\n      C[i][j_init] = 0.0\n      j_init = j_init + 1\n    i = i + 1\n  var i_mm: int = 0\n  while i_mm < 256\n    var k: int = 0\n    while k < 256\n      var aik: float = A[i_mm][k]\n      var j_mm: int = 0\n      while j_mm < 256\n        C[i_mm][j_mm] = C[i_mm][j_mm] + aik * B[k][j_mm]\n        j_mm = j_mm + 1\n      k = k + 1\n    i_mm = i_mm + 1\n  var acc: float = 0.0\n  var i_sum: int = 0\n  while i_sum < 256\n    var j_sum: int = 0\n    while j_sum < 256\n      acc = acc + C[i_sum][j_sum]\n      j_sum = j_sum + 1\n    i_sum = i_sum + 1\n  li_rt_volatile_sink_f64(acc)\n  return 0\n",
