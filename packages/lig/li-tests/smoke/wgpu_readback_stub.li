import lig

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_lig_present_version() < 2:
    return 1
  if lig_native_pixel_source_wgpu_readback() != 3:
    return 2
  var swap: LigSwapchain = lig_present_swapchain_create(1280.0, 720.0)
  if lig_present_wgpu_readback_rgba8(swap) != 0:
    return 0
  if lig_present_host_native_pixel_source_flag() == lig_native_pixel_source_wgpu_readback():
    return 3
  return 0
