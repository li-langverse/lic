type Wallet = object
  public balance: int

def Wallet_take(self: var Wallet, amount: int) -> unit
  requires self.balance >= amount
  requires amount >= 0
  ensures true
  decreases 0
=
  self.balance = self.balance - amount

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var w: Wallet
  w.balance = 5
  w.take(10)
  return 0
