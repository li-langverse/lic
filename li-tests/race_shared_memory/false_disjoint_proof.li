# EXPLOIT: requires claims disjoint tiles but body writes shared cell.
# MUST NOT compile — expected: Lean / VC rejects false proof.

def false_proof(grid: var array[8, array[8, f64]]) -> unit
  requires true
  ensures true
  decreases 0
=
  parallel for i in 0..<8
    requires disjoint_row(i, grid)
    decreases 8 - i
  =
    grid[0][0] = grid[0][0] + 1.0
