import studio
import studio.ai
import assets
import render

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_studio_ai_version() < 2:
    return 1
  if studio_ai_agent_diagnose_smoke() != 0:
    return 2
  if studio_publish_smoke() != 0:
    return 3
  if assets_smoke() != 0:
    return 4
  return render_studio_viewport_smoke()
