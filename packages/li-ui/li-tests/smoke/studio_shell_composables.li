import ui

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_ui_studio_composables_version() < 1:
    return 1
  var layout: StudioShellLayout = layout_studio_shell_adaptive(1920.0, 1080.0)
  if layout.dock.w != studio_dock_width_px():
    return 2
  if layout.inspector.w != studio_inspector_width_px():
    return 3
  if layout_panel_switch_within_budget_ms() != 1:
    return 4
  var frame: PaintFrame = paint_frame_new()
  paint_studio_shell_chrome(frame, layout)
  var vp: Rect = layout_region_rect(layout, studio_region_viewport())
  if vp.w <= 0.0:
    return 5
  if frame.cmd_count != paint_studio_shell_chrome_count():
    return 6
  if frame.last_kind != paint_op_viewport_grid():
    return 7
  return 0
