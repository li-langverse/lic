import http

extern proc li_rt_httpd_load_routing_fixture() -> int32
extern proc li_rt_httpd_serve_routed_once(port: int32) -> int32

def main() raises IO, Alloc -> int
  requires true
  ensures result == 0
  decreases 0
=
  if load_routes_from_routing_fixture() != 0:
    return 10
  var rc: int = li_rt_httpd_serve_routed_once(18081)
  if rc != 0:
    return rc
  return 0
