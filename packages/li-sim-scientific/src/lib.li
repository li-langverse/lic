
import sim
import physics.particles
import physics.rigid
import math.numerics

def li_sim_scientific_version() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

# PH-SIM vertical gap #4 — one MD smoke step per studio tick (no full SimWorld).
def sim_scientific_tick_stub(detail: int) -> int
  requires detail >= 0
  requires detail <= 3
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  var d: int = detail
  var r: SimRunResult = run_md_lj_smoke(d)
  if run_result_ok(r) != 1:
    return 0
  return 1

def heat_axis_coord(i: int) -> float
  requires i >= 0
  ensures true
  decreases i
=
  var base: float = 0.0
  var rem: int = i
  if i >= 120:
    base = 1.2
    rem = i - 120
  if i >= 110:
    if i < 120:
      base = 1.1
      rem = i - 110
  if i >= 100:
    if i < 110:
      base = 1.0
      rem = i - 100
  if i >= 90:
    if i < 100:
      base = 0.9
      rem = i - 90
  if i >= 80:
    if i < 90:
      base = 0.8
      rem = i - 80
  if i >= 70:
    if i < 80:
      base = 0.7
      rem = i - 70
  if i >= 60:
    if i < 70:
      base = 0.6
      rem = i - 60
  if i >= 50:
    if i < 60:
      base = 0.5
      rem = i - 50
  if i >= 40:
    if i < 50:
      base = 0.4
      rem = i - 40
  if i >= 30:
    if i < 40:
      base = 0.3
      rem = i - 30
  if i >= 20:
    if i < 30:
      base = 0.2
      rem = i - 20
  if i >= 10:
    if i < 20:
      base = 0.1
      rem = i - 10
  var ones: float = 0.0
  if rem == 0:
    ones = 0.0
  if rem == 1:
    ones = 0.01
  if rem == 2:
    ones = 0.02
  if rem == 3:
    ones = 0.03
  if rem == 4:
    ones = 0.04
  if rem == 5:
    ones = 0.05
  if rem == 6:
    ones = 0.06
  if rem == 7:
    ones = 0.07
  if rem == 8:
    ones = 0.08
  if rem == 9:
    ones = 0.09
  return base + ones

# Pure-Li smoke: separable coordinate field sum on 128×128 (grid setup path; stencil blocked on E0201).
def heat_2d_field_init_sum() -> float
  requires true
  ensures true
  decreases 0
=
  var acc: float = 0.0
  var i0: int = 0
  while i0 < 128
    var j0: int = 0
    while j0 < 128
      var x0: float = heat_axis_coord(i0)
      var y0: float = heat_axis_coord(j0)
      acc = acc + x0 * y0
      j0 = j0 + 1
    i0 = i0 + 1
  return acc

def run_num_dot_axpy_smoke(detail: int) -> SimRunResult
  requires detail >= 0
  requires detail <= 3
  ensures result.ok == 1
  ensures result.algo_id == 1
  ensures result.detail_emitted == detail
  decreases 0
=
  var r: SimRunResult
  r.ok = 1
  r.algo_id = algo_num_dot_axpy()
  r.vertical_id = 0
  r.checksum = num_dot_axpy_smoke_checksum()
  r.detail_emitted = detail
  return r


def run_md_lj_smoke(detail: int) -> SimRunResult
  requires detail >= 0
  requires detail <= 3
  ensures result.ok == 1
  ensures result.algo_id == 101
  ensures result.detail_emitted == detail
  decreases 0
=
  var f: float = lj_force_scalar(1.12, 1.0, 1.0, 2.5)
  var r: SimRunResult
  r.ok = 1
  r.algo_id = algo_md_lj_cutoff_mic()
  r.vertical_id = vertical_md_lennard_jones()
  r.checksum = f
  r.detail_emitted = detail
  return r

def run_heat_smoke(detail: int) -> SimRunResult
  requires detail >= 0
  requires detail <= 3
  ensures result.ok == 1
  ensures result.algo_id == 201
  ensures result.detail_emitted == detail
  decreases 0
=
  var r: SimRunResult
  r.ok = 1
  r.algo_id = algo_pde_heat_explicit_2d()
  r.vertical_id = vertical_pde_heat_2d()
  r.checksum = heat_2d_field_init_sum()
  r.detail_emitted = detail
  return r

def run_rigid_smoke(detail: int) -> SimRunResult
  requires detail >= 0
  requires detail <= 3
  ensures result.ok == 1
  ensures result.detail_emitted == detail
  decreases 0
=
  var body: RigidBody
  body.px = 0.0
  body.py = 0.0
  body.pz = 0.0
  body.vx = 1.0
  body.vy = 0.0
  body.vz = 0.0
  body.inv_mass = 1.0
  body.radius = 0.5
  rigid_integrate_semi_implicit(body, 0.0, 0.0, -9.81, 0.01)
  var r: SimRunResult
  r.ok = 1
  r.algo_id = algo_rigid_semi_implicit()
  r.vertical_id = vertical_gaming_rigid()
  r.checksum = body.pz
  r.detail_emitted = detail
  return r

def run_algo_registry_stub(algo_id: int, detail: int) -> SimRunResult
  requires detail >= 0
  requires detail <= 3
  requires algo_in_registry(algo_id) == 1
  ensures result.ok == 1
  ensures result.algo_id == algo_id
  ensures result.detail_emitted == detail
  decreases 0
=
  var vert: int = 0
  if algo_id >= 101:
    if algo_id <= 117:
      vert = vertical_md_lennard_jones()
  if algo_id >= 201:
    if algo_id <= 216:
      vert = vertical_pde_heat_2d()
  if algo_id >= 301:
    if algo_id <= 305:
      vert = vertical_gaming_rigid()
  if algo_id >= 401:
    if algo_id <= 432:
      vert = vertical_qm_dft()
  var r: SimRunResult
  r.ok = 1
  r.algo_id = algo_id
  r.vertical_id = vert
  r.checksum = 1.001
  r.detail_emitted = detail
  return r

def run_algo(algo_id: int, detail: int) -> SimRunResult
  requires detail >= 0
  requires detail <= 3
  requires algo_id > 0
  ensures result.detail_emitted == detail
  decreases 0
=
  var reg_chk: int = algo_id
  var reg_run: int = algo_id
  if algo_id == algo_num_dot_axpy():
    var d_num: int = detail
    return run_num_dot_axpy_smoke(d_num)
  if algo_id == algo_md_lj_cutoff_mic():
    var d0: int = detail
    return run_md_lj_smoke(d0)
  if algo_id == algo_md_integrator_verlet():
    var d1: int = detail
    return run_md_lj_smoke(d1)
  if algo_id == algo_pde_heat_explicit_2d():
    var d2: int = detail
    return run_heat_smoke(d2)
  if algo_id == algo_rigid_semi_implicit():
    var d3: int = detail
    return run_rigid_smoke(d3)
  if algo_in_registry(reg_chk) == 1:
    var d4: int = detail
    return run_algo_registry_stub(reg_run, d4)
  var bad: SimRunResult
  var d5: int = detail
  bad.ok = 0
  bad.algo_id = algo_id
  bad.vertical_id = 0
  bad.checksum = 0.0
  bad.detail_emitted = d5
  return bad

def run_simulation(vertical_id: int, detail: int) -> SimRunResult
  requires detail >= 0
  requires detail <= 3
  requires vertical_id > 0
  ensures result.detail_emitted == detail
  decreases 0
=
  if vertical_id == vertical_md_lennard_jones():
    var d0: int = detail
    return run_md_lj_smoke(d0)
  if vertical_id == vertical_pde_heat_2d():
    var d1: int = detail
    return run_heat_smoke(d1)
  if vertical_id == vertical_gaming_rigid():
    var d2: int = detail
    return run_rigid_smoke(d2)
  if vertical_id == vertical_qm_dft():
    var d3: int = detail
    return run_algo(algo_qm_dft_scf_energy(), d3)
  var bad: SimRunResult
  var d4: int = detail
  bad.ok = 0
  bad.algo_id = 0
  bad.vertical_id = vertical_id
  bad.checksum = 0.0
  bad.detail_emitted = d4
  return bad
