# G-vc: per-field ensures on Vec3 return — component-wise witness vs cross-product CallProc.
type Vec3 = object
  public x: float
  public y: float
  public z: float

def vec3_add(a: Vec3, b: Vec3) -> Vec3
  requires true
  ensures result.x == a.x + b.x
  ensures result.y == a.y + b.y
  ensures result.z == a.z + b.z
  decreases 0
=
  var r: Vec3
  r.x = a.x + b.x
  r.y = a.y + b.y
  r.z = a.z + b.z
  return r

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var a: Vec3
  a.x = 1.0
  a.y = 2.0
  a.z = 3.0
  var b: Vec3
  b.x = 4.0
  b.y = 5.0
  b.z = 6.0
  var c: Vec3 = vec3_add(a, b)
  return 0
