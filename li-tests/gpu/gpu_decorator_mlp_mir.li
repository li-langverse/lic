# WP-GPU-06: @gpu on mlp-named def → kernel_id 2 launch prologue.

@gpu
def mlp_scale(x: float) -> float
  requires true
  ensures result == x + 1.0
  decreases 0
=
  return x + 1.0

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if mlp_scale(2.0) != 3.0:
    return 1
  return 0
