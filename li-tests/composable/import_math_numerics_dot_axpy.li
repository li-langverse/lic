import math.numerics

def smoke_num_dot_axpy() -> int
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  var c: float = num_dot_axpy_smoke_checksum()
  if c < 97.9:
    return 1
  if c > 98.1:
    return 1
  return 0

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  return smoke_num_dot_axpy()
