import sim
import sim.scientific

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var md_oracle: float = sim_scientific_oracle_checksum_md()
  var heat_oracle: float = sim_scientific_oracle_checksum_heat()
  var md105: SimRunResult = run_algo(105, 1)
  if run_result_ok(md105) != 1:
    return 1
  if md105.algo_id != 105:
    return 2
  if md105.checksum != md_oracle:
    return 3
  if md105.checksum == 1.001:
    return 4
  var heat210: SimRunResult = run_algo(210, 2)
  if run_result_ok(heat210) != 1:
    return 5
  if heat210.algo_id != 210:
    return 6
  if heat210.checksum != heat_oracle:
    return 7
  if heat210.checksum == 1.001:
    return 8
  var rigid302: SimRunResult = run_algo(302, 0)
  if run_result_ok(rigid302) != 1:
    return 9
  if rigid302.algo_id != 302:
    return 10
  if rigid302.checksum == 1.001:
    return 11
  var qm418: SimRunResult = run_algo(algo_qm_dft_scf_energy(), 0)
  if run_result_ok(qm418) != 1:
    return 12
  if qm418.checksum != 1.001:
    return 13
  return 0
