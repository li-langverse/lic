{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Li World Studio theme override",
  "description": "Partial CSS custom properties applied on top of built-in aurora defaults when data-theme=custom.",
  "type": "object",
  "properties": {
    "name": { "type": "string", "maxLength": 32 },
    "tokens": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^(#[0-9a-fA-F]{3,8}|rgba?\\([^)]+\\))$"
      },
      "properties": {
        "bg-deep": {},
        "bg-surface": {},
        "bg-elevated": {},
        "text": {},
        "muted": {},
        "accent": {},
        "agent": {},
        "pass": {},
        "warn": {},
        "fail": {},
        "border-focus": {}
      }
    }
  },
  "required": ["tokens"]
}
