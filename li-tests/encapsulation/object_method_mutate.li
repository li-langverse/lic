type Counter = object
  public value: int

def Counter_bump(self: var Counter) -> Counter
  requires true
  ensures result.value == self.value
  decreases 0
=
  self.value = self.value + 1
  return self

def main() -> int
  requires true
  ensures result == 2
  decreases 0
=
  var c: Counter
  c.value = 1
  c = Counter_bump(c)
  return c.value
