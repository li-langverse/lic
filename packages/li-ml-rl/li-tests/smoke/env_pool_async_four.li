import ml_rl
import sim

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if ml_rl_async_env_count() < 4:
    return 1
  var sess: SimSessionStub = sim_session_stub_default()
  sim_session_apply_studio_profile(2, sess)
  if ml_rl_env_pool_async_collect(sess, 0.02) != sim_status_ok():
    return 2
  if sess.tick != ml_rl_async_env_count():
    return 3
  if sim_session_replay_last_tick(sess) != ml_rl_async_env_count():
    return 4
  return 0
