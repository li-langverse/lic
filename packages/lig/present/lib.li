  requires true
  ensures result == 0
  decreases 0
=
  return 0

def lig_native_pixel_source_host_cpu() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def lig_native_pixel_source_paint_blit() -> int
  requires true
  ensures result == 2
  decreases 0
=
  return 2

def lig_native_pixel_source_wgpu_readback() -> int
  requires true
  ensures result == 3
  decreases 0
=
  return 3

def lig_native_pixel_source_wgpu_draw_list() -> int
  requires true
  ensures result == 4
  decreases 0
=
  return 4

def lig_kernel_present_blit_rgba8() -> int
  requires true
  ensures result == 3
  decreases 0
=
  return 3

def lig_kernel_present_wgpu_readback() -> int
  requires true
  ensures result == 4
  decreases 0
=
  return 4

def lig_present_wgpu_readback_active() -> int raises IO
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  return li_rt_lig_wgpu_readback_active()

def lig_backend_webgpu() -> int
  requires true
  ensures result == 4
  decreases 0
=
  return 4

def lig_present_status_ok() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def lig_present_status_fail() -> int
  requires true
  ensures result == 0
  decreases 0
=
  return 0

def lig_wgpu_smoke_status_pass() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def lig_wgpu_smoke_status_fail() -> int
  requires true
  ensures result == 0
  decreases 0
=
  return 0

type LigSwapchain = object
  public viewport_w: float
  public viewport_h: float
  public backend_id: int
  public swapchain_ok: int
  public adapter_ok: int
  public surface_ok: int

type LigPresentFrame = object
  public frame_id: int
  public presented: int
  public native_pixels: int
  public native_pixel_source: int
  public dt_ms: float

type LigWgpuSmoke = object
  public backend_id: int
  public status: int
  public adapter_ok: int
  public surface_ok: int
  public swapchain: LigSwapchain

def lig_present_swapchain_create(vp_w: float, vp_h: float) -> LigSwapchain raises IO
  requires vp_w >= 0.0
  requires vp_h >= 0.0
  ensures result.viewport_w == vp_w
  ensures result.viewport_h == vp_h
  ensures result.backend_id == lig_backend_webgpu()
  decreases 0
=
  var out: LigSwapchain
  out.viewport_w = vp_w
  out.viewport_h = vp_h
  out.backend_id = lig_backend_webgpu()
  out.adapter_ok = 1
  var iw: int = 0
  var ih: int = 0
  if vp_w > 0.0:
    iw = 1
  if vp_h > 0.0:
    ih = 1
  if vp_w >= 64.0:
    iw = 1280
  if vp_h >= 36.0:
    ih = 720
  out.swapchain_ok = li_rt_lig_wgpu_swapchain_create(iw, ih)
  out.surface_ok = 0
  if out.swapchain_ok == lig_present_status_ok():
    out.surface_ok = 1
  return out

def lig_present_frame(swap: LigSwapchain, frame_id: int) -> LigPresentFrame raises IO
  requires frame_id >= 0
  requires swap.backend_id == lig_backend_webgpu()
  ensures result.frame_id == frame_id
  decreases frame_id
=
  var out: LigPresentFrame
  out.frame_id = frame_id
  out.dt_ms = li_rt_lig_host_present_dt_ms()
  out.native_pixels = li_rt_lig_host_native_pixels()
  out.native_pixel_source = li_rt_lig_host_native_pixel_source()
  out.presented = li_rt_lig_wgpu_present_frame(swap.swapchain_ok)
  if li_rt_lig_host_present_active() != 1:
    out.native_pixels = 0
    out.native_pixel_source = lig_native_pixel_source_none()
  return out

def lig_present_host_native_pixel_source_flag() -> int raises IO
  requires true
  ensures result >= 0
  ensures result <= 4
  decreases 0
=
  return li_rt_lig_host_native_pixel_source()

def lig_wgpu_draw_list_submit(vp_w: float, vp_h: float, cmd_count: int, pbr_tag: int) -> int raises IO
  requires vp_w >= 0.0
  requires vp_h >= 0.0
  requires cmd_count >= 0
  requires pbr_tag >= 21
  requires pbr_tag <= 27
  ensures result >= 0
  ensures result <= 1
  decreases cmd_count
=
  var iw: int = 0
  var ih: int = 0
  if vp_w >= 64.0:
    iw = 1280
  if vp_h >= 36.0:
    ih = 720
  return li_rt_lig_wgpu_draw_list_submit(iw, ih, cmd_count, pbr_tag)

def lig_present_blit_profile_tag_h_px(profile_id: int) -> int
  requires profile_id >= 1
  requires profile_id <= 7
  ensures result >= 21
  ensures result <= 27
  decreases profile_id
=
  if profile_id == 1:
    return 21
  if profile_id == 2:
    return 22
  if profile_id == 3:
    return 23
  if profile_id == 4:
    return 24
  if profile_id == 5:
    return 25
  if profile_id == 6:
    return 26
  return 27

def lig_present_wgpu_readback_paint_summary(vp_w: float, vp_h: float, profile_id: int, paint_cmd_count: int) -> int raises IO
  requires vp_w >= 0.0
  requires vp_h >= 0.0
  requires profile_id >= 1
  requires profile_id <= 7
  requires paint_cmd_count >= 0
  ensures result >= 0
  ensures result <= 1
  decreases paint_cmd_count
=
  var iw: int = 0
  var ih: int = 0
  if vp_w >= 64.0:
    iw = 1280
  if vp_h >= 36.0:
    ih = 720
  var tag_i: int = lig_present_blit_profile_tag_h_px(profile_id)
  return li_rt_lig_wgpu_readback_stub(iw, ih, profile_id, paint_cmd_count, tag_i)

def lig_present_blit_paint_summary(vp_w: float, vp_h: float, profile_id: int, paint_cmd_count: int) -> int raises IO
  requires vp_w >= 0.0
  requires vp_h >= 0.0
  requires profile_id >= 1
  requires profile_id <= 7
  requires paint_cmd_count >= 0
  ensures result >= 0
  ensures result <= 1
  decreases paint_cmd_count
=
  if lig_present_wgpu_readback_active() == 1:
    return lig_present_wgpu_readback_paint_summary(vp_w, vp_h, profile_id, paint_cmd_count)
  var iw: int = 0
  var ih: int = 0
  if vp_w >= 64.0:
    iw = 1280
  if vp_h >= 36.0:
    ih = 720
  var tag_i: int = lig_present_blit_profile_tag_h_px(profile_id)
  return li_rt_lig_present_blit_rgba8(iw, ih, profile_id, paint_cmd_count, tag_i)

def lig_present_host_active() -> int raises IO
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  return li_rt_lig_host_present_active()

def lig_present_surface_ok() -> int raises IO
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  return li_rt_lig_present_surface_ok()

def lig_present_host_dt_ms() -> float raises IO
  requires true
  ensures result >= 0.0
  decreases 0
=
  return li_rt_lig_host_present_dt_ms()

def lig_present_host_native_pixels_flag() -> int raises IO
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  return li_rt_lig_host_native_pixels()

def lig_wgpu_smoke_run() -> LigWgpuSmoke raises IO, Alloc
  requires true
  ensures result.adapter_ok == 1
  ensures result.surface_ok >= 0
  ensures result.surface_ok <= 1
  decreases 0
=
  var s: LigWgpuSmoke
  s.backend_id = lig_backend_webgpu()
  s.swapchain = lig_present_swapchain_create(1280.0, 720.0)
  s.adapter_ok = s.swapchain.adapter_ok
  s.surface_ok = lig_present_surface_ok()
  s.status = lig_wgpu_smoke_status_fail()
  if s.surface_ok == 1:
    s.status = lig_wgpu_smoke_status_pass()
  return s

def lig_wgpu_smoke_passed(smoke: LigWgpuSmoke) -> int
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  if smoke.status == lig_wgpu_smoke_status_pass():
    if smoke.backend_id == lig_backend_webgpu():
      if smoke.adapter_ok == 1:
        return 1
  return 0

def lig_wgpu_smoke_surface_ready(smoke: LigWgpuSmoke) -> int
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  return smoke.surface_ok
