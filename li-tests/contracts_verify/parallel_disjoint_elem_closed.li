def par_disjoint_elem(buf: var array[8, float]) -> unit
  requires true
  ensures true
  decreases 0
=
  parallel for j in 0..<8
    requires disjoint_elem(j, buf)
    decreases 8 - j
  =
    buf[j] = 0.0

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var buf: array[8, float]
  par_disjoint_elem(buf)
  return 0
