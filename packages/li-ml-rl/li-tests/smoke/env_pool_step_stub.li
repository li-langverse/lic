import sim
import ml.rl

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var pool: EnvPoolStub = env_pool_stub_default()
  if env_pool_activate(pool) != 0:
    return 1
  var sess: SimSessionStub = sim_session_stub_default()
  sim_session_apply_studio_profile(2, sess)
  if env_pool_step(pool, sess, 0.02) != sim_status_ok():
    return 5
  if sess.tick != 1:
    return 6
  return 0
