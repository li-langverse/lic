import render

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_render_version() < 3:
    return 1
  if li_std_lig_version() < 2:
    return 2
  if li_std_gui_version() < 1:
    return 3
  var layout: StudioShellLayout = layout_studio_shell_adaptive(1280.0, 720.0)
  var vp: ViewportRegion = gui_viewport_region_from_layout(layout)
  var smoke: RenderViewportSmoke = render_wgpu_viewport_smoke_pure(vp)
  if render_viewport_smoke_ok(smoke) != 1:
    return 4
  var counter: RenderFpsCounter = render_bench_fps_counter_simulate()
  if render_fps_counter_meets_target(counter) != 1:
    return 5
  return 0
