import render
import gui

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var layout: ShellLayout = gui_shell_layout_default()
  var vp: ViewportRegion = gui_viewport_region_from_layout(layout)
  var smoke: RenderViewportSmoke = render_wgpu_draw_list_smoke_pure(vp, 1)
  if render_wgpu_draw_list_smoke_ok(smoke) != 1:
    return 1
  var list: RenderDrawList = render_draw_list_new()
  render_draw_list_push_clear(list, 0.05, 0.07, 0.1)
  var mat: RenderPbrLiteMaterial = render_pbr_lite_material_default()
  render_draw_list_push_mesh(list, 1, mat)
  render_draw_list_push_particles(list, 1000, mat)
  if render_draw_list_submit_pure(list) != 1:
    return 2
  if list.cmd_count != 3:
    return 3
  if list.mesh_count != 1:
    return 4
  if list.particle_count != 1000:
    return 5
  return 0
