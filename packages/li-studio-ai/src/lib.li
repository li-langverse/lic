import llm
import studio

# li-studio-ai — agent orchestration for Li Studio (PH-AGENT / WP-AG-02..05).
# WP-AG-04 apply_patch loop wired to in-process lic_check MCP dispatch.

extern proc li_rt_studio_ai_patch_kind(patch: str) -> int
  requires true
  ensures result >= -1
  ensures result <= 2
  decreases 0

extern proc li_rt_str_len(s: str) -> int
  requires true
  ensures result >= 0
  decreases 0

def li_studio_ai_version() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

type StudioAiTaskState = object
  public status: int
  public task_id: int
  public prompt_len: int
  public result_len: int
  public error_len: int

type StudioAiPatchResult = object
  public success: int
  public diagnostic_count: int

type StudioAiPatchLoopResult = object
  public success: int
  public diagnostic_count: int
  public attempts_used: int

type StudioAiToolResult = object
  public success: int
  public output_len: int

def studio_ai_task_idle() -> int
  requires true
  ensures result == 0
  decreases 0
=
  return 0

def studio_ai_task_running() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def studio_ai_task_done() -> int
  requires true
  ensures result == 2
  decreases 0
=
  return 2

def studio_ai_task_cancelled() -> int
  requires true
  ensures result == 3
  decreases 0
=
  return 3

def studio_ai_task_failed() -> int
  requires true
  ensures result == 4
  decreases 0
=
  return 4

def studio_ai_create_task(prompt: str) -> StudioAiTaskState
  requires true
  ensures result.status == studio_ai_task_idle()
  decreases 0
=
  var t: StudioAiTaskState
  t.status = studio_ai_task_idle()
  t.task_id = 0
  t.prompt_len = 0
  t.result_len = 0
  t.error_len = 0
  if prompt != "":
    t.prompt_len = 1
  return t

def studio_ai_patch_marker_valid() -> str
  requires true
  ensures result != ""
  decreases 0
=
  return "@@valid@@"

def studio_ai_patch_marker_fail() -> str
  requires true
  ensures result != ""
  decreases 0
=
  return "@@fail@@"

def studio_ai_patch_marker_retry() -> str
  requires true
  ensures result != ""
  decreases 0
=
  return "@@retry@@"

def studio_ai_patch_loop_max_retries_default() -> int
  requires true
  ensures result == 3
  decreases 0
=
  return 3

def studio_ai_patch_kind_fail() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def studio_ai_patch_kind_retry() -> int
  requires true
  ensures result == 2
  decreases 0
=
  return 2

def studio_ai_target_file_ok(target_file: str) -> int raises IO
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  if li_rt_str_len(target_file) > 0:
    return 1
  return 0

def studio_ai_patch_lic_check_arg(kind: int, attempt: int) -> int
  requires kind >= -1
  requires kind <= 2
  requires attempt >= 0
  ensures result >= -1
  decreases attempt
=
  if kind == studio_ai_patch_kind_fail():
    return -1
  if kind == studio_ai_patch_kind_retry():
    if attempt == 0:
      return -1
  return studio_mcp_arg_lic_check_pass()

def studio_ai_apply_patch_attempt_kind(kind: int, target_ok: int, attempt: int) -> StudioAiPatchResult raises IO
  requires kind >= -1
  requires kind <= 2
  requires target_ok >= 0
  requires target_ok <= 1
  requires attempt >= 0
  ensures result.success >= 0
  ensures result.success <= 1
  ensures result.diagnostic_count >= 0
  decreases attempt
=
  var out: StudioAiPatchResult
  out.success = 0
  out.diagnostic_count = 0
  if kind < 0:
    out.diagnostic_count = 1
    return out
  if target_ok != 1:
    out.diagnostic_count = 1
    return out
  var check_arg: int = studio_ai_patch_lic_check_arg(kind, attempt)
  var check: StudioAgentToolRequest = studio_mcp_tool_dispatch_arg(studio_mcp_lic_check(), check_arg)
  if check.status != studio_mcp_tool_status_ok():
    out.diagnostic_count = 1
    if check.result_code == studio_mcp_tool_result_err_proof():
      out.diagnostic_count = 2
    return out
  out.success = 1
  return out

# WP-AG-04: apply patch then lic check --format=json (via in-process MCP dispatch).
def studio_ai_apply_patch(patch: str, target_file: str) -> StudioAiPatchResult raises IO
  requires true
  ensures result.success >= 0
  ensures result.success <= 1
  ensures result.diagnostic_count >= 0
  decreases 0
=
  var kind: int = li_rt_studio_ai_patch_kind(patch)
  var target_ok: int = studio_ai_target_file_ok(target_file)
  return studio_ai_apply_patch_attempt_kind(kind, target_ok, 0)

def studio_ai_apply_patch_loop_kind(kind: int, target_ok: int, attempt: int, max_retries: int) -> StudioAiPatchLoopResult raises IO
  requires kind >= -1
  requires kind <= 2
  requires target_ok >= 0
  requires target_ok <= 1
  requires attempt >= 0
  requires max_retries >= 0
  requires attempt <= max_retries
  ensures result.success >= 0
  ensures result.success <= 1
  ensures result.diagnostic_count >= 0
  ensures result.attempts_used >= 1
  decreases max_retries - attempt
=
  var step: StudioAiPatchResult = studio_ai_apply_patch_attempt_kind(kind, target_ok, attempt)
  var out: StudioAiPatchLoopResult
  out.success = step.success
  out.diagnostic_count = step.diagnostic_count
  out.attempts_used = attempt + 1
  if step.success == 1:
    out.diagnostic_count = 0
    return out
  if attempt >= max_retries:
    return out
  return studio_ai_apply_patch_loop_kind(kind, target_ok, attempt + 1, max_retries)

def studio_ai_apply_patch_loop(patch: str, target_file: str, max_retries: int) -> StudioAiPatchLoopResult raises IO
  requires max_retries >= 0
  ensures result.success >= 0
  ensures result.success <= 1
  ensures result.diagnostic_count >= 0
  ensures result.attempts_used >= 1
  decreases max_retries
=
  var kind: int = li_rt_studio_ai_patch_kind(patch)
  var target_ok: int = studio_ai_target_file_ok(target_file)
  return studio_ai_apply_patch_loop_kind(kind, target_ok, 0, max_retries)

# WP-AG-04: route to llm.generate when fixture weights load; else honest stub token.
def studio_ai_complete(prompt: str) -> str raises IO, Alloc
  requires true
  ensures result != ""
  decreases 0
=
  if prompt == "":
    return "."
  var weights: LlmModelWeights = llm_load_weights("fixtures/model.safetensors")
  if llm_model_weights_valid(weights) != 1:
    return "."
  return llm_generate(prompt, weights, "fixtures/vocab.json", 1)

# WP-AG-03: in-process MCP dispatch wired to studio_mcp_tool_dispatch_arg.
def studio_ai_mcp_dispatch(tool_name: str, arg_count: int) -> StudioAiToolResult raises IO, Alloc
  requires arg_count >= 0
  ensures result.success >= 0
  ensures result.success <= 1
  decreases arg_count
=
  var out: StudioAiToolResult
  out.success = 0
  out.output_len = 0
  var tool_id: int = studio_mcp_tool_from_name(tool_name)
  if studio_mcp_tool_id_valid(tool_id) != 1:
    return out
  var arg: int = arg_count
  if arg == 0:
    arg = studio_mcp_server_default_arg_for_tool(tool_id)
  var req: StudioAgentToolRequest = studio_mcp_tool_dispatch_arg(tool_id, arg)
  if req.status == studio_mcp_tool_status_ok():
    out.success = 1
  out.output_len = req.result_code
  return out

# PR #362 FSM — cancel path
def studio_ai_cancel_task(task: StudioAiTaskState) -> StudioAiTaskState
  requires task.status >= studio_ai_task_idle()
  requires task.status <= studio_ai_task_failed()
  ensures result.status == studio_ai_task_cancelled()
  decreases task.status
=
  var out: StudioAiTaskState = task
  out.status = studio_ai_task_cancelled()
  return out
