def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var A: array[2, array[3, float]]
  var B: array[3, array[2, float]]
  var C: array[2, array[2, float]]
  A[0][0] = 1.0
  A[0][1] = 2.0
  A[0][2] = 3.0
  A[1][0] = 4.0
  A[1][1] = 5.0
  A[1][2] = 6.0
  B[0][0] = 7.0
  B[0][1] = 8.0
  B[1][0] = 9.0
  B[1][1] = 10.0
  B[2][0] = 11.0
  B[2][1] = 12.0
  C = A @ B
  return 0
