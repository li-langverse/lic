# M1.5 leak_censor oracle — TOML load + runtime scrub selftest (C).
import http

extern proc li_rt_httpd_leak_censor_enabled() -> int
  requires true
  ensures 0 <= result
  ensures result <= 1

extern proc li_rt_httpd_leak_censor_deny_path_count() -> int
  requires true
  ensures 0 <= result

extern proc li_rt_httpd_leak_censor_pattern_openai() -> int
  requires true
  ensures 0 <= result
  ensures result <= 1

extern proc li_rt_httpd_leak_scrub_selftest() -> int
  requires true
  ensures -3 <= result
  ensures result <= 0

def main() raises IO, Alloc -> int
  requires true
  ensures result == 0
  decreases 0
=
  var cfg: str = "li-tests/config_desugar/good/leak_censor_m15.toml"
  if load_routes_from_toml(cfg) != 0:
    return 1
  if li_rt_httpd_leak_censor_enabled() != 1:
    return 2
  if li_rt_httpd_leak_censor_deny_path_count() < 1:
    return 3
  if li_rt_httpd_leak_censor_pattern_openai() != 1:
    return 4
  if li_rt_httpd_leak_scrub_selftest() != 0:
    return 5
  return 0
