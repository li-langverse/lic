   \"metric\",\n+                \"value\",\n+                \"unit\",\n+                \"git_sha\",\n+                \"cpu_model\",\n+                \"flags\",\n+                \"passed\",\n+            ]\n+        )\n+        w.writerows(rows)\n+    return 0 if ok_all else 1\n+\n+\n+if __name__ == \"__main__\":\n+    sys.exit(main())"
