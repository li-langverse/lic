import studio.ai

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_studio_ai_version() != 0:
    return 1
  var task: StudioAiTaskState = studio_ai_create_task("hello")
  if task.status != studio_ai_task_idle():
    return 2
  if task.prompt_len != 1:
    return 3
  var cancelled: StudioAiTaskState = studio_ai_cancel_task(task)
  if cancelled.status != studio_ai_task_cancelled():
    return 4
  return 0
