import sim
import sim.robotics
import studio

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_sim_robotics_studio_profile_id() != studio_profile_sim_robotics():
    return 1
  if li_sim_robotics_profile_contract() != sim_contract_sim_robotics():
    return 2
  var r: SimRunResult = run_robo_multibody_smoke(0)
  if run_result_ok(r) != 1:
    return 3
  if r.algo_id != algo_robo_multibody_step():
    return 4
  var cfg: StudioProjectConfig = studio_project_config_new(studio_profile_sim_robotics())
  var sess: SimSessionStub = sim_session_stub_default()
  if studio_sim_step_hook(cfg, sess, 0.01) != sim_status_ok():
    return 5
  if sess.tick != 1:
    return 6
  if sess.sim_contract_id != sim_contract_sim_robotics():
    return 7
  if sensor_bus_validate(sess.sensor_bus) != 1:
    return 8
  if sess.sensor_bus.frame_count != 1:
    return 9
  if sess.sensor_bus.last_frame.vertical_id != vertical_sim_robotics():
    return 10
  return 0
