def algo_in_registry(algo_id: int) -> int
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  if algo_id < 1:
    return 0
  if algo_id <= 19:
    return 1
  if algo_id >= 101:
    if algo_id <= 117:
      return 1
  if algo_id >= 201:
    if algo_id <= 216:
      return 1
  if algo_id >= 301:
    if algo_id <= 305:
      return 1
  if algo_id >= 401:
    if algo_id <= 432:
      return 1
  if algo_id >= 501:
    if algo_id <= 505:
      return 1
  if algo_id >= 511:
    if algo_id <= 514:
      return 1
  if algo_id >= 521:
    if algo_id <= 523:
      return 1
  if algo_id >= 601:
    if algo_id <= 610:
      return 1
  if algo_id >= 701:
    if algo_id <= 707:
      return 1
  if algo_id >= 801:
    if algo_id <= 805:
      return 1
  if algo_id >= 901:
    if algo_id <= 903:
      return 1
  return 0

