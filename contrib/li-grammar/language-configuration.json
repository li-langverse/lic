{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(def|proc|type|object|enum|if|else|elif|while|for|parallel for|var|let|import).*(:|=)\\s*$|^\\s*=\\s*$",
    "decreaseIndentPattern": "^\\s*(else|elif)\\b"
  },
  "folding": {
    "offSide": true,
    "markers": {
      "start": "^\\s*#\\s*region",
      "end": "^\\s*#\\s*endregion"
    }
  }
}
