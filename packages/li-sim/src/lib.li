# PH-SIM SIM-0 — studio profile → sim contract (read-only; no stepping).
def sim_contract_unknown() -> int
  requires true
  ensures result == 0
  decreases 0
=
  return 0

def sim_contract_game() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def sim_contract_sim_rl() -> int
  requires true
  ensures result == 2
  decreases 0
=
  return 2

