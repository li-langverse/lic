import sim

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if sim_rl_env_ipc_fork_mode_label() != 4:
    return 1
  var pool: EnvPoolStub = env_pool_stub_default()
  var sess: SimSessionStub = sim_session_stub_default()
  sim_session_apply_studio_profile(2, sess)
  if env_pool_stub_step_fork_ipc(pool, sess, 0.02) != sim_status_ok():
