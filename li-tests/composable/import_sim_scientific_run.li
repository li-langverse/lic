import sim
import sim.scientific

def smoke_sim_outputs() -> int
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  if sim_scientific_oracle_checksum_md() != scientific_oracle_md_lennard_jones():
    return 1
  if sim_scientific_oracle_checksum_heat() != scientific_oracle_pde_heat_2d():
    return 2
  var d_md: int = 0
  var d_heat: int = 1
  var d_robo: int = 0
  var d_qm: int = 0
  var r1: SimRunResult = run_simulation(vertical_md_lennard_jones(), d_md)
  if run_result_ok(r1) != 1:
    return 3
  if r1.checksum <= 0.0:
    return 4
  var r2: SimRunResult = run_algo(algo_pde_heat_explicit_2d(), d_heat)
  if run_result_ok(r2) != 1:
    return 5
  if r2.checksum <= 0.0:
    return 6
  var r3: SimRunResult = run_algo(algo_robo_multibody_step(), d_robo)
  if run_result_ok(r3) != 1:
    return 7
  var r4: SimRunResult = run_algo(algo_qm_dft_scf_energy(), d_qm)
  if run_result_ok(r4) != 1:
    return 8
  return 0
