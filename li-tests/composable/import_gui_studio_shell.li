import gui
import ui

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_gui_version() < 1:
    return 1
  if inspector_section_count() != 3:
    return 2
  var shell: StudioShell = studio_shell_layout_hd()
  var chrome: AdaptiveLayout = adaptive_layout_hd()
  if shell.sidebar.w != chrome.sidebar.w:
    return 3
  if shell.main.w != chrome.main.w:
    return 4
  if shell.inspector.w != chrome.inspector.w:
    return 5
  var doc: UiDocument = ui_document_new()
  var panel: GuiRect = shell.inspector
  var stroke: PaintCmd = paint_rect(0, panel)
  ui_document_attach_paint(doc, stroke)
  if doc.paint_count != 1:
    return 6
  var sidebar: GuiRect = shell.sidebar
  var hit: int = gui_hit_test_rect(sidebar, 10.0, 10.0)
  if hit != 1:
    return 7
  var row: InspectorRow = inspector_row_new(1, 2, 0)
  if row.advanced != 0:
    return 8
  return 0
