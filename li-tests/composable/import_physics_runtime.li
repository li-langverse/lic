import physics.rigid

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var v: int = li_std_physics_rigid_version()
  if v < 1:
    return 1
  var body: RigidBody
  body.px = 0.0
  body.py = 0.0
  body.pz = 1.0
  body.vx = 0.0
  body.vy = 0.0
  body.vz = 0.0
  body.inv_mass = 1.0
  body.radius = 0.5
  rigid_integrate_semi_implicit(body, 0.0, 0.0, -9.81, 0.016)
  if body.pz >= 1.0:
    return 2
  return 0
