import cad

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var a: CadVec3
  a.x = 0.0
  a.y = 0.0
  a.z = 0.0
  var b: CadVec3
  b.x = 1.0
  b.y = 0.0
  b.z = 0.0
  var c: CadVec3
  c.x = 2.0
  c.y = 0.0
  c.z = 0.0
  var t: CadTriangle
  t.a = a
  t.b = b
  t.c = c
  if cad_triangle_is_degenerate(t) != 1:
    return 1
  var m: CadMesh = cad_mesh_new(cad_kernel_mesh_stub())
  if m.kernel_kind != cad_kernel_mesh_stub():
    return 2
  return 0
