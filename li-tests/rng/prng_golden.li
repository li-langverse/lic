# Golden PRNG vectors — seed 42, three prng_next steps (bench LCG, full state).
import rng

def prng_golden_first() -> int
  requires true
  ensures result == 267293721401565306211
  decreases 0
=
  var p: Prng
  prng_seed(p, 42)
  return prng_next(p)

def prng_golden_third() -> int
  requires true
  ensures result == 10825991748531875682998585346365361542306463711213431678281
  decreases 0
=
  var p: Prng
  prng_seed(p, 42)
  discard prng_next(p)
  discard prng_next(p)
  return prng_next(p)

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if prng_golden_first() != 267293721401565306211:
    return 1
  if prng_golden_third() != 10825991748531875682998585346365361542306463711213431678281:
    return 1
  return 0
