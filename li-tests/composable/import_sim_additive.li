# PH-AM-0 — import sim.additive (li-sim-additive composable gate).

import sim.additive

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var v: int = li_sim_additive_version()
  if v < 1:
    return 1
  var f: int = additive_export_print_stub(additive_format_stl(), 10)
  if f != 0:
    return 2
  return 0
