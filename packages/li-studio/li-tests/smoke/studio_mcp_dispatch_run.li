import studio

def main() -> int raises IO
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 9:
    return 1
  var build_req: StudioAgentToolRequest = studio_mcp_tool_dispatch(studio_mcp_lic_build())
  if build_req.status != studio_mcp_tool_status_ok():
    return 10
  var pub_req: StudioAgentToolRequest = studio_mcp_tool_dispatch(studio_mcp_publish_bundle())
  if pub_req.status != studio_mcp_tool_status_ok():
    return 11
  var chem_req: StudioAgentToolRequest = studio_mcp_tool_dispatch(studio_mcp_chem_dft_run())
  if chem_req.status != studio_mcp_tool_status_ok():
    return 12
  if studio_mcp_chem_dft_energy_hartree() != -76.0:
    return 13
  var profile_req: StudioAgentToolRequest = studio_mcp_tool_dispatch(studio_mcp_sim_set_profile())
  if profile_req.status != studio_mcp_tool_status_ok():
    return 14
  if studio_mcp_last_profile_id() != studio_profile_game():
    return 15
  return 0
