import studio

def main() -> int raises IO
  requires true
  ensures result == 0
  decreases 0
=
  var path: str = "/tmp/studio_vertical_capture_smoke.ppm"
  if studio_vertical_capture_ppm(studio_profile_game(), 0, path, 320, 180) != 1:
    return 1
  if studio_vertical_capture_ppm(studio_profile_sim_scientific(), 1, path, 320, 180) != 1:
    return 2
  return 0
