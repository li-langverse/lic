import studio

def smoke_studio_sim_step_stub() -> int
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  var cfg: StudioProjectConfig = studio_project_config_new(studio_profile_sim_scientific())
  var sess: SimSessionStub = sim_session_stub_default()
  if studio_sim_step_hook(cfg, sess, 0.01) != sim_status_ok():
    return 1
  if sess.tick != 1:
    return 1
  if sess.sim_contract_id != sim_contract_sim_scientific():
    return 1
  return 0
