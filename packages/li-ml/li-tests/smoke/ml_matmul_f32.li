import ml

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var a: array[64, float]
  var b: array[64, float]
  var c: array[64, float]
  a[0] = 1.0
  a[1] = 2.0
  a[2] = 3.0
  b[0] = 4.0
  b[1] = 5.0
  b[2] = 6.0
  if ml_matmul_f32(1, 1, 3, a, b, c) != 1:
    return 1
  # 1*4 + 2*5 + 3*6 = 32
  if c[0] < 31.9 || c[0] > 32.1:
    return 2
  return 0
