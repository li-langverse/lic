{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": ".cursor/hooks/session-context.sh"
      }
    ],
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/guard-destructive-git.sh"
      },
      {
        "command": ".cursor/hooks/guard-secrets.sh"
      },
      {
        "command": ".cursor/hooks/guard-direct-push.sh"
      },
      {
        "command": ".cursor/hooks/guard-backup.sh"
      }
    ],
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/remind-governance-docs.sh",
        "matcher": "docs/**"
      },
      {
        "command": ".cursor/hooks/remind-governance-docs.sh",
        "matcher": "proposals/**"
      },
      {
        "command": ".cursor/hooks/remind-stdlib-coverage.sh",
        "matcher": "std/**"
      },
      {
        "command": ".cursor/hooks/hpc-competitive-nudge.sh",
        "matcher": "benchmarks/**"
      },
      {
        "command": ".cursor/hooks/composable-package-nudge.sh",
        "matcher": "packages/**/src/main.li"
      },
      {
        "command": ".cursor/hooks/guard-official-package-ci.sh",
        "matcher": "packages/**"
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/strict-by-default-guard.sh"
      },
      {
        "command": ".cursor/hooks/remind-release-notes.sh"
      },
      {
        "command": ".cursor/hooks/session-audit.sh"
      },
      {
        "command": ".cursor/hooks/open-pr-github.sh"
      },
      {
        "command": ".cursor/hooks/hpc-competitive-nudge.sh"
      }
    ]
  }
}
