import sim.scientific

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var md0: float = scientific_oracle_md_lennard_jones()
  var md1: float = scientific_oracle_md_lennard_jones()
  if md0 != md1:
    return 1
  if md0 <= 0.0:
    return 2
  var heat0: float = scientific_oracle_pde_heat_2d()
  var heat1: float = scientific_oracle_pde_heat_2d()
  if heat0 != heat1:
    return 3
  if heat0 <= 0.0:
    return 4
  if sim_scientific_oracle_checksum_md() != md0:
    return 5
  if sim_scientific_oracle_checksum_heat() != heat0:
    return 6
  var d_md: int = 1
  var d_heat: int = 2
  var r_md: SimRunResult = run_simulation(vertical_md_lennard_jones(), d_md)
  if r_md.checksum <= 0.0:
    return 7
  var r_heat: SimRunResult = run_simulation(vertical_pde_heat_2d(), d_heat)
  if r_heat.checksum <= 0.0:
    return 8
  if sim_scientific_viz_tier_ok(1) != 1:
    return 9
  return 0
