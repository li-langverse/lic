import sim

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var replay: SimReplay = sim_replay_new(8)
  sim_replay_push(replay, 1)
  sim_replay_push(replay, 2)
  if sim_replay_last_tick(replay) != 2:
    return 1
  var sess: SimSessionStub = sim_session_stub_default()
  if sim_reset(sess) != sim_status_ok():
    return 2
  if sim_step(sess, 0.016) != sim_status_ok():
    return 3
  if sim_session_replay_last_tick(sess) != 1:
    return 4
  if sess.replay_count != 1:
    return 5
  return 0
