import sim.viz

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var s0: VizPipelineState = viz_pipeline_init()
  if s0.profile_id != viz_profile_sim_scientific():
    return 1
  var s1: VizPipelineState = viz_pipeline_add_source(s0, viz_source_kind_sphere())
  var s2: VizPipelineState = viz_pipeline_set_display_rep(s1, viz_display_rep_wireframe())
  if s2.display_rep != viz_display_rep_wireframe():
    return 2
  var s3: VizPipelineState = viz_pipeline_apply(s2)
  if s3.pending_apply != 0:
    return 3
  return 0
