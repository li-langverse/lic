# G-par research: disjoint_row(i, grid) claims row i is disjoint, but body writes grid[i][0].
# If this compiles, policy only pattern-matches grid[0][0] (policy_module.cpp), not per-iter rows.
def row_i_alias(grid: var array[8, array[8, f64]]) -> unit
  requires true
  ensures true
  decreases 0
=
  parallel for i in 0..<8
    requires disjoint_row(i, grid)
    decreases 8 - i
  =
    grid[i][0] = grid[i][0] + 1.0
