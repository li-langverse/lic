# G-par / G-dec: proc-level @parallel(disjoint=) inherits to nested `parallel for` only.
# Nested @parallel on plain `for` bypasses check_stmt_parallel (Stmt::For early return).
@cpu
@parallel(disjoint=disjoint_elem)
def par_def_decor_for() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var buf: array[8, f64]
  @parallel
  for i in 0..<8
    buf[i] = 1.0
  return 0
