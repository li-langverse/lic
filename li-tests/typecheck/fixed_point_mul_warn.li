# Fixed-point style: int32 multiply triggers W0501 (warning only; build still ok).
def scaled_product(a: int32, b: int32) -> int32
  requires true
  ensures true
  decreases 0
=
  return a * b

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var x: int32 = 1000i32
  var y: int32 = 2000i32
  var p: int32 = scaled_product(x, y)
  return int(p)
